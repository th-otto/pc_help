screen( sensitive("FRESTORE") )
FRESTORE <ea>              -- \#Privileged\# --

    Restore floating point coprocessor state from <ea>.
    <ea> is first byte of state frame saved by previous \#FSAVE\#.

\#Sizes:\# not applicable

\#CPUs:\# 48

\#Flags:\# unchanged

<ea>: \#(An)\# \#(An)+\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#
\end

screen( sensitive("FSAVE") )
FSAVE <ea>                 -- \#Privileged\# --

    Save floating point coprocessor state to <ea>.
    <ea> is first byte of state frame buffer (unless <ea> = -(An) ).
    Size of state frame in bytes is given in the table below:

            frame | 68881 | 68882 or 68040
            ------+-------+-------+----------------
            NULL  |    4  |    4  | Benign state
            ------+-------+-------+----------------
            IDLE  |   28  |   60  | After exception
            ------+-------+-------+----------------
            BUSY  |  184  |  216  | Mid-process

    This does not include the data registers or control registers,
    which can be saved using \#FMOVEM\# instructions.

\#Sizes:\# not applicable

\#CPUs:\# 48

\#Flags:\# unchanged

<ea>: \#(An)\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#


See also \#FSAVE\#
\end

screen( sensitive("FSCALE") )
FSCALE <ea>,\#FPn\#
FSCALE.X \#FPn\#,\#FPn\#

    Floating point multiply by power of 2.
    \#Dest\# = Dest * pow(2.0, trunc(\#Source\#))

    Combine Dest = mantissa and Source = exponent.

\#Sizes:\# Byte, Word, Long, Single, Double, Extended, Packed

\#CPUs:\# 48

\#OPERR:\# -infinity or +infinity 

<ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
      \#addr\# \##data\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#


See also \#FGETEXP\# and \#FGETMAN\#.
\end


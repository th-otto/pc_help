screen( "max.size" )
/* ******************************************************************
MACRO max.size first,second

Puts the larger of 'first' and 'second' into D0.

   max.b #'a',#'b'   ;will put 'b' into D0
   max.w #0,x        ;will put variable x into D0 if x>0
   max.l A1,A2       ;will put the larger of A0 or A1 into D0
****************************************************************** */

MACRO max.size first,second
LOCAL skip
  MOVE.size first,D0
  CMP.size  second,D0
  BGT       skip
  MOVE.size second,D0
skip:
ENDM
\end

screen( "call_TOS" )
/* ******************************************************************
MACRO call_TOS ntrap,cmd,arg1,size1,arg2,size2,arg3,size3,arg4,size4

All GEMDOS, BIOS, XBIOS, VDI & AES functions are implemented by
TRAP instructions.  This macro will perform any such function call
involving up to four arguments.  Uses label 'npop'.

ntrap = trap number (1=\link("%%GLOBAL%%")GEMDOS\#, 2=\link("%%GLOBAL%%")AES\# & \link("%%GLOBAL%%")VDI\#, 13=\link("%%GLOBAL%%")BIOS\#, 14=\link("%%GLOBAL%%")XBIOS\#)
cmd   = command number
arg1 - arg4   = optional function arguments
size1 - size4 = size of arguments in bytes (1, 2, or 4)

For example, '\link("%%GLOBAL%%")Pterm0\#()' could be implemented by 'call_TOS 1,0'
****************************************************************** */

MACRO call_TOS ntrap,cmd,arg1,size1,arg2,size2,arg3,size3,arg4,size4

npop = 2     ;number bytes to pop off stack.  cmd takes 2 bytes
             ;push arguments onto stack
IFNB arg4
  IF size4 == 1
    move.b  arg4,-(A7)
  ENDIF
  IF size4 == 2
    move.w  arg4,-(A7)
  ENDIF
  IF size4 == 4
    move.l  arg4,-(A7)
  ENDIF
  npop = npop + size4
ENDIF

IFNB arg3
  IF size3 == 1
    move.b  arg3,-(A7)
  ENDIF
  IF size3 == 2
    move.w  arg3,-(A7)
  ENDIF
  IF size3 == 4
    move.l  arg3,-(A7)
  ENDIF
  npop = npop + size3
ENDIF

IFNB arg2
  IF size2 == 1
    move.b  arg2,-(A7)
  ENDIF
  IF size2 == 2
    move.w  arg2,-(A7)
  ENDIF
  IF size2 == 4
    move.l  arg2,-(A7)
  ENDIF
  npop = npop + size2
ENDIF

IFNB arg1
  IF size1 == 1
    move.b  arg1,-(A7)
  ENDIF
  IF size1 == 2
    move.w  arg1,-(A7)
  ENDIF
  IF size1 == 4
    move.l  arg1,-(A7)
  ENDIF
  npop = npop + size1
ENDIF

  move.w  cmd,-(A7)  ;push command onto stack
  trap #ntrap        ;perform trap
  add.l #npop,A7     ;restore stack pointer
ENDM
\end

screen( "multiply_by_constant" )
/* ******************************************************************
MACRO multiply_by_constant ea,constant

Multiplying by powers of two or other constants can often be
implemented faster using shift instructions rather than by MULS.
Output of this macro will be in register D0.
Uses labels bit and shift.

ea = long effective address (anything except D0)
constant >= 0
****************************************************************** */

MACRO multiply_by_constant ea,constant

IFLT constant
  ERROR "multiply_by_constant macro: constant must be >= 0"
ENDIF

IFEQ constant
  clr.l  D0
  EXITM
ENDIF

bit = $4000_0000  ;check bits of constant from left to right
shift = -1        ;number of shifts needed (-1 = nothing in D0)
  REPT 31

  IFGE shift
    shift = shift + 1
    IF shift > 8  ;maximum shift = 8
      asl.l #8,D0
      shift = 1
    ENDIF
  ENDIF

  IFNE bit & constant
    IFLT shift
      move.l ea,D0  ;leftmost non-zero bit in constant
    ELSE
      asl.l #shift,D0
      add.l ea,D0   ;any other non-zero bits in constant
    ENDIF
    shift = 0
  ENDIF

  bit = bit >> 1
  ENDM           ;end of REPT block

IFGT shift
  asl.l #shift,D0
ENDIF
ENDM             ;end of MACRO multiply_by_constant
\end

screen( "auto_resident" )
/* ******************************************************************
             Main program to load a device driver

Calls external function 'init' in \#Supervisor Mode\#.
Remains in RAM after termination.

Note: Object file MUST be first in Project File (PCSTART not used).
      Use BSS segment for all buffers; Malloc not available.
      Set stack size = 0 in linker options.
****************************************************************** */

IMPORT init

TEXT
start:
  pea.l init
  move.w #38,-(A7)   ;Supexec(init)
  trap #14
  addq.l #6,A7

  lea start-256,A0   ;base page address
  move.l #256,D0     ;size of base page
  add.l $C(A0),D0    ;size of text segment
  add.l $14(A0),D0   ;size of data segment
  add.l $1C(A0),D0   ;size of BSS segment

  clr.w -(A7)
  move.l D0,-(A7)
  move.w #$31,-(A7)  ;Ptermres(size,0)
  trap #1
END
\end

screen( "printer_driver" )
/* ******************************************************************
               Interrupt (buffered) printer driver

Buffered printer drivers (even with a small buffer) can significantly
improve speed by allowing the user software to be formatting the next
line while waiting for the printer to catch up (when the user software
and the printer run at about the same speed).

Function 'init' is called from \#auto_resident\# in \#Supervisor Mode\#.
****************************************************************** */

EXPORT init

bufsize = 1024        ;must be a power of 2
HZ_200 = $4BA         ;system timer

TEXT
SUPER
init:                 ;insert printer driver vectors
  lea status_vec,A0
  move.l A0,$55E      ;bcostat_vec device 0
  lea print_vec,A0
  move.l A0,$57E      ;bconout_vec device 0
  lea interrupt_vec,A0
  move.l A0,$100      ;MFP Centronix Busy Exception
  or.b #1,$FFFA09     ;enable printer interrupts (MFP IERB)
  rts

status_vec:           ;return status of printer (0 = full)
  move.w status(PC),D0
  ext.l D0
  rts

print_vec:            ;print a character
  move.w 6(A7),D0     ;get character from stack
  tst.w status(PC)    ;buffer full?
  bne ready
  move.l HZ_200,D1    ;yes, compute 10 sec timeout
  add.l #(10*200),D1
  move.w #$2300,SR    ;enable interrupts
wait:
  tst.w status(PC)    ;is buffer still full?
  bne ready
  cmp.l HZ_200,D1     ;has time expired?
  bhi wait
  clr.l D0            ;yes, signal failure
  subq.w #1,status    ;reset status flag (clears buffer)
  rts

ready:
  move.w #$2700,SR    ;disable interrupts
  move.w head(PC),D1
  cmp.w tail(PC),D1   ;buffer empty?
  bne insert
  btst.b #0,$FFFA01   ;yes, printer busy?  (MFP GPIP)
    bne insert
  bsr putchar         ;no, print character
    bra ok

insert:               ;put character into buffer
  lea iorec(PC),A0
  move.b D0,(A0,D1.W)
  addq.w #1,D1        ;increment head
  and.w #(bufsize-1),D1
  move.w D1,head
  cmp.w tail(PC),D1   ;buffer full?
  bne ok
  clr.w status
ok:
  moveq.l #-1,D0      ;signal success
  rts

interrupt_vec:        ;printer ready for another character
  movem.l D0-D1/A0,-(A7)
  move.w tail(PC),D1  ;Note: head = tail when buffer empty or full
  tst.w status(PC)    ;buffer full?
  beq another
  cmp.w head(PC),D1   ;buffer empty?
  beq empty
another:
  lea iorec(PC),A0    ;print next character
  move.b (A0,D1.W),D0
  bsr putchar
  addq.w #1,D1        ;increment tail
  and.w #(bufsize-1),D1
  move.w D1,tail
  move.w #-1,status   ;buffer not full now
empty:
  bclr #0,$FFFA11     ;clear in-service bit (MFP ISRB)
  movem.l (A7)+,D0-D1/A0
  rte

putchar:              ;send character in D0 to printer
  lea $FF8800,A0      ;sound chip
  move.b #15,(A0)     ;Port B
  move.b D0,2(A0)     ;write character
  move.b #14,(A0)     ;Port A
  move.b (A0),D0
  and.b #(!$20),D0    ;strobe (bit 5) low
  move.b D0,2(A0)
  or.b #$20,D0        ;strobe (bit 5) high
  move.b D0,2(A0)
  rts

DATA
head: dc.w 0          ;location of next byte in iorec to fill
tail: dc.w 0          ;location of next byte in iorec to print
status: dc.w -1       ;0 = buffer full

BSS
iorec: ds.b bufsize   ;buffer
\end

screen( "dble_vector_prod" )
/* ******************************************************************
double dble_vector_prod(int num, double *a, int inca,
                                 double *b, int incb)

Returns vector product of a and b:
  a[0]*b[0] + a[inca]*b[incb] + ... + a[(num-1)*inca]*b[(num-1)*incb]

Uses 68881 FPU (see \link("%%GLOBAL%%")Parameter Passing\#).
******************************************************************* */
EXPORT dble_vector_prod

MC68030
MC68881

dble_vector_prod:
  \#FMOVECR\# #$F,FP0        ;FP0 = 0.0
  SUBQ.W #1,D0           ;if(--num < 0) return(0.0)
  BLT done
  MULS #12,D1            ;inca *= sizeof(double)
  MULS #12,D2            ;incb *= sizeof(double)
loop:
  FMOVE.X (A0),FP1       ;FP1 = *a
  ADDA.L D1,A0           ;a += inca
  FMUL.X (A1),FP1        ;FP1 *= *b
  ADDA.L D2,A1           ;b += incb
  FADD.X FP1,FP0         ;FP0 += FP1
  DBRA.W D0,loop         ;if(--num >= 0) goto loop
done:
  RTS                    ;result is in FP0
\end

screen( capsensitive("Tversion") )
/* ******************************************************************
long Tversion( void )

Returns the TOS Version number.  Must be executed in \#Supervisor Mode\#.
  tos = \link("%%GLOBAL%%")Supexec\#(Tversion).
******************************************************************* */
EXPORT Tversion

Tversion:
  MOVEA $4F2,A0           ;put \#_sysbase\# into A0
  CLR.L D0
  MOVE.W 2(A0),D0         ;put os_version into D0 (see \link("%%GLOBAL%%")SYSHDR\#).
  RTS
\end

screen( "force_media_change" )
;    void force_media_change( int dev )
;
;    Forces a media change on the next access of drive 'dev'.
;    Can handle multiple requests (uses a bit map for drives).
;    Just be sure to access all drives before terminating.

EXPORT force_media_change

media_change = $47E

TEXT
force_media_change:
  move.l drvmap,D1
  bset.l D0,D1                  ;set bit for drive 'dev'
  move.l D1,drvmap

  move.l A2,-(SP)               ;save register A2
  pea init
  move.w #38,-(SP)              ;execute Supexec(init)
  trap #14
  addq.l #6,SP
  move.l (SP)+,A2
  rts

SUPER
init:
  tst.l oldvector               ;is vector already installed?
  bne done
  move.l media_change,oldvector ;save old vector
  move.l A0,media_change        ;install new vector
done:
  clr.l D0
  rts

  DC.L 'XBRA',0                 ;XBRA protocol (no cookie)
oldvector:
  DC.L 0
newvector:
  move.w 4(SP),D0               ;get drive
  move.l drvmap,D1
  bclr.l D0,D1                  ;is this right drive?
  bne restore
  move.l oldvector,A0           ;no, use old vector
  jmp    (A0)

restore:
  move.l D1,drvmap
  tst.l D1                      ;last request?
  bne return
  move.l media_change,D0        ;yes, check interrupt vector
  cmp.l #newvector,D0
  beq okay
xbra:
  move.l D0,A0                  ;new interrupt vector
    move.l -12(A0),D0
    cmp.l    #'XBRA',D0
  bne okay                      ;does not follow XBRA, kill it
    move.l -4(A0),D0
  cmp.l #newvector,D0
    bne xbra
    move.l oldvector,-4(A0)       ;remove new vector from list
    bra reset

okay:
  move.l oldvector,media_change ;restore old vector
reset:
    clr.l oldvector
return:
  moveq.l #2,D0                 ;return definite media change (2) 
  rts

DATA
drvmap:    DC.L 0
\end

screen( capsensitive("ACCset") )
/* ******************************************************************
void ACCset(void);
void ACCreset(void);

There are certain functions which should not be called from an
accessory (after AES has been initialized):

Malloc(), Mxalloc(), Mshrink(), Fcreate(), Fopen() or any stdlib
function which uses these GEMDOS functions, such as malloc() or
fopen().

The reason is that single-tasking TOS will assign the resulting RAM
or files to the application, rather than the accessory, and will
free/close them when the application terminates.

This problem can be solved by bracketing the function call with the
ACCset() - ACCreset() functions:

  ACCset();
  p = Malloc(size);
  ACCreset();

If you call ACCset(), you MUST call ACCreset() before the next AES
call.  Do NOT call ACCreset() before ACCset() has been called.
****************************************************************** */

EXPORT ACCset, ACCreset
IMPORT _BasPag           ;base page pointer provided by \link("%%GLOBAL%%")PCSTART\#

SYSBASE = $4F2           ;OS Header (see \#_sysbase\# and \link("%%GLOBAL%%")SYSHDR\#)
PRUN = $602C             ;for TOS < 1.02
SPAIN = $873C            ;for Spain only 

TEXT
ACCset:
  pea (A2)               ;save A2 to stack (Pure C binding)
  pea set_bpa(PC)
  move.w #38,-(A7)       ;\link("%%GLOBAL%%")Supexec\#(set_bpa)
  trap #14
  addq.l #6,A7
  move.l (A7)+,A2        ;restore A2
  rts

ACCreset:
  move.l save,D0         ;get saved application bpa
  cmp.l _BasPag,D0       ;compare to accessory bpa
  beq done1
  pea (A2)               ;save A2 to stack (Pure C binding)
  pea reset(PC)
  move.w #38,-(A7)       ;\link("%%GLOBAL%%")Supexec\#(reset)
  trap #14
  addq.l #6,A7
  move.l (A7)+,A2        ;restore A2
done1:
  rts

SUPER
set_bpa:
  bsr get_prun           ;returns address in A0
  move.l (A0),save       ;save application bpa
  move.l _BasPag,(A0)    ;set accessory bpa
  rts

reset:
  bsr get_prun           ;returns address in A0
  move.l save(PC),(A0)   ;restore application bpa
  rts

get_prun:
  move.l SYSBASE,A0      ;get sysheader
  move.w 2(A0),D0        ;check TOS version
  cmp.w #$102,D0
  blt old_tos
  move.l $28(A0),A0      ;prun for TOS >= 1.02
  rts
old_tos:
  move.w $1C(A0),D0      ;check country code
  lsr.w #1,D0
  cmp #4,D0              ;check for Spain
  beq spain
  lea PRUN,A0            ;prun for TOS < 1.02
  rts
spain:
  lea SPAIN,A0           ;prun for Spain only
  rts

BSS
save:    ds.l 1
\end


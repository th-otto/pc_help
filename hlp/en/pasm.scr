\#Sizes:\# not applicable

\#CPUs:\# 5

<ea> = \#(An)\# \#(An)+\# \#d(An)\# \#d(An,Rx)\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#
       \#addr\# \#d(PC)\# \#d(PC,Rx)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#

See also \#PSAVE\#
\end

screen( sensitive("PSAVE") )
PSAVE <ea>                -- Not Applicable to Atari --

    Save PMMU registers to RAM.

\#Sizes:\# not applicable

\#CPUs:\# 5

<ea> = \#(An)\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#
       \#addr\#

See also \#PRESTORE\#
\end


screen( sensitive("FMOVE") )
FMOVE <ea>,\#FPn\#
FMOVE \#FPn\#,<ea>
FMOVE.P \#FPn\#,<ea>{Dn}
FMOVE.P \#FPn\#,<ea>{#<k factor>}

    Move to or from floating point register (converting data type).
    FPn = (double) <ea>, <ea> = (type) Fpn.
    <k factor> (or the k factor contained in Dn) = -64 to 63:
      -64 to 0 = 1 - <number of significant digits>.
      1 to 17 = <number of significant digits>.
      18 to 63 same as 17, only set OPERR flag.

\#Sizes:\# Byte, Word, Long, Single, Double, Extended, Packed

\#CPUs:\# 48

\#OPERR:\# cannot convert data type.

\#Source\# <ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
             \#addr\# \##data\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#

\#Dest\# <ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
             \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#


See also \#FMOVE (Control Register)\#, \#FMOVECR\#, \#FMOVEM\# and
\#FMOVEM (Control Registers)\#.
\end

screen( "FMOVE (Control Register)" )
)
FMOVE.L <ea>,FPcr
FMOVE.L FPcr,<ea>

    Move to or from floating point control register.
    FPcr refers to either \#FPCR\#, \#FPSR\# or \#FPIAR\#.

\#Sizes:\# Long

\#CPUs:\# 48

\#OPERR:\# can be set by move to FPSR.

\#Source\# <ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
             \#addr\# \##data\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#
             \#An\# to FPIAR only

\#Dest\# <ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
           \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#
           \#An\# from FPIAR only


See also \#FMOVE\#, \#FMOVECR\#, \#FMOVEM\# and \#FMOVEM (Control Registers)\#
\end

screen( sensitive("FMOVECR") )
FMOVECR.X #<index>,\#FPn\#

    Move floating point constant from ROM to register FPn.
    <index> = $00 -> pi          = 3.1415926535897932
              $0B -> \#FLOG10\#(2.0) = 0.3010299956639812
              $0C -> e           = 2.7182818284590452
              $0D -> \#FLOG2\#(e)    = 1.4426950408889634
              $0E -> \#FLOG10\#(e)   = 0.4342944819032518
              $0F -> 0.0
              $30 -> \#FLOGN\#(2.0)  = 0.6931471805599453
              $31 -> \#FLOGN\#(10.0) = 2.3025850929940457
              $32 -> 1.0E0       = 1.0
              $33 -> 1.0E1       = 10.0
              $34 -> 1.0E2       = 100.0
              $35 -> 1.0E4       = 10000.0
              $36 -> 1.0E8
                  ...
              $3F -> 1.0E4096

\#Sizes:\# Extended

\#CPUs:\# 48

\#OPERR:\# none

See also \#FMOVE\#, \#FMOVE (Control Register)\#, \#FMOVEM\# and
\#FMOVEM (Control Registers)\#.
\end

screen( sensitive("FMOVEM") )
FMOVEM.X <ea>,<FPn list>
FMOVEM.X <FPn list>,<ea>

    Move to or from multiple floating point registers.
    <FPn list> = list of \#FPn\# registers.
      use '-' for a range of registers.
      use '/' to separate ranges or individual registers.


\#Sizes:\# Extended

\#CPUs:\# 48

\#OPERR:\# none

\#Source\# <ea>: \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
             \#addr\# \##data\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#

\#Dest\# <ea>: \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
           \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#


See also \#FMOVE\#, \#FMOVE (Control Register)\#, \#FMOVECR\#, and
\#FMOVEM (Control Registers)\#.
\end

screen( "FMOVEM (Control Registers)" )
FMOVEM.L <ea>,<list>
FMOVEM.L <list>,<ea>

    Move to or from multiple floating point control registers.
    <list> = list of control registers: \#FPCR\#, \#FPSR\# or \#FPIAR\#.
      use '/' to separate registers.

\#Sizes:\# Long

\#CPUs:\# 48

\#OPERR:\# can be set by move to FPSR.

\#Source\# <ea>: \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
             \#addr\# \##data\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#

\#Dest\# <ea>: \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
           \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#


See also \#FMOVE\#, \#FMOVE (Control Register)\#, \#FMOVECR\#, and \#FMOVEM\#.
\end


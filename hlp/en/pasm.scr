screen( sensitive("PFLUSH"),
		sensitive("PFLUSHA") )
PFLUSHA                       -- \#Privileged\# --
PFLUSH <fc>,#mask
PFLUSH <fc>,#mask,<ea>

    Flush PMMU address translation table.
    PFLUSHA flushes everything.
    And mask with <fc> register and flush applicable tables.
    If <ea> is specified, flush only tables including <ea>.

\#Sizes:\# not applicable

\#CPUs:\# 345

<fc> = \#SFC\# or \#DFC\#

mask = 0 ... 7 (bit mask)

<ea> = \#(An)\# \#d(An)\# \#d(An,Rx)\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#
       \#addr\#

See also \#Function Code\# and \#ATC\#.
\end

screen( sensitive("PFLUSHS") )
PFLUSHS <fc>,#mask               -- Not Applicable to Atari --
PFLUSHS <fc>,#mask,<ea>

    Flush PMMU address translation table (shared globally).
    And mask with <fc> register and flush applicable tables.
    If <ea> is specified, flush only tables including <ea>.

\#Sizes:\# not applicable

\#CPUs:\# 5

<fc> = \#SFC\# or \#DFC\#

mask = 0 ... 7 (bit mask)

<ea> = \#(An)\# \#d(An)\# \#d(An,Rx)\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#
       \#addr\#

See also \#Function Code\# and \#ATC\#.
\end


		sensitive("PSLC"),
		sensitive("PSLS"),
		sensitive("PSSC"),
		sensitive("PSSS"),
		sensitive("PSWC"),
		sensitive("PSWS") )
PScc <ea>                  -- Not Applicable to Atari --

    Set <ea> to TRUE (-1) on \link("PMMU Condition Codes")PMMU Condition Code\#, FALSE (0) otherwise.

\#Sizes:\# Byte

\#CPUs:\# 5

<ea> = \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#
       \#addr\#
\end

screen( "PTEST",
		sensitive("PTESTR"),
		sensitive("PTESTW") )
PTESTR <fc>,<ea>,#level          -- Privileged --
PTESTR <fc>,<ea>,#level,\#An\#
PTESTW <fc>,<ea>,#level
PTESTW <fc>,<ea>,#level,\#An\#

    Set \#PMMU Condition Codes\# for simulated access.
    PTESTR simulates read access to <ea>.
    PTESTW simulates write access to <ea>.
    Loads physical address into register An (optional).

\#Sizes:\# not applicable

\#CPUs:\# 345

<fc> = \#SFC\# \#DFC\# \#Dn\# \##data\#

level = 0 ... 7 (search level parameter)

<ea> = \#(An)\# \#d(An)\# \#d(An,Rx)\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#
       \#addr\#

See also \#MOVEC\#, \#Function Code\# and \#ATC\#.
\end


screen( sensitive("SWAP") )
SWAP \#Dn\#

    Swap high and low words of a data register.
    Equivalent to  \#ROL\# 16,Dn  (except for X & C flags).

\#Sizes:\# Word

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 C=0

68000 Time: 4 clocks


See also \#EXG\#
\end

screen( sensitive("TAS") )
TAS <ea>

    Test and set.  (Prevent interrupt between steps.)
    Set \#Condition Codes\# according to <ea>, then sets <ea> |= $80.
    

\#Sizes:\# Byte

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 C=0

Time charts: \#TAS.B\#

<ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#


See also \#CMP\#, \#CMPA\#, \#CMPI\#, \#CMPM\#, \#CMP2\#, \#TST\#
\end

screen( sensitive("TRAP") )
TRAP \##data\#

    Causes a TRAP \link("Exceptions")exception\# (vector 32 + data).
    data = 0 to 15

    TRAP is used by Atari for ROM function calls:
      TRAP #1   ;\link("%%GLOBAL%%")GEMDOS\#
      TRAP #2   ;\link("%%GLOBAL%%")AES\# & \link("%%GLOBAL%%")VDI\#
      TRAP #13  ;\link("%%GLOBAL%%")BIOS\#
      TRAP #14  ;\link("%%GLOBAL%%")XBIOS\#
    Arguments are pushed onto the stack in \link("%%GLOBAL%%")cdecl\# fashion.
    A word function number is then pushed onto the stack.
    The TRAP is executed.

\#Sizes:\# Byte

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 C=0

68000 Time: 34 clocks


See also \#BKPT\#, \#ILLEGAL\#, \#RTE\#, \#TRAPcc\#, \#TRAPV\#
\end

screen( "TRAPcc",
		sensitive("TRAPVS"),
		sensitive("TRAPCC"),
		sensitive("TRAPCS"),
		sensitive("TRAPEQ"),
		sensitive("TRAPF"),
		sensitive("TRAPGE"),
		sensitive("TRAPGT"),
		sensitive("TRAPHI"),
		sensitive("TRAPLE"),
		sensitive("TRAPLS"),
		sensitive("TRAPLT"),
		sensitive("TRAPMI"),
		sensitive("TRAPNE"),
		sensitive("TRAPPL"),
		sensitive("TRAPT"),
		sensitive("TRAPVC") )
TRAPcc
TRAPcc.W \##data\#
TRAPcc.L \##data\#

    Causes a TRAPV \link("Exceptions")exception\# (vector 7) on \#Condition Codes\#.
    data is included in the format 2 stack frame.

\#Sizes:\# Word, Long

\#CPUs:\# 234

\#Flags:\# unchanged


TRAPT same as TRAP
TRAPF same as \#NOP\#

See also \#BKPT\#, \#ILLEGAL\#, \#RTE\#, \#TRAP\#, \#TRAPV\#
\end

screen( sensitive("TRAPV") )
TRAPV

    Causes a TRAPV \link("Exceptions")exception\# (vector 7) on overflow (flag V set).

\#Sizes:\# not applicable

\#CPUs:\# 01234

\#Flags:\# unchanged

68000 Time: 34 clocks


See also \#BKPT\#, \#ILLEGAL\#, \#RTE\#, \#TRAP\#, \#TRAPcc\#
\end

screen( sensitive("TST") )
TST <ea>

    Test.  Set \#Condition Codes\# according to <ea>.
    

\#Sizes:\# Byte, Word, Long

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 C=0

Time charts: \#TST.W\#, \#TST.L\#

<ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#


See also \#CMP\#, \#CMPA\#, \#CMPI\#, \#CMPM\#, \#CMP2\#, \#TAS\#
\end

screen( sensitive("UNLK") )
UNLK \#An\#

    Restore An and A7 using standard stack frame.  (Usually An = A6.)
    Move An to A7, then move (A7)+ to An.

    Reverses action of previous LINK.

\#Sizes:\# not applicable

\#CPUs:\# 01234

\#Flags:\# unchanged

68000 Time: 12 clocks


See also \#LINK\#.
\end

screen( sensitive("UNPK") )
UNPK \#Dn\#,\#Dn\#,\##data\#
UNPK \#-(An)\#,\#-(An)\#,\##data\#

    Convert BCD to ASCII (two digits).
    \#Dest\# = ((\#Source\# & $F) | ((\#Source\# & $F0) << 4)) + data
    data = 0 to 65535  ($3030 for ASCII, $F0F0 for EBCDIC)

\#Sizes:\# Word

\#CPUs:\# 234

\#Flags:\# unchanged


See also \#ABCD\#, \#NBCD\#, \#PACK\#, \#SBCD\#
\end

screen( "MOVE.W" )
\#MOVE\#.W                 68000 Instruction Timing Chart
----------------------------------------------------------------------------+
        |                           Dest                                    |
 Source +----+----+------+-------+-------+-------+--------+--------+--------+
        | Dn | An | (An) | (An)+ | -(An) | d(An) |d(An,Rx)| addr.W | addr.L |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
   Dn   |  4 |  4 |   8  |    8  |    8  |   12  |   14   |   12   |   16   |
   An   |  4 |  4 |   8  |    8  |    8  |   12  |   14   |   12   |   16   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
  (An)  |  8 |  8 |  12  |   12  |   12  |   16  |   18   |   16   |   20   |
  (An)+ |  8 |  8 |  12  |   12  |   12  |   16  |   18   |   16   |   20   |
  -(An) | 10 | 10 |  14  |   14  |   14  |   18  |   20   |   18   |   22   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
  d(An) | 12 | 12 |  16  |   16  |   16  |   20  |   22   |   20   |   24   |
d(An,Rx)| 14 | 14 |  18  |   18  |   18  |   22  |   24   |   22   |   26   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
 addr.W | 12 | 12 |  16  |   16  |   16  |   20  |   22   |   20   |   24   |
 addr.L | 16 | 16 |  20  |   20  |   20  |   24  |   26   |   24   |   28   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
  d(PC) | 12 | 12 |  16  |   16  |   16  |   20  |   22   |   20   |   24   |
d(PC,Rx)| 14 | 14 |  18  |   18  |   18  |   22  |   24   |   22   |   26   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
  #data |  8 |  8 |  12  |   12  |   12  |   16  |   18   |   16   |   20   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
\end

screen( "MOVE.L" )
\#MOVE\#.L                 68000 Instruction Timing Chart
----------------------------------------------------------------------------+
        |                           Dest                                    |
 Source +----+----+------+-------+-------+-------+--------+--------+--------+
        | Dn | An | (An) | (An)+ | -(An) | d(An) |d(An,Rx)| addr.W | addr.L |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
   Dn   |  4 |  4 |  12  |   12  |   12  |   16  |   18   |   16   |   20   |
   An   |  4 |  4 |  12  |   12  |   12  |   16  |   18   |   16   |   20   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
  (An)  | 12 | 12 |  20  |   20  |   20  |   24  |   26   |   24   |   28   |
  (An)+ | 12 | 12 |  20  |   20  |   20  |   24  |   26   |   24   |   28   |
  -(An) | 14 | 14 |  22  |   22  |   22  |   26  |   28   |   26   |   30   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
  d(An) | 16 | 16 |  24  |   24  |   24  |   28  |   30   |   28   |   32   |
d(An,Rx)| 18 | 18 |  26  |   26  |   26  |   30  |   32   |   30   |   34   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
 addr.W | 16 | 16 |  24  |   24  |   24  |   28  |   30   |   28   |   32   |
 addr.L | 20 | 20 |  28  |   28  |   28  |   32  |   34   |   32   |   36   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
  d(PC) | 16 | 16 |  24  |   24  |   24  |   28  |   30   |   28   |   32   |
d(PC,Rx)| 18 | 18 |  26  |   26  |   26  |   30  |   32   |   30   |   34   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
  #data | 12 | 12 |  20  |   20  |   20  |   24  |   26   |   24   |   28   |
--------+----+----+------+-------+-------+-------+--------+--------+--------+
\end


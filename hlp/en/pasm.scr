\#prv_auxo\#     = $50E  ;L   vector    XBIOS   printer status (serial)
\#prv_aux\#      = $512  ;L   vector    XBIOS   print character (serial)

\#_v_bas_ad\#    = $44E  ;L   address   Video   current screen image

screen( sensitive("PACK") )
PACK \#Dn\#,\#Dn\#,\##data\#
PACK \#-(An)\#,\#-(An)\#,\##data\#

    Convert ASCII to BCD (two digits per byte byte).
    \#Dest\# = ((\#Source\# + data) & $F) |
               (((\#Source\# + data) >> 4) & $F0)
    data = 0 to 65535  (0 for ASCII or EBCDIC)

\#Sizes:\# Byte

\#CPUs:\# 234

\#Flags:\# unchanged


See also \#ABCD\#, \#NBCD\#, \#SBCD\#, \#UNPK\#
\end

screen( sensitive("PEA") )
PEA <ea>

    Push effective address onto stack.
    Sets -(A7) = <ea> address (not contents).

\#Sizes:\# long

\#CPUs:\# 01234

\#Flags:\# unchanged

Time charts: \#PEA.L\#

<ea>: \#(An)\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#


See also \#LEA\#
\end

screen( sensitive("RESET") )
RESET                           -- \#Privileged\# --

    Reset external devices.
    Sends 'reset' signal to external devices.

\#Sizes:\# not applicable

\#CPUs:\# 01234

68000 Time: 132 clocks

\#Flags:\# unchanged
\end

screen( sensitive("ROL") )
ROL \link("Dn")Ds\#,\#Dn\#
ROL \##data\#,\#Dn\#
ROL.W <ea>

    Rotate left.
    Dn = (Dn << \#Source\#) | (Dn >> (32 - \#Source\#)).
    <ea> = (<ea> << 1) | (<ea> >> 31).
    data = 1 to 8.  Uses rightmost 5 bits (0-31) of Ds.

\#Sizes:\# Byte, Word, Long    (except ROL.W <ea>)

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 C=last bit shifted out
           If Ds == 0, C=0 

Time charts: \#ROL.W\#

<ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#


See also \#ASL\#, \#ASR\#, \#LSL\#, \#LSR\#, \#ROR\#, \#ROXL\#, \#ROXR\#,
         \#SWAP\#
\end

screen( sensitive("ROR") )
ROR \link("Dn")Ds\#,\#Dn\#
ROR \##data\#,\#Dn\#
ROR.W <ea>

    Rotate right.
    Dn = (Dn >> \#Source\#) | (Dn << (32 - \#Source\#)).
    <ea> = (<ea> >> 1) | (<ea> << 31).
    data = 1 to 8.  Uses rightmost 5 bits (0-31) of Ds.

\#Sizes:\# Byte, Word, Long    (except ROR.W <ea>)

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 C=last bit shifted out
           If Ds == 0, C=0 

Time charts: \#ROR.W\#

<ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#


See also \#ASL\#, \#ASR\#, \#LSL\#, \#LSR\#, \#ROL\#, \#ROXL\#, \#ROXR\#,
         \#SWAP\#
\end

screen( sensitive("ROXL") )
ROXL \link("Dn")Ds\#,\#Dn\#
ROXL \##data\#,\#Dn\#
ROXL.W <ea>

    Rotate left with extend.  (Usually \#Source\# = 1.)
    <ea> = (<ea> << 1) | extend
    Dn = (Dn << Source) | (extend << (Source-1) | (Dn >> (33-Source)).
    data = 1 to 8.  Uses rightmost 5 bits (0-31) of Source Dn.

    This instruction can be used to rotate multiple words or do bit
    reversals.

\#Sizes:\# Byte, Word, Long    (except ROXL.W <ea>)

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 C=X=last bit shifted out

Time charts: \#ROXL.W\#

<ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#


See also \#ASL\#, \#ASR\#, \#LSL\#, \#LSR\#, \#ROL\#, \#ROR\#, \#ROXR\#
\end

screen( sensitive("ROXR") )
ROXR \link("Dn")Ds\#,\#Dn\#
ROXR \##data\#,\#Dn\#
ROXR.W <ea>

    Rotate right with extend.  (Usually \#Source\# = 1.)
    <ea> = (<ea> >> 1) | (extend << 31).
    Dn = (Dn >> Source) | (extend >> (Source-1) | (Dn << (33-Source)).
    data = 1 to 8.  Uses rightmost 5 bits (0-31) of Ds.

    This instruction can be used to rotate multiple words or do bit
    reversals.

\#Sizes:\# Byte, Word, Long    (except ROXR.W <ea>)

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 C=X=last bit shifted out

Time charts: \#ROXR.W\#

<ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#


See also \#ASL\#, \#ASR\#, \#LSL\#, \#LSR\#, \#ROL\#, \#ROR\#, \#ROXL\#
\end

screen( sensitive("RTD") )
RTD \##data\#

    Return from subroutine and deallocate arguments.
    Pops longword from stack to \#Program Counter\#.
    Increments A7 (stack pointer) by data.
    data = -32768 to 32767

\#Sizes:\# not applicable.

\#CPUs:\# 1234

\#Flags:\# unchanged


See also \#BSR\#, \#JSR\#, \#RTR\#, \#RTS\#.
\end

screen( sensitive("RTE") )
RTE                    -- \#Privileged\# --

    Return from \link("Exceptions")exception\#.
    Restores all registers saved in exception stack frame,
    including the \#Status Register\# and \#Program Counter\#.

\#Sizes:\# not applicable.

\#CPUs:\# 01234

\#Flags:\# restored from stack.

68000 Time: 20 clocks


See also \#BKPT\#, \#ILLEGAL\#, \#TRAP\#, \#TRAPcc\#, \#TRAPV\#
\end

screen( sensitive("RTM") )
RTM                    -- Invalid for Atari --

    Return from PMMU.
    Restores all registers saved in module stack frame.

\#Sizes:\# not applicable

\#CPUs:\# 5

\#Flags:\# restored from stack.

See also \#CALLM\#.
\end

screen( sensitive("RTR") )
RTR

    Return from subroutine and restore condition codes.
    Equivalent to a \link("MOVE to CCR")MOVE (A7)+,CCR\#, \#RTS\# combination.

    Assumes a \link("MOVE from CCR")MOVE CCR,-(A7)\# as first instruction in subroutine.

\#Sizes:\# not applicable.

\#CPUs:\# 01234

\#Flags:\# restored from stack.

68000 Time: 20 clocks


See also \#BSR\#, \#JSR\#, \#RTD\#, \#RTS\#.
\end

screen( sensitive("RTS") )
RTS

    Return from subroutine.
    Pops longword from stack to \#Program Counter\#.

    Reverses action of previous BSR or JSR.

\#Sizes:\# not applicable.

\#CPUs:\# 01234

\#Flags:\# unchanged.

68000 Time: 16 clocks


See also \#BSR\#, \#JSR\#, \#RTD\#, \#RTR\#.
\end

screen( sensitive("SBCD") )
SBCD \#Dn\#,\#Dn\#
SBCD \#-(An)\#,\#-(An)\#

    Subtract BCD with extend.  \#Dest\# -= (\#Source\# + Extend).
    Clear X bit and set Z bit before first byte (see \#MOVE to CCR\#).

\#Sizes:\# Byte

\#CPUs:\# 01234

\#Flags:\# N=? Z=* V=? X=C=*  (Z either cleared or unchanged)

Time charts: \#SBCD.B\#


See also \#ABCD\#, \#NBCD\#, \#PACK\#, \#UNPK\#
\end


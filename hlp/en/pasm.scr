screen( sensitive("MOVEC") )
MOVEC Rc,Rn                    -- \#Privileged\# --
MOVEC Rn,Rc

    Fetch or set control registers.

\#Sizes:\# Long

\#CPUs:\# 1234

\#Flags:\# unchanged

Rn: \#Dn\#, \#An\#

Rc: \#SFC\#, \#DFC\#, \#CACR\#, \#USP\#, \#VBR\#, \#CAAR\#, \#MSP\#, \#ISP\#


See also: \#MOVE\#, \#MOVEA\# \#MOVEM\#, \#MOVEP\#, \#MOVEQ\#, \#MOVES\#, \#MOVE16\#,
          \#MOVE to CCR\#, \#MOVE from CCR\#, \#MOVE to SR\#, \#MOVE from SR\#,
          \#MOVE from USP\#, \#MOVE to USP\#
\end

screen( sensitive("MOVEM") )
MOVEM <list>,<ea>
MOVEM <ea>,<list>

    Move multiple registers.
    This instruction can be used to save registers to the stack.
    It is also a fast way to copy blocks of memory.

\#Sizes:\# Word, Long

\#CPUs:\# 01234

\#Flags:\# unchanged

Time charts: \#MOVEM.W\#, \#MOVEM.L\#

\#Source\# <ea>: \#(An)\# \#(An)+\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
             \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#

\#Dest\# <ea>: \#(An)\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
           \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#

<list>: A range of registers is specified using '-', as in 'D0-D7'.
        A break between ranges (or individual registers) is specified
          using '/', as in 'D0/D4-D7/A0-A5'
        The order is irrelevant.


See also: \#MOVE\#, \#MOVEA\# \#MOVEC\#, \#MOVEP\#, \#MOVEQ\#, \#MOVES\#, \#MOVE16\#,
          \#MOVE to CCR\#, \#MOVE from CCR\#, \#MOVE to SR\#, \#MOVE from SR\#,
          \#MOVE from USP\#, \#MOVE to USP\#
\end

screen( sensitive("MOVEP") )
MOVEP \#d(An)\#,\#Dn\#
MOVEP \#Dn\#,\#d(An)\#

    Move peripheral data.  Skips every other byte in memory.
    d(An) points to first byte used.

    When an 8 bit chip is attached to a 16 bit bus, only every other
    byte is used.

   The 68030 can support dynamic bus sizes, so that one could attach
   8 bit chips to an 8 bit bus.  However, the Atari TT maintains the
   same I/O port addresses as the ST, presumably using a 16 bit bus
   for peripherals.

\#Sizes:\# Word, Long

\#CPUs:\# 01234

\#Flags:\# unchanged

68000 Time: 16 (word) or 24 (long)


See also: \#MOVE\#, \#MOVEA\# \#MOVEC\#, \#MOVEM\#, \#MOVEQ\#, \#MOVES\#, \#MOVE16\#,
          \#MOVE to CCR\#, \#MOVE from CCR\#, \#MOVE to SR\#, \#MOVE from SR\#,
          \#MOVE from USP\#, \#MOVE to USP\#
\end

screen( sensitive("MOVEQ") )
MOVEQ \##data\#,\#Dn\#

    Copy data to Dn, sign extended.  data = -128 to 127.

\#Sizes:\# Long

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 C=0

68000 Time: 4 clocks

See also: \#MOVE\#, \#MOVEA\# \#MOVEC\#, \#MOVEM\#, \#MOVEP\#, \#MOVES\#, \#MOVE16\#,
          \#MOVE to CCR\#, \#MOVE from CCR\#, \#MOVE to SR\#, \#MOVE from SR\#,
          \#MOVE from USP\#, \#MOVE to USP\#
\end

screen( sensitive("MOVES") )
MOVES Rn,<ea>                   -- \#Privileged\# --
MOVES <ea>,Rn

    Uses \#DFC\# register to control memory access to \#Dest\# <ea>.
    Uses \#SFC\# register to control memory access to \#Source\# <ea>.

\#Sizes:\# Byte, Word, Long

\#CPUs:\# 1234

\#Flags:\# unchanged

Rn: \#Dn\#, \#An\#  (transfer to An will be sign extended to 32 bits)

<ea>: \#(An)\# \#-(An)\# \#(An)+\# \#d(An)\# \#d(An,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#


See also: \#MOVE\#, \#MOVEA\# \#MOVEC\#, \#MOVEM\#, \#MOVEP\#, \#MOVEQ\#, \#MOVE16\#,
          \#MOVE to CCR\#, \#MOVE from CCR\#, \#MOVE to SR\#, \#MOVE from SR\#,
          \#MOVE from USP\#, \#MOVE to USP\#
\end


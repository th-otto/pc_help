screen( sensitive("LINK") )
LINK \#An\#,#size

    Create standard stack frame.  (Usually An = A6, and size < 0.)

    Move An to --(A7), move A7 to An, then add size to A7.

    Used to allocate space on stack for local variables, which are
    referenced using \link("d(An)")d(A6)\#.

\#Sizes:\# Word   (also Long for CPUs 234)

\#CPUs:\# 01234

\#Flags:\# unchanged

68000 Time: 16 clocks


See also \#UNLK\# and \link("%%GLOBAL%%")Help Compiler Language\#.
\end

screen( sensitive("LSL") )
LSL \link("Dn")Ds\#,\#Dn\#
LSL \##data\#,\#Dn\#
LSL.W <ea>

    Logical shift left.  Dn <<= \#Source\#  or  <ea> <<= 1.
    data = 1 to 8.  Uses rightmost 5 bits (0-31) of Ds.
    Pads zeros to right.

\#Sizes:\# Byte, Word, Long    (except LSL.W <ea>)

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 X=C=last bit shifted out
           If Ds == 0, X unchanged and C=0 

Time charts: \#LSL.W\#

<ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#


See also \#ASL\#, \#ASR\#, \#LSR\#, \#ROL\#, \#ROR\#, \#ROXL\#, \#ROXR\#
\end

screen( sensitive("LSR") )
LSR \link("Dn")Ds\#,\#Dn\#
LSR \##data\#,\#Dn\#
LSR.W <ea>

    Logical shift right.  Dn >>= \#Source\#  or  <ea> >>= 1.
    data = 1 to 8.  Uses rightmost 5 bits (0-31) of Ds.
    Pads zeros to left.

\#Sizes:\# Byte, Word, Long    (except LSR.W <ea>)

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=0 X=C=last bit shifted out
           If Ds == 0, X unchanged and C=0 

Time charts: \#LSR.W\#

<ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#


See also \#ASL\#, \#ASR\#, \#LSL\#, \#ROL\#, \#ROR\#, \#ROXL\#, \#ROXR\#
\end


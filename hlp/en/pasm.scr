		sensitive("SCC"),
		sensitive("SCS"),
		sensitive("SVC"),
		sensitive("SVS"),
		sensitive("SEQ"),
		sensitive("SF"),
		sensitive("SGE"),
		sensitive("SGT"),
		sensitive("SHI"),
		sensitive("SLE"),
		sensitive("SLS"),
		sensitive("SLT"),
		sensitive("SMI"),
		sensitive("SNE"),
		sensitive("SPL"),
		sensitive("ST") )
Scc <ea>

    Set <ea> to -1 (TRUE) on \link("Condition Codes")condition code\#.
    Clear <ea> (FALSE) otherwise.

\#Sizes:\# Byte

\#CPUs:\# 01234

\#Flags:\# unchanged

Time Charts: \#SF.B\#, \#ST.B\#

<ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
      \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#

ST same as \#MOVEQ\#.B #-1,
SF same as \#CLR\#.B

See also \#Bcc\#, \#DBcc\#, \#TRAPcc\#
\end

screen( sensitive("STOP") )
STOP #data                -- \#Privileged\# --

    Set \#Status Register\# and wait for interrupt.

\#Sizes:\# Word

\#CPUs:\# 01234

\#Flags:\# set from data

68000 Time: 4 clocks


See also \#MOVE to SR\#
\end

screen( sensitive("SUB") )
SUB <ea>,\#Dn\#
SUB \#Dn\#,<ea>

    Subtract binary.  \#Dest\# -= \#Source\#.

\#Sizes:\# Byte, Word, Long

\#CPUs:\# 01234

\#Flags:\# N=* Z=* V=* X=C=*

Time charts: \#SUB.W\#, \#SUB.L\#

Source <ea>: \#Dn\# \#An\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\# \#d(PC)\# \#d(PC,Rx)\#
             \#addr\# \##data\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\# \#([b,PC],Rx,d)\# \#([b,PC,Rx],d)\#

Dest <ea>: \#Dn\# \#(An)\# \#(An)+\# \#-(An)\# \#d(An)\# \#d(An,Rx)\#
           \#addr\# \#([b,An],Rx,d)\# \#([b,An,Rx],d)\#

SUB <ea>,An       translated as  SUBA <ea>,An
SUB #data,<ea>  translated as  SUBQ #data,<ea>  for 1 to 8
                                 SUBI #data,<ea>  otherwise

See also \#ADD\#, \#ADDA\#, \#ADDI\#, \#ADDX\#, \#SUBA\#, \#SUBI\#, \#SUBQ\#, \#SUBX\#
         \#NEG\#, \#NEGX\#
\end


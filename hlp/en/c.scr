screen( capsensitive("printf/scanf Formats") )
printf/scanf Formats
----------------------------------------------------------------------
\link("%%GLOBAL%%")printf\# \#Syntax\#:  %[\link("%flags")<flags>\#][\link("%width")<width>\#][\link("%precision").<precision>\#][\link("%l")l\#]\link("%type")<type>\#

The number of characters outputted varies, unless fixed by the
"\link("%width")width\#.\link("%precision")precision\#" modifiers.

Characters between % specifications will be outputted directly (except
that one must use "%%" to output a percent symbol).
Newlines must be explicitly entered.

\link("%%GLOBAL%%")scanf\# \#Syntax\#:   %[\link("%*")*\#][\link("%[]")[<cset>]\#][\link("%width")<width>\#][\link("%l")l\#]\link("%type")<type>\#

An input field is terminated by the first illegal character or
by the "\link("%width")width\#" modifier (whichever comes first).

Consecutive fields are generally separated by blanks, however one can
use other character(s) by including them between the % specifications.
For example, the two fields for "%g,%g" MUST be separated by a comma.

Most fields ignore leading blanks, tabs and newlines, and therefore
cannot be terminated until at least one legal character is entered
(no blank default).

A "%s" field is terminated by a newline, unless the legal character
set is modified using the "\link("%[]")[cset]\#" modifier.
\end

screen( "%type" )
\#printf/scanf Formats\# types
----------------------------------------------------------------------
  %c  Character   (\#char\#)
  %s  String      (\#char\#*)            NULL terminated
  %d  Decimal     (\#int\#)              also %i
  %u  Unsigned    (\#unsigned\# \#int\#)
  %o  Octal       (\#int\#)
  %x  Hexadecimal (\#unsigned\# \#int\#)
  %f  Floating    (\#float\#)            e.g. 100.0
  %e  Exponent    (\#float\#)            e.g. 1.0e2
  %g  %f or %e    (\#float\#)

  %%  Percent Sign

printf only:
  %p  Address     (\#void\#*) Writes address in hex.
  %n  Length      (\#int\#*)  Returns number characters output so far.

See also \link("%l")length modifier\#.
\end

screen( "%l" )
\#printf/scanf Formats\# length modifier
----------------------------------------------------------------------
%ld  \#long\#           (decimal)                also %li
%lu  \#unsigned\# \#long\#  (decimal)
%lo  \#long\#           (octal)
%lx  \#unsigned\# \#long\#  (hexadecimal)
%lf  \#double\#         (floating)
%le  \#double\#         (exponent)
%lg  \#double\#         (exponent optional)

Note: Since floats are converted to doubles before being passed in
      \#Variable Argument Lists\#, %f and %lf are indentical in printf()
      but different in scanf().
\end

screen( "%flags" )
\link("printf/scanf Formats")printf Formats\# Flags
----------------------------------------------------------------------
 -     left justified (relevant only when using \link("%width")width\# modifier).
 0     pad with zeros
 +     add '+' to positive numbers
 blank add ' ' to positive numbers (align with '-').
 #     use alternate form ('0xnnn' for %#x, '0nnn' for %#o).
\end

screen( "%width" )
\#printf/scanf Formats\# width modifier
----------------------------------------------------------------------
\link("%%GLOBAL%%")printf\#:
  Minimum number of character to output.
  Will normally output right justified with blank pad.
  Output can be longer than width.
  Use '*' to get width from argument list (\#int\#).
  See also \#%precision\#.

\link("%%GLOBAL%%")scanf\#:
  Maximum number of characters to read.
\end

screen( "%precision" )
\link("printf/scanf Formats")printf Formats\# precision modifier
----------------------------------------------------------------------
Maximum number characters (%f %e %g and %s only).
Use '0' to use default value.
Use '*' to get width from argument list (\#int\#).

See also \#%width\#.
\end

screen( "%*" )
\link("printf/scanf Formats")scanf Formats\# '*' modifier
----------------------------------------------------------------------
Skip input field.

For example, "%*10s" means skip 10 characters.
\end

screen( "%[]" )
\link("printf/scanf Formats")scanf Formats\# "[]" modifier
----------------------------------------------------------------------
Allowed character set (mostly used with %s format).
When '^' is the first character, character set NOT allowed.

Examples:
  "%*[\\t \\n]s" will skip any number of tabs, blanks and newlines.
  "%[^,]s" will terminate the string when the next ',' is reached.
\end


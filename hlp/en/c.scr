screen( "Error: # operator" )
# operator not followed by macro argument name
----------------------------------------------------------------------
  The # operator is used to merge strings in a function macro; e.g.

    \##define\# name(arg) "front-" # arg "-end"
    char* test = name("middle");

  is translated as

    test = "front-middle-end";
\end

screen( "Error: K&R arguments" )
'XXXXXX' not an argument 
----------------------------------------------------------------------
K&R function declaration only:

  Argument name in type declaration does not match any name in
  argument list:

    function(argument)
      int wrong_name;
     { ...

See \#Functions\#.
\end

screen( "Error: RAM" )
Out of memory                                (Internal Compiler Error)
----------------------------------------------------------------------
  Compiler ran out of RAM.

  Probably due to cache accumulation (see \link("%%GLOBAL%%")Shell Options\#), or a
  very BIG source code file.
\end

screen( "Error: address" )
Must take address of memory location
----------------------------------------------------------------------
  Attempted to use address '&' operator on a \#register\# or a computed
  expression (stored on a \#register\#).

See \#Operators\#.
\end

screen( "Error: argument syntax" )
Argument list syntax error
----------------------------------------------------------------------
  Argument list must be enclosed in parenthesis ( ) and separated by
  commas.

  Check intervening comments and/or ANSI type declarations.

See \#Functions\#.
\end

screen( "Error: auto" )
Too much auto memory
----------------------------------------------------------------------
  Each function can have at most 32K bytes of local variables.

See \#auto\#.
\end

screen( "Error: bad character" )
Illegal character 'C' (0xXX)
----------------------------------------------------------------------
  Source code contains a non-ASCII character.

Note: Use \#Backslash Sequences\# to create non-ASCII characters in
      strings.
\end

screen( "Error: bad directive" )
Unknown preprocessor directive 'XXXXXX'
----------------------------------------------------------------------
  Valid directives are \##define\#, \##undef\#, \##include\#, \##if\#, \##ifdef\#, \##ifndef\#,
  \##else\#, \##elif\#, \##endif\#, \##error\# and \##pragma\#.
\end

screen( "Error: bit fields" )
Bit field size syntax
----------------------------------------------------------------------
  The size of a \link("Bit Fields")bit field\# must be between 1 and 32 bits.
\end

screen( "Error: call type" )
Type mismatch in parameter 'XXXXXX' in call to function 'XXXXXX'
----------------------------------------------------------------------
  Parameter in prototype does not match function call, nor can calling
  parameter be converted to the right type.

See \#Functions\#.
\end

screen( "Error: conflict" )
Conflicting type modifiers
----------------------------------------------------------------------
  \#unsigned\# and \#signed\# conflict.
  \#cdecl\# and \#pascal\# conflict.
\end

screen( "Error: conversion" )
Incompatible type conversion
----------------------------------------------------------------------
The following type conversions are not allowed:

  function() = variable
  structure  = single variable
  array      = single variable
  pointer    = floating point
\end

screen( "Error: duplicate function" )
Type mismatch in redeclaration of 'XXXXXX'
----------------------------------------------------------------------
  Prototype does not agree with function definition, or the function
  name is already used for another function.

See \#Functions\#.
\end

screen( "Error: duplicate variable" )
Redeclaration of 'XXXXXX'
----------------------------------------------------------------------
  Variable name XXXXXX already used.

  To legally redeclare a variable, do it inside a \#local block\#.

See \#Variables\#.
\end

screen( "Error: extern" )
Incompatible storage class
----------------------------------------------------------------------
  Function definitions cannot be \#extern\# (unlike prototypes).

See \#Functions\#.
\end

screen( "Error: file" )
Unable to created output file 'XXXXXX'       (Internal Compiler Error)
----------------------------------------------------------------------
  Diskette or file was write protected, or tried to use a non-existent
  folder, or (rare) the directory was full.
\end

screen( "Error: filename too long" )
File name too long
----------------------------------------------------------------------
  The filename in an \##include\# directive must be < 64 characters.
\end

screen( "Error: floating operation" )
Illegal use of floating point
----------------------------------------------------------------------
  One cannot perform bitwise or modulus '%' operations on float's.
  (Check for unintended '.' after a constant.)

See \#float\#, \#double\#, \link("%%GLOBAL%%")fmod\#() and \#Operators\#.
\end

screen( "Error: function definition" )
Function definition out of place
----------------------------------------------------------------------
  You cannot put a function definition inside another function
  definition.

  Check for unbalanced braces { } in the preceding function definition
  using \link("%%GLOBAL%%")Check Braces\# or by double-clicking braces.

See \#Functions\#.
\end

screen( "Error: function not variable" )
Function doesn't take variable number of arguments
----------------------------------------------------------------------
  \link("%%GLOBAL%%")va_start\#, \link("%%GLOBAL%%")va_arg\# and \link("%%GLOBAL%%")va_end\# can only be used in a function
  with a variable argument list (...).

See \#Functions\#.
\end

screen( "Error: function type" )
Not an allowed type
----------------------------------------------------------------------
  A function cannot return a function pointer or an entire array.
  A \#void\# function cannot return anything.

Note: A function CAN return a structure.

See \#Functions\# and \#Parameter Passing\#.
\end

screen( "Error: include file" )
Unable to open include file
----------------------------------------------------------------------
  File probably doesn't exist, or is in the wrong folder.
\end

screen( "Error: indirection" )
Invalid indirection
----------------------------------------------------------------------
  Attempt to dereference '*' a \#void\# pointer or a non-pointer.

See \#Pointers\#.
\end

screen( "Error: initialization" )
Illegal initialization
----------------------------------------------------------------------
  A variable must be initialized with a constant expression.
  Pointers can be initialized with the address of a \#global\#, \#static\#
  or \#extern\# variable (+/- a constant).

See \#Variables\# and \#Constants\#.
\end

screen( "Error: macro arguments" )
Wrong number of arguments in call of 'XXXXXX'
----------------------------------------------------------------------
  Check macro definition (using \link("%%GLOBAL%%")Project Help\#) for correct number
  of arguments, or check spelling of macro/function name.
\end

screen( "Error: macro too long" )
Macro expansion too long
----------------------------------------------------------------------
  Macro expansion longer than 4096 characters.

  (Probably an infinite recursive expansion.)
\end

screen( "Error: missing ;" )
Statement missing ;
----------------------------------------------------------------------
  Statements must be separated by a semicolon ';'.
\end

screen( "Error: missing }" )
Compound statement missing }
----------------------------------------------------------------------
  Check braces using \link("%%GLOBAL%%")Check Braces\#.

See \#Not an Operator\#.
\end

screen( "Error: no #endif" )
Unexpected end of file in condition started on line #
----------------------------------------------------------------------
  Missing an \##endif\# after an \##if\#, \##ifdef\#, \##ifndef\#, \##else\# or \##elif\#.

  Note: \link("%%GLOBAL%%")Find Error\# will point to end of file.
        Use \link("%%GLOBAL%%")Goto Line...\# to start search.
\end

screen( "Error: no */" )
Unexpected end of file in comment started on line #
----------------------------------------------------------------------
  Missing a terminating '*/' after the \link("Comments")comment\# in question.

  Note: \link("%%GLOBAL%%")Find Error\# will point to end of file.
        Use \link("%%GLOBAL%%")Goto Line...\# to locate start of comment.

  Also check the -C flag of \link("%%GLOBAL%%")Compiler Options\#.
\end

screen( "Error: no argument" )
Argument # missing name
----------------------------------------------------------------------
  No name found between two commas in argument list for function
  definition or prototype:

    function(arg1,,arg3)  /* argument 2 missing */

Note: When function has no arguments at all, use 'function(void)'
      instead of 'function()'.

See \#Functions\#.
\end

screen( "Error: not a function" )
Call of non-function
----------------------------------------------------------------------
  Name used in function call defined as something else.

  You probably used parenthesis where you should have used brackets:

    array(i);  /* instead of */  array[i];

  or left out an operator between the name and the parenthesis:

    variable (a + b);  /* instead of  */  variable * (a + b);

See also \#Arrays\#, \#Operators\# and \#Functions\#.
\end

screen( "Error: number parameters" )
Mismatched number of parameters in definition.
----------------------------------------------------------------------
  Number of parameters in a function prototype is different from the
  number of parameters in the corresponding function definition.

See \#Functions\#.
\end

screen( "Error: options" )
Incorrect ... option                         (Internal Compiler Error)
----------------------------------------------------------------------
  PC.PRG called CCP.TTP or PCC.TTP using bad options.

  Check for blanks in the edit fields of \link("%%GLOBAL%%")Compiler Options\#.
\end

screen( "Error: pointer addition" )
Invalid pointer addition
----------------------------------------------------------------------
  One cannot add a pointer to an address (or pointer).

See \#Pointers\#.
\end

screen( "Error: pointer operation" )
Illegal use of pointer
----------------------------------------------------------------------
  Pointers can only be added, subtracted, compared, or dereferenced
  ('*' or '->').

See \#Pointers\# and \#Operators\#.
\end

screen( "Error: pointer subtraction" )
Illegal pointer subtraction
----------------------------------------------------------------------
  One cannot subtract a pointer from a non-pointer.

See \#Pointers\#.
\end

screen( "Error: structure" )
Structure or union syntax error
----------------------------------------------------------------------
  Probably mismatched braces, or using a comma instead of a ;

See \#struct\# or \#union\# for syntax.
\end

screen( "Error: structure operation" )
Illegal structure operation
----------------------------------------------------------------------
  The '.' operator can only be used with structures or unions.

  Structures can only be used with the '.', '&' (unary address) and
  '=' (replacement) operators.

See \#Structures\# and \#Operators\#.
\end

screen( "Error: structure pointer" )
Pointer required on left side of ->
----------------------------------------------------------------------
  Lvalue must be a STRUCTURE pointer.

Note: '->' operator has higher precedence than \#casting\#, so use
      '((struct name*) p)->member' not '(struct name*) p->member'.

See \#Structures\# and \#Operators\#.
\end

screen( "Error: symbol" )
Undefined symbol 'XXXXXX'
----------------------------------------------------------------------
  XXXXXX was used as a variable or type name, but was not defined.

  A local definition may have been terminated by too many } braces.
  A global definition may be been located later in the file.

See \#Names\#, \#Variables\# and \#typedef\#.
\end

screen( "Error: syntax" )
Expression syntax
----------------------------------------------------------------------
  Catch all error message.  Could be almost anything.

See \#Names\#, \#Constants\#, \#Operators\# and \#Functions\#.
\end

screen( "Error: too few parameters" )
Too few parameters in call to 'XXXXXX'
----------------------------------------------------------------------
  Function call used fewer parameters than in prototype or definition.

See \#Functions\#.
\end

screen( "Error: too many cases" )
Too many cases
----------------------------------------------------------------------
  The number of \#case\# statements in a \#switch\# block exceeded 255
  (version 1.0) or 8191 (version 1.1).

  The easiest way to overcome this problem is to break up the block
  using:

switch( test ) {
  ...                        /* the first 255 cases */
default: switch( test ) {
  ...                        /* remaining cases */
 } }
\end

screen( "Error: too many classes" )
Too many storage classes in declaration
----------------------------------------------------------------------
  Only one storage class (\#extern\# \#static\# \#auto\# \#register\#) per
  declaration.

See \#Storage Classes\# and \#Variables\#.
\end

screen( "Error: too many defaults" )
Too many default cases
----------------------------------------------------------------------
  Only one \#default\# statement per \#switch\# block.
\end

screen( "Error: too many init" )
Too many initializers
----------------------------------------------------------------------
  Number of constants in list exceeds the array or structure size.

See \#Arrays\# and \#Structures\#.
\end

screen( "Error: too many parameters" )
Extra parameter in call to 'XXXXXX'
----------------------------------------------------------------------
  Function call used more parameters than in prototype or definition.

See \#Functions\#.
\end

screen( "Error: too many types" )
Too many types in declaration
----------------------------------------------------------------------
  Only a \#union\# can have more than one data type.

See \#Data Types\# and \#Variables\#.
\end

screen( "Error: two dots" )
Two consecutive dots
----------------------------------------------------------------------
  Structures and unions use single dots, and variable argument lists
  use three dots.  Two is either too many or too few.
\end

screen( "Error: typedef" )
Improper use of typedef symbol
----------------------------------------------------------------------
  Names declared using a \#typedef\# statement can only be used to cast
  or declare data types.
\end

screen( "Error: unknown size" )
Size of structure or array not known
----------------------------------------------------------------------
This error can be caused by...

  using the 'array[]' definition without an initialization.
  any arithmetic operation with a \#void\# pointer.
  using an undefined structure name.

See \#Arrays\# and \#Pointers\#.
\end

screen( "Error: write" )
Error writing output file                    (Internal Compiler Error)
----------------------------------------------------------------------
  Out of disk space, or bad sector encountered.
\end

screen( "Error: too many errors" )
Too many error or warning messages
----------------------------------------------------------------------
  Number of error or warning messages has exceeded the limit set by
  the \link("%%GLOBAL%%")Compiler Options\#.

    Compilation is terminated at this point.
\end

screen( "Error: divide" )
Division by zero
----------------------------------------------------------------------
  Expressions involving only constants are pre-computed by the
  compiler.

  In this case, the expression resulted in a division by zero.
\end

screen( capsensitive("Warning") )
Compiler Warning Messages   (in alphabetical order)
----------------------------------------------------------------------
(For more information, double-click [?] button.)

\link("use")[?]\#  'XXXXXX' declared but never used
\link("aus")[?]\#  'XXXXXX' is assigned a value which is never used
\link("str")[?]\#  'XXXXXX' not part of structure
\link("amb")[?]\#  Ambiguous operators need parenthesis
\link("ret")[?]\#  Both return and return of a value used
\link("pro")[?]\#  Call to function 'XXXXXX' with no prototype
\link("eff")[?]\#  Code has no effect
\link("cln")[?]\#  Constant is long
\link("rng")[?]\#  Constant out of range in comparison
\link("sig")[?]\#  Conversion may lose significant digits
\link("rvl")[?]\#  Function should return a value
\link("ucp")[?]\#  Mixing pointers to signed and unsigned char
\link("nod")[?]\#  No declaration for function 'XXXXXX'
\link("apt")[?]\#  Non-portable pointer assignment
\link("cpt")[?]\#  Non-portable pointer comparison
\link("rpt")[?]\#  Non-portable pointer conversion
\link("par")[?]\#  Parameter 'XXXXXX' is never used
\link("pia")[?]\#  Possible incorrect assignment
\link("def")[?]\#  Possible use of 'XXXXXX' before definition
\link("dup")[?]\#  Redefinition of 'XXXXXX' is not identical
\link("stv")[?]\#  Structure passed by value
\link("amp")[?]\#  Superfluous & with function or array
\link("sus")[?]\#  Suspicious pointer conversion
\link("stu")[?]\#  Undefined structure 'XXXXXX'
\link("voi")[?]\#  Void functions may not return a value
\link("rch")[?]\#  Unreachable code
\link("zst")[?]\#  Zero length structure

Warnings are not fatal (unless the total number exceeds the limit set
in the \link("%%GLOBAL%%")Compiler Options\#).

Warning messages can be turned on or off according to the warning
level set in the \link("%%GLOBAL%%")Compiler Options\#, or individually using the
\##pragma warn\# directive
\end

screen( capsensitive("#pragma warn") )
\##pragma\# warn - Turn warning messages on or off
----------------------------------------------------------------------
Syntax:    #pragma warn +<code>    /* turn message on  */
           #pragma warn -<code>    /* turn message off */
           #pragma warn .<code>    /* reset to default */

where <code> is one of the following:

\#amb\# - Ambiguous operators need parenthesis
\#amp\# - Superfluous & with function or array
\#apt\# - Non-portable pointer conversion
\#aus\# - 'XXXXXX' is assigned a value which is never used
\#cln\# - Constant is long
\#cpt\# - Non-portable pointer comparison
\#def\# - Possible use of 'XXXXXX' before definition
\#dup\# - Redefinition of 'XXXXXX' is not identical
\#eff\# - Code has no effect
\#nod\# - No declaration for function 'XXXXXX'
\#par\# - Parameter 'XXXXXX' is never used
\#pia\# - Possible incorrect assignment
\#pro\# - Call to function 'XXXXXX' with no prototype
\#rch\# - Unreachable code
\#ret\# - Both return and return of a value used
\#rng\# - Constant out of range in comparison
\#rpt\# - Non-portable pointer assignment
\#rvl\# - Function should return a value
\#sig\# - Conversion may lose significant digits
\#str\# - 'XXXXXX' not part of structure
\#stu\# - Undefined structure 'XXXXXX'
\#stv\# - Structure passed by value
\#sus\# - Suspicious pointer conversion
\#ucp\# - Mixing pointers to signed and unsigned char
\#use\# - 'XXXXXX' declared but never used
\#voi\# - Void functions may not return a value
\#zst\# - Zero length structure
\end

screen( "dup" )
Redefinition of 'XXXXXX' is not identical
----------------------------------------------------------------------
  A macro by that name was already defined (see \##define\#).
  Use \##undef\# before new macro definition to remove warning.

dup = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "ret" )
Both return and return of a value used
----------------------------------------------------------------------
  \#return\# must use the same data type as the function.
  \#void\# functions should use 'return;' or 'return(void);'

  Note: Implied 'return(void)' at end of function definition { }.

  See also:
    \link("voi")Void functions may not return a value\#
    \link("rvl")Function should return a value\#

ret = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "str" )
'XXXXXX' not part of structure
----------------------------------------------------------------------
  Code used <structure> .XXXXXX or <structure*> ->XXXXXX, but there is
  no XXXXXX in the structure definition.

str = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "stu" )
Undefined structure 'XXXXXX'
----------------------------------------------------------------------
  Code used '\#struct\# XXXXXX' in a variable definition, \#casting\#, or
  \#typedef\# statement, but XXXXXX  was never defined as a structure
  name.

  Note: \link("%%GLOBAL%%")Find Error\# points to end of function block.

stu = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "sus" )
Suspicious pointer conversion
----------------------------------------------------------------------
  Pointer conversion between incompatible data types.
  Cast pointer to remove warning.

sus = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "voi" )
Void functions may not return a value
----------------------------------------------------------------------
  \link("void")Void\# \link("Functions")functions\# must use 'return;' or 'return(void);'
  Either change \#return\# or change function type.

voi = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "zst" )
Zero length structure
----------------------------------------------------------------------
  \#struct\# definition contained nothing inside braces { }.
  (Probably all member definitions were in error.)

zst = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "aus" )
'XXXXXX' is assigned a value which is never used
----------------------------------------------------------------------
  You probably deleted the code which used variable XXXXXX, or just
  haven't got around to writing it yet.

aus = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "def" )
Possible use of 'XXXXXX' before definition
----------------------------------------------------------------------
  \#auto\# variables should be initialized during execution before
  they are used in an operation.  However, it is possible that the
  initialization was too obscure for the compiler to figure out.

  For example,

   for(i=0; i<100; i++) {
     if(i == 0) sum = 0;
     else sum = sum + i;
    }

  will produce this warning for 'sum'.

def = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "eff" )
Code has no effect
----------------------------------------------------------------------
  No syntax errors, but no variables were changed by this statement.
  For example,

   A = B;   /* changes A */

   A + B;   /* changes nothing */

  Note: If you hold down the shift key while typing '=' you will get
  '+' instead.  This is a common typing error.

eff = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "par" )
Parameter 'XXXXXX' is never used
----------------------------------------------------------------------
  The function definition contains XXXXXX in its parameter list, but
  never uses it in the code.

  This is often done deliberately for future expansion or
  compatibility with previous versions.

  Note: \link("%%GLOBAL%%")Find Error\# will point to the end of the function.

par = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "pia" )
Possible incorrect assignment
----------------------------------------------------------------------
  While a statement of the form 'if( a = b )' is legal and useful,
  more often the intended statement was of the form 'if( a == b )'
  and the extra '=' was left out by mistake.

 To remove this warning, use 'if( (a = b) != 0 )' instead.

pia = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "rch" )
Unreachable code
----------------------------------------------------------------------
  Executable code follows a \#return\# or \#goto\# statement.

  Probably missing a \#goto\# label or have unbalanced braces.

rch = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "rvl" )
Function should return a value
----------------------------------------------------------------------
  Only a \#void\# function may use '\#return\#;' or 'return(void);'.

  (There is an implied 'return(void)' at the end of a \link("Functions")function\#
  definition if it is reachable.)

  Either change the function type to void or use 'return( <value> );'
  or 'return <value>;'.

rvl = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "amb" )
Ambiguous operators need parenthesis
----------------------------------------------------------------------
  Possible confusion between bitwise, arithmetic, and relational
  operations:

     a + b < c & d

  Operator precedence establishes a unique calculation, but adding
  parenthesis would certainly make the code more readable.

amb = code for \##pragma warn\#.
 2  = \#warning level\# for message.
\end

screen( "amp" )
Superfluous & with function or array
----------------------------------------------------------------------
  A function name without parenthesis ( ) or an array name without
  brackets [ ] means the address of the function or array.
  The unary & (address) operator is not needed.

amp = code for \##pragma warn\#.
 2  = \#warning level\# for message.
\end

screen( "nod" )
No declaration for function 'XXXXXX'
----------------------------------------------------------------------
  A function prototyped as \#static\# was never defined.

  Note: \link("%%GLOBAL%%")Find Error\# will point to end of module.

nod = code for \##pragma warn\#.
 2  = \#warning level\# for message.
\end

screen( "pro" )
Call to function 'XXXXXX' with no prototype
----------------------------------------------------------------------
  Function definition or prototype should precede all calls to enable
  parameter type checking.

pro = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "stv" )
Structure passed by value
----------------------------------------------------------------------
  Every element of the structure is copied to the registers and/or
  stack (usually structures are passed by address).

 To pass the structure by address, use the unary & (address) operator.

 Note: the prototype parameter must be the same structure, not just a
 list of variables with the same type as structure elements.

stv = code for \##pragma warn\#.
 2  = \#warning level\# for message.
\end

screen( "use" )
'XXXXXX' declared but never used
----------------------------------------------------------------------
  Probably an obsolete variable or goto label, ripe for deletion.

  Note: \link("%%GLOBAL%%")Find Error\# will point to end of local block.

use = code for \##pragma warn\#.
 2  = \#warning level\# for message.
\end

screen( "apt" )
Non-portable pointer conversion
----------------------------------------------------------------------
  A non-pointer was used as a pointer function parameter.

  Use \#casting\# to remove warning.

apt = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "cln" )
Constant is long
----------------------------------------------------------------------
  Integer constant exceeded the range of \#int\# (default) but was not
  explicitly typed as \#long\#.  (Concatenate 'L' to remove warning.)

cln = code for \##pragma warn\#.
 2  = \#warning level\# for message.
\end

screen( "cpt" )
Non-portable pointer comparison
----------------------------------------------------------------------
  A pointer was compared to a non-pointer; e.g., 'p < l'

  Use \#casting\# to remove the warning; e.g '(long) p < l'

cpt = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "rng" )
Constant out of range in comparison
----------------------------------------------------------------------
  The comparison will always fail or always succeed.

    short i;
    if(i < 1234567L) ...

rng = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "rpt" )
Non-portable pointer assignment
----------------------------------------------------------------------
  Either a pointer was set to a non-pointer, or a non-pointer was set
  to a pointer: 'l = p' or 'p = l'  (l is long and p is a pointer)

  Use \#casting\# to remove warning: 'l = (long) p' or 'p = (void *) l'

rpt = code for \##pragma warn\#.
 1  = \#warning level\# for message.
\end

screen( "sig" )
Conversion may lose significant digits
----------------------------------------------------------------------
  Conversion from \#long\# to \#short\# or \#short\# to \#char\#, etc.

  Use \#casting\# to remove warning: 'i = (int) l'

sig = code for \##pragma warn\#.
 2  = \#warning level\# for message.
\end

screen( "ucp" )
Mixing pointers to signed and unsigned char
----------------------------------------------------------------------
  Using signed char pointers as unsigned char function parameters, or
  using unsigned char pointers as signed char function parameters.

  Use \#casting\# to remove warning, or change all \#char\# to either
  \#signed\# or \#unsigned\#.  (See -K flag from \link("%%GLOBAL%%")Compiler Options\#.)

ucp = code for \##pragma warn\#.
 2  = \#warning level\# for message.
\end

screen( "warning level" )
Warning Level
----------------------------------------------------------------------
... is used in the \link("%%GLOBAL%%")Compiler Options\# as a crude implementation of
the -W flag.

  0 = Show no warning messages.
  1 = Show some warning messages.
  2 = Show all warning messages.
\end


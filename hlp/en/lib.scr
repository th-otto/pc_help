screen( capsensitive("clearerr") )
#include <stdio.h>

void clearerr( \#FILE\# *stream );

  <stream> is an open stream (see \#fopen\#).


Function is used to clear an error condition so that future calls to
\#ferror\#() or \#feof\#() do not keep reporting the same error.

See also \#Standard I/O\#.
\end

screen( capsensitive("fclose") )
#include <stdio.h>

int fclose( \#FILE\# *stream );

  <stream> is an open stream (see \#fopen\#).


Function is used to close a stream.
Any data in the output buffer will be flushed to the file.

It returns 0 normally, or an error code if the stream is not open.

See also \#Standard I/O\# and \#errno\#.
\end

screen( capsensitive("feof") )
#include <stdio.h>

int feof( \#FILE\# *stream );

  <stream> is an open stream (see \#fopen\#).


Function returns 0 normally, or nonzero on End Of File.
The EOF flag can be reset by \#rewind\#(), \#fseek\#(), \#fsetpos\#() or
\#clearerr\#().

See also \#Standard I/O\#.
\end

screen( capsensitive("ferror") )
#include <stdio.h>

int ferror( \#FILE\# *stream );

  <stream> is an open stream (see \#fopen\#).


Function returns 0 normally, or an error code if a read or write error
has occurred anytime since the last call to \#clearerr\#().
It does NOT detect end of file.

See also \#Standard I/O\#, \#errno\#, \#perror\#() and \#strerror\#().
\end

screen( capsensitive("fflush") )
#include <stdio.h>

int fflush( \#FILE\# *stream );

  <stream> is an open stream (see \#fopen\#).


Function flushes the output buffer to the file.  In particular, it can
be used on \#stdout\# or \#stderr\# to display a message without using a
newline.

It returns 0 normally, or an error code on a write error.

See also \#Standard I/O\# and \#errno\#.
\end

screen( capsensitive("fgetc") )
#include <stdio.h>

int fgetc( \#FILE\# *stream );

  <stream> is an open stream (see \#fopen\#).


Function returns the next character from the stream, or EOF on end of
file.

See also \#Standard I/O\#, \#getc\#() and \#ungetc\#().
\end

screen( capsensitive("fgets") )
#include <stdio.h>

char* fgets( char *buf, int n, \#FILE\# *stream );

  <buf> is an <n> byte char array used to store the string.
  <n> is the number of bytes in array <buf>
  <stream> is an open stream (see \#fopen\#).


Function reads to the next newline, or until the EOF, or until n-1
characters are read, and stores them as a NULL terminated string.
It will include the newline character (10) if found.

It returns a pointer to the string, or NULL on error.

See also \#Standard I/O\# and \#fread\#().
\end

screen( capsensitive("fgetpos") )
#include <stdio.h>

int fgetpos( \#FILE\# *stream, \#fpos_t\# *pos );

  <stream> was returned by \#fopen\#() or \#freopen\#().
  <pos> points to an unsigned long variable to contain the position.


Function returns the current position in the file for later use by
\#fsetpos\#().

It returns 0 normally, or an error code.

See also \#Standard I/O\#, \#ftell\#() and \#errno\#.
\end

screen( capsensitive("fopen") )
#include <stdio.h>

\#FILE\#* fopen( const char *filename, const char *\#mode\#);

  <filename> is a string containing a filename (see \#Pathnames\#).
    If no file by that name exists, a new one is created.  
  <\#mode\#> is a string containing the read/write options.


Function opens a file and returns a FILE pointer to be used by other
I/O functions.  It returns NULL if unsuccesful.

Note: Streams \#stdin\#, \#stdout\#, \#stderr\#, \#stdaux\# and \#stdprn\# are opened
      automatically.

See also \#Standard I/O\#, \#freopen\#() and \#tmpfile\#.
\end

screen( capsensitive("fprintf") )
#include <stdio.h>

int fprintf( \#FILE\# *stream, const char *format, \link("%%GLOBAL%%")...\# );

  <stream> is an open stream (see \#fopen\#).
  <format> is a string containing text and '%' sequences for
           converting variables into text.
           See \link("%%GLOBAL%%")printf/scanf Formats\#.
  <...> is a list of variables to be formatted.

Function performs a formatted write to a stream.
It returns the number of characters written or EOF if an error occurs.

See also \#Standard I/O\# and \#Formatting\#.
\end

screen( capsensitive("fputc") )
#include <stdio.h>

int fputc( int c, \#FILE\# *stream );

  <c> is a character (0-255) passed as an int.
  <stream> is an open stream (see \#fopen\#).


Function writes character <c> to a stream.
It returns 0 normally, or an error code.

See also \#Standard I/O\# or \#errno\#.
\end

screen( capsensitive("fputs") )
#include <stdio.h>

int fputs( const char *s, \#FILE\# *stream );

  <s> is a string to written.
  <stream> is an open stream (see \#fopen\#).


Function writes string <s> to a stream.  
It returns 0 normally, or an error code.

Note: There is NO implied newline at the end of the string.

See also \#Standard I/O\#, \#fwrite\#() and \#errno\#.
\end

screen( capsensitive("fread") )
#include <stdio.h>

\#size_t\# fread( void *buf, \#size_t\# size, \#size_t\# n, \#FILE\# *stream );

  <buf> is an array with (at least) <n> elements.
  <size> is the size of each element: <size> = \link("%%GLOBAL%%")sizeof\#(buf[0])
  <n> is the number of of elements in <buf> (to be read).
  <stream> is an open stream (see \#fopen\#).


Function reads <size> * <n> bytes into array <buf>. 
It returns the number of bytes read, or 0 on an error.

See also \#Standard I/O\# and \#fgets\#().
\end

screen( capsensitive("freopen") )
#include <stdio.h>

\#FILE\#* freopen( const char *filename, const char *\#mode\#, \#FILE\# *stream);

  <filename> is a string containing a filename (see \#Pathnames\#).
             If no file by that name exists, a new one is created.  
  <\#mode\#> is a string containing the read/write options.
  <stream> is an open stream (see \#fopen\#).


Function opens a file using a specific stream, which will be closed if
previously open.

It returns the stream pointer, or NULL if unsuccessful.

Note: This is one way to redirect I/O to \#stdin\# or \#stdout\#.

See also \#Standard I/O\# and \#fopen\#().
\end

screen( capsensitive("fscanf") )
#include <stdio.h>

int fscanf( \#FILE\# *stream, const char *format, \link("%%GLOBAL%%")...\# );

  <stream> is an open stream (see \#fopen\#).
  <format> is a string containing '%' sequences for converting text
           into variables and separating characters.
           See \link("%%GLOBAL%%")printf/scanf Formats\#.
  <...> is a list of pointers to variables to be filled.


Function performs a formatted read from a stream.
It returns the number of fields read or EOF if an error occurs.

See also \#Standard I/O\# and \#Formatting\#.
\end

screen( capsensitive("fseek") )
#include <stdio.h>

int fseek( \#FILE\# *stream, long offset, int from );

  <stream> was returned by \#fopen\#() or \#freopen\#().
  <offset> is the distance in bytes from the starting point.
  <from> defines the starting point:
         SEEK_SET (0)  from start of file.
         SEEK_CUR (1)  from current position.
         SEEK_END (2)  from end of file. 


Function positions the file indicator of the stream to a given
location (random access).

It returns 0 normally, or non-zero on error.

See also \#Standard I/O\# and \#fsetpos\#().
\end

screen( capsensitive("fsetpos") )
#include <stdio.h>

int fsetpos( \#FILE\# *stream, \#fpos_t\# *pos );

  <stream> was returned by \#fopen\#() or \#freopen\#().
  <pos> points to a variable previously calculated by \#fgetpos\#().


Function positions the file indicator of the stream to a given
location (random access).

See also \#Standard I/O\# and \#fseek\#().
\end

screen( capsensitive("ftell") )
#include <stdio.h>

long ftell( \#FILE\# *stream );

  <stream> was returned by \#fopen\#() or \#freopen\#().


Function returns the current position of the file indicator for later
used by \#fseek\#().  (It returns -1 on error.)

Note: Position is given relative to the start.

See also \#Standard I/O\# and \#fgetpos\#().
\end

screen( capsensitive("fwrite") )
#include <stdio.h>

\#size_t\# fwrite( void *buf, \#size_t\# size, \#size_t\# n, \#FILE\# *stream );

  <buf> is an array with (at least) <n> elements.
  <size> is the size of each element: <size> = \link("%%GLOBAL%%")sizeof\#(buf[0])
  <n> is the number of elements in <buf> (to be written).
  <stream> is an open stream (see \#fopen\#).


Function writes <size> * <n> bytes from array <buf>. 
It returns the number of bytes written (error if < size * n).

See also \#Standard I/O\# and \#fputs\#().
\end

screen( capsensitive("getc") )
#include <stdio.h>

int getc( \#FILE\# *stream );

  <stream> is an open stream (see \#fopen\#).


Function returns the next character from the stream, or EOF on end of
file.

Note: getc() is implemented as a macro.

See also \#Standard I/O\#, \#fgetc\#() and \#ungetc\#().
\end

screen( capsensitive("getchar") )
#include <stdio.h>

int getchar( void );


Function returns the next character from \#stdin\#, or EOF.

Note: getchar() is implemented as a macro.

See also \#Standard I/O\#, \#getc\#() and \#setbuf\#().
\end

screen( capsensitive("gets") )
#include <stdio.h>

char* gets( char *buf );

  <buf> is a char array used to store the string.  It must be large
        enough to hold any possible input line.


Function reads \#stdin\# to the next newline or EOF, and stores them as a
NULL terminated string.  The newline will NOT be included.

It returns a pointer to the string, or NULL on error.

Note: gets() is implemented as a macro.

See also \#Standard I/O\# and \#fgets\#().
\end

screen( capsensitive("perror") )
#include <stdio.h>

void perror( const char *msg );

  <msg> is a NULL terminated string (error message).


Function writes the supplied message to \#stderr\#, followed by a
semicolon, the status of \#errno\# and a newline.

See also \#Standard I/O\# and \#strerror\#().
\end

screen( capsensitive("printf") )
#include <stdio.h>

int printf( const char *format, \link("%%GLOBAL%%")...\# );

  <format> is a string containing text and '%' sequences for
           converting variables into text.
           See \link("%%GLOBAL%%")printf/scanf Formats\#.
  <...> is a list of variables to be formatted.


Function performs a formatted write to \#stdout\#.
It returns the number of characters written or EOF if an error occurs.

See also \#Standard I/O\# and \#Formatting\#.
\end

screen( capsensitive("putc") )
#include <stdio.h>

int putc( int c, \#FILE\# *stream);

  <c> is a character (0-255) passed as an int.
  <stream> is an open stream (see \#fopen\#).


Function writes one character to a stream.
It returns 0 normally, or EOF if an error occurs.

Note: putc() is implemented as a macro.

See also \#Standard I/O\# and \#fputc\#().
\end

screen( capsensitive("putchar") )
#include <stdio.h>

int putchar( int c );

  <c> is a character (0-255) passed as an int.


Function writes one character to \#stdout\#.
It returns 0 normally, or EOF if an error occurs.

Note: putchar() is implemented as a macro.

See also \#Standard I/O\# and \#putc\#().
\end

screen( capsensitive("puts") )
#include <stdio.h>

int puts( const char *s );

  <s> is a NULL terminated string to be written.


Function writes string <s> to \#stdout\#, followed by a newline.
It returns 0 normally, or EOF if an error occurs.

Note: puts() is implemented as a macro.

See also \#Standard I/O\# and \#fputs\#().
\end

screen( capsensitive("remove") )
#include <stdio.h>

int remove( const char *filename );

  <filename> is a string containing a filename (see \#Pathnames\#).


Function deletes a file.
It returns 0 normally, or non-zero if an error occurs.

See also \#Standard I/O\#.
\end

screen( capsensitive("rename") )
#include <stdio.h>

int rename( const char *old, const char *new );

  <old> is a string containing a filename of an existing file.
  <new> is a string containing the new filename.


This renames file <old> to be <new>.  These pathnames do not have to
be in the same directory, so long as they are on the same drive.
If <new> already exists, <old> will not be renamed.

It returns 0 normally, or non-zero if an error occurs.

See also \#Standard I/O\# and \#Pathnames\#.
\end

screen( capsensitive("rewind") )
#include <stdio.h>

int rewind( \#FILE\# *stream);

  <stream> is an open stream (see \#fopen\#).


Function positions the stream to the beginning of the file and clears
any error condition.

It returns 0 normally, or EOF if an error occurs.

See also \#Standard I/O\#.
\end

screen( capsensitive("scanf") )

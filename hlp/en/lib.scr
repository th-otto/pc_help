WF_BEVENT                                                      <aes.h>
----------------------------------------------------------------------
  int bitflags1;     /* 1 = untoppable window */
  int bitflags2;     /* reserved              */
  int bitflags3;     /* reserved              */
  int bitflags4;     /* reserved              */

  \#wind_get\#(handle, WF_BEVENT, &bitflags1, &bitflags2, &bitflags3,
           &bitflags4);
  \#wind_set\#(handle, WF_BEVENT, bitflags1, bitflags2, bitflags3,
           bitflags4);

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( capsensitive("WF_BOTTOM") )
WF_BOTTOM                                                      <aes.h>
----------------------------------------------------------------------

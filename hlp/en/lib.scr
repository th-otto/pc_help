#include <graphics.h>

int textheight( char *textstring );

  <textstring> is a NULL terminated string.


Function returns the height in pixels to needed to write <textstring>
using the current text settings.
It returns the horizontal extent when using VERT_DIR direction.

VDI: \#vqt_extent\#() and \#vqt_f_extent\#();

See also \#BGI Text\# and \#graphresult\#().
\end

screen( capsensitive("textwidth") )
#include <graphics.h>

int textwidth( char *textstring );

  <textstring> is a NULL terminated string.


Function returns the width in pixels to needed to write <textstring>
using the current text settings.
It returns the vertical extent when using VERT_DIR direction.

VDI: \#vqt_extent\#() and \#vqt_f_extent\#();

See also \#BGI Text\# and \#graphresult\#().

#include <aes.h>

int wind_new( void );


Function closes and deletes all windows, resets the \#wind_update\#()
status, flushes all buffers and restores the mouse ownership to the
system.

Note: Implemented starting with \#AES Version\# 1.40

\#AES Opcode\# 109

See also \#Window\#.
\end

screen( capsensitive("rsrc_load") )
#include <aes.h>

int rsrc_load( const char *pfname );

  <pfname> is a NULL terminated string containing the resource
           filename (see \#Pathnames\#).


Function loads a resource file into memory, resetting pointer and
converting object coordinates into pixels.

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 111

See also \#Resource\#.
\end

screen( capsensitive("rsrc_free") )
#include <aes.h>

int rsrc_free( void );


Function releases the memory allocated by \#rsrc_load\#().
It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 111

See also \#Resource\#.
\end

screen( capsensitive("rsrc_gaddr") )
#include <aes.h>

int rsrc_gaddr( int type, int index, void *addr );

  <type> is the type of data structure to locate, particularly:
         R_TREE  returns an \#OBJECT\#* for an \#Object Tree\# array.
         R_STRING returns a char* for a free string.
         R_IMAGEDATA returns a \#BITBLK\#* for a free image.
  <index> is the array index for the specified data structure type.
  <addr> returns a pointer to the specified a data structure.


Function can return pointers to any of the data structures listed in
\#Resource File Data Types\#.  However, the <index> values used refer to
the array index inside the resource file, which is generally not
known.  (The header file provided by a resource file editor generally
provides an \#OBJECT\# index relative to the start of the tree, not to the
start of the resource file array.)  While it is possible to compute
the <index> values, it is easier simply to point to the needed data
structure using:

  \#OBJECT\# *tree;
  rsrc_gaddr(R_TREE, TREENUM, &tree);  /* TREENUM from header file */
  tree[OBNUM].ob_state = SELECTED;     /* OBNUM from header file   */
  tree[OBNUM].ob_spec.tedinfo->te_ptext = "New string";
  ...

Its return value is a positive number normally, or 0 on an error.

\#AES Opcode\# 112

See also \#Resource\# and \#Resource File Data Types\#.
\end

screen( capsensitive("rsrc_saddr") )
#include <aes.h>

int rsrc_saddr( int type, int index, void *addr );

  <type> is the type of pointer to add or replace:
         R_FRSTR - free string (char*).
         R_FRIMG - free image (BITBLK*).
  <index> is the array index for the specified pointer type.
  <addr> is the address of the specified a data structure.


Function can be used to add or replace free strings or free images for
subsequent use by \#rsrc_gaddr\#().

It returns is a positive number normally, or 0 on an error.

\#AES Opcode\# 113

See also \#Resource\#.
\end

screen( capsensitive("rsrc_obfix") )
#include <aes.h>

int rsrc_obfix( \#OBJECT\# *tree, int object );

  <tree> is the \#Object Tree\# array.
  <object> is the array index for the specified object.


Function converts \#OBJECT\# screen coordinates from the resource file
format (number characters in the low byte, a signed pixel offset in
the high byte) to pixels (using the current resolution).

This conversion is performed automatically by \#rsrc_load\#().

It always returns a value of 1.

Note: <object> does not actually have to be in the \#Object Tree\#
      pointed to by <tree>.  It is simply the offset from <tree> in
      the \#OBJECT\# array.

\#AES Opcode\# 114

See also \#Resource\# and \#graf_handle\#().
\end

screen( capsensitive("rsrc_rcfix") )
#include <aes.h>

int rsrc_rcfix( \#RSHDR\# *rc_header );

  <rc_header> is a resource file header in RAM.


Function initialize a resource file already in RAM, setting
\#rsrc_gaddr\#() pointers and converting object coordinates into pixels.

Rather than loading the resource file at run time, some programs
include the resource file in the program's data segment.

It returns a positive number normally, or 0 on an error.

Note: One cannot also use \#rsrc_load\#() without an intervening call to
      \#rsrc_free\#().
      Implemented starting with \#AES Version\# 4.00

\#AES Opcode\# 115

See also \#Resource\# and \#AES_PROCESS\#.
\end

screen( capsensitive("shel_read") )
#include <aes.h>

int shel_read( char *pname, char *pcmd );

  <pname> is a buffer to be filled with the program pathname.
  <pcmd> is a buffer to be filled with the command line (128 bytes).
         The first byte holds the number of remaining bytes.


Function returns the pathname of the application and the command line
(if any).

It returns a positive number normally, or 0 on an error.

Note: A command line can only be created if the application is invoked
      by another program or by a data file (e.g. dropping a data file
      on top of the application icon on the desktop) in which case
      the command line consists of the data filename.
      shel_read() will not return the command line for a TTP program.

\#AES Opcode\# 120

See also \#Shell\#, \link("%%GLOBAL%%")main\#() and \#BASPAG\#.
\end

screen( capsensitive("shel_write") )
#include <aes.h>

int shel_write( int doex, int isgr, int iscr, char *cmd, char *tail );

*** Prior to \#AES Version\# 4.00 ***

  <doex> selects whether to run another application (1) or return to
         the desktop (0) when this application terminates.
         (Calls from child processes will take effect when the parent
         process terminates.)
  <isgr> informs GEM that the next application uses graphics (1)
         or not (0).
  <iscr> informs GEM that the next application uses AES (1)
         or not (0).
  <cmd> is a NULL terminated string containing the program pathname.
  <tail> is a Pascal string containing the command line (max 128 bytes).
         The first byte holds the number of remaining bytes.

It returns a positive number normally, or 0 on an error.

*** After \#AES Version\# 4.00 ***

  <doex> contains the mode (low byte) and bit flags (high byte).
         Mode values are:
          0 = \#SWM_LAUNCH\#
          1 = \#SWM_LAUNCHNOW\#
          3 = \#SWM_LAUNCHACC\#
          4 = \#SWM_SHUTDOWN\#
          6 = \#SWM_REZCHANGE\#
          7 = \#SWM_BROADCAST\#
          8 = \#SWM_ENVIRON\#
          9 = \#SWM_NEWMSG\#
         10 = \#SWM_AESMSG\#

        Bit flags are:
         0x100 = set RAM limit
         0x200 = set process priority
         0x400 = set default directory
         0x800 = set environment string

        If any of the bit flags are set, <cmd> points to a \#SHELW\#
        structure containing the needed information.

  The remaining parameters and the return value depend on <doex>.

\#AES Opcode\# 121

See also \#Shell\#, \#Pexec\#() and \#AES_SHELL\#.
\end

screen( capsensitive("shel_get") )
#include <aes.h>

int shel_get( char *buf, int len );

  <buf> is the buffer array to be filled.
  <len> is the size of buffer in bytes (must be at least 4192).


Function reads the AES internal buffer, which is used to store
DESKTOP.INF data.

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 122

See also \#Shell\#.
\end

screen( capsensitive("shel_put") )
#include <aes.h>

int shel_put( char *buf, int len );

  <buf> points to the new AES buffer data.
  <len> is the size of buffer in bytes (must <=1024 until Rainbow TOS,
        or <=4192 for later versions).


Function writes new data into the AES internal buffer, which is
currently used to store DESKTOP.INF data.

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 123

See also \#Shell\#.
\end

screen( capsensitive("shel_find") )
#include <aes.h>

int shel_find( char *pbuff );

  <pbuff> is a two way buffer:
          It passes the filename (NULL terminated).
          It returns the pathname (NULL terminated).


Function searches the current directory and each directory in the
search path.

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 124

See also \#Shell\# and \#Pathnames\#.
\end

screen( capsensitive("shel_envrn") )
#include <aes.h>

int shel_envrn( char **pvalue, char *parm );

  <pvalue> returns the address of the byte following the parameters
           string.
  <parm> is a NULL terminated string of the form "PATH=".


Function searches the TOS environment for a specific parameter.
It always returns a value of 1.

\#AES Opcode\# 125

See also \#Shell\#, \#SWM_ENVIRON\# and \#environment\#.

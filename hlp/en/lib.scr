screen( capsensitive("Line A") )
Line A Graphics
----------------------------------------------------------------------
... are a set of primitive screen graphics functions.  Instead of
using a \link("%%GLOBAL%%")TRAP\# instruction, they use unimplemented instructions
in the range $A000 - $AFFF to create an exception (see \link("%%GLOBAL%%")ALINE\#).

Atari plans to discontinue Line A, and the functions can only be used
with ST screen resolutions.  \#VDI\# functions should be used instead.

\#linea_init\# - must be called first

\#bit_blt\#          \#get_pixel\#        \#set_ln_mask\#      \#text_blt\#
\#draw_circle\#      \#hide_mouse\#       \#set_wrt_mode\#     \#transform_mouse\#
\#draw_line\#        \#horizontal_line\#  \#set_pattern\#      \#undraw_sprite\#
\#draw_sprite\#      \#print_string\#     \#set_clip\#
\#filled_polygon\#   \#put_pixel\#        \#set_text_blt\#
\#filled_rect\#      \#set_fg_bp\#        \#show_mouse\#

See also \#LINEA\#, \#VDIESC\#, \#FONTS\# and \#LINEA_FUNP\#.
\end

screen( capsensitive("SDB") )
Sprite Definition Block                                      <linea.h>
----------------------------------------------------------------------
typedef struct {
  int xhot,             /* x location of origin */
  int yhot,             /* y location of origin */
  int form,             /* VDIFM or XORFM       */
  int bgcol,            /* Background color     */
  int fgcol,            /* Foreground color     */
  int image[32];        /* Sprite-Image         */
 } SDB;

The origin location is given relative to the upper left corner of the
16x16 space (positive downward).

The image array consists of two interleaved 16x16 pixel bitmaps:

image[0] = top row of mask
image[1] = top row of data
image[2] = second row of mask
image[3] = second row of data
 ...

The mask determines what part of the 16x16 space will be transparent
(0) or opaque (1).
The data determines where to use the foreground color (1) or the
background color (0).  The data image must fit within the mask.

See also \#MFORM\#.
\end

screen( capsensitive("SSB") )
Sprite Save Buffer                                           <linea.h>
----------------------------------------------------------------------
typedef int SSB[10 + 4 * 64];      /* for 4 or less bit planes */

Used to save the screen image "behind" a sprite.

See \#draw_sprite\#() and \#undraw_sprite\#().
\end

screen( capsensitive("FONT_HDR"),
		capsensitive("fonthrd") )
Bitmap Font Header                                           <linea.h>
----------------------------------------------------------------------
typedef struct fonthdr {
  int id;                         /* font ID number (1 = system)    */
  int size;                       /* size of font in "points"       */
  char facename[32];              /* name of font                   */
  int ade_lo;                     /* smallest ASCII value in font   */
  int ade_hi;                     /* largest ASCII value in font    */
  int top_dist;                   /* top to baseline distance       */
  int asc_dist;                   /* assent line to baseline dist.  */
  int hlf_dist;                   /* half line to baseline distance */
  int des_dist;                   /* baseline to descent line dist. */
  int bot_dist;                   /* baseline to bottom distance    */
  int wchr_wdt;                   /* width of widest character      */
  int wcel_wdt;                   /* cell width of widest character */
  int lft_ofst;                   /* increase to left when skewed   */
  int rgt_ofst;                   /* increase to right when skewed  */
  int thckning;                   /* pixel smear for boldface (1)   */
  int undrline;                   /* thickness for underline (1)    */
  int lghtng_m;                   /* bit mask for light (0x5555)    */
  int skewng_m;                   /* bit mask for skew (0x5555)     */

  struct {
    unsigned             :12;     /* not used                       */
    unsigned mono_spaced : 1;     /* proportional spacing           */
    unsigned f68000      : 1;     /* 0 = swap high/low bytes        */
    unsigned hot         : 1;     /* horizontal offset table exists */
    unsigned system      : 1;     /* Default system font            */
   } flags;

  char *hz_ofst;                  /* horizontal offset table        */
  int *ch_ofst;                   /* character offset table         */
  void *fnt_dta;                  /* font image data                */
  int frm_wdt;                    /* width of font image in bytes   */
  int frm_hgt;                    /* height of font image in pixels */
  struct fonthdr *next;           /* pointer to next font           */
} FONT_HDR;

The font image can be treated as a single bit plane raster image one
character high, packed from left to right with ade_lo to ade_hi.

The character offset table contains the horizontal pixel location for
the start of each character.

The horizontal offset table (when used) contains a left/right shift
to be applied to the bit image for each character.
\end

screen( capsensitive("LINEA") )
Line A Parameters                                            <linea.h>
----------------------------------------------------------------------
typedef struct {
  int v_planes;               /* number bitplanes (1, 2 or 4)       */
  int v_lin_wr;               /* number bytes per scanline          */
  int *contrl;                /* control array (see \#GEMPARBLK\#)      */
  int *intin;                 /* input int array                    */
  int *ptsin;                 /* input x,y coordinates              */
  int *intout;                /* output int array                   */
  int *ptsout;                /* output x,y coordinates             */
  int fg_bp_1;                /* 1 = use plane 0 (see \#Bit Planes\#)   */
  int fg_bp_2;                /* 1 = use plane 1                    */
  int fg_bp_3;                /* 1 = use plane 2                    */
  int fg_bp_4;                /* 1 = use plane 3                    */
  int lstlin;                 /* don't draw last pixel in pline     */
  unsigned ln_mask;           /* line pattern mask (\#vsl_udsty\#)      */
  int wrt_mode;               /* VDI writing mode (\#vswr_mode\#)       */
  int x1, y1, x2, y2;         /* line segment coordinates           */
  void *patptr;               /* fill pattern (\#vsf_udpat\#)           */
  unsigned patmsk;            /* pattern index mask                 */
  int multifill;              /* 0 = monochrome fill pattern        */
  int clip;                   /* clipping flag (0 = disabled)       */
  int xmn_clip, ymn_clip,
      xmx_clip, ymx_clip;     /* clipping rectangle                 */

  int xacc_dda;               /* text scaling accumulator           */
  int dda_inc;                /* text scale factor (0 - 256)        */
  int t_sclsts;               /* 1 = scale up, 0 = scale down       */
  int mono_status;            /* 0 = proportional spacing           */
  int sourcex, sourcey;       /* x,y coordinates in font image      */
  int destx, desty;           /* x,y coordinates in screen image    */
  int delx;                   /* character width                    */
  int dely;                   /* character height                   */
  void *fbase;                /* font image data                    */
  int fwidth;                 /* width of font image in bytes       */
  int style;                  /* effects bit flag: 1 = bold,        */
                              /* 2=light, 4=underline, 8 = outline  */
  unsigned litemask;          /* bit mask for light text            */
  unsigned skewmask;          /* bit mask for skew (italics)        */
  int weight;                 /* width to thicken boldface          */
  int r_off;                  /* increase to right for skew         */
  int l_off;                  /* increase to left for skew          */
  int scale;                  /* 0 = no scaling                     */
  int chup;                   /* rotation (0, 900, 1800, 2700)      */
  int text_fg;                /* foreground \link("Bit Planes")color\# for text blt      */
  void *scrtchp;              /* buffer for effects                 */
  int scrpt2;                 /* index in buffer                    */
  int text_bg;                /* background \link("Bit Planes")color\# for text blt      */
  int copy_tran;              /* 1 = transparent, 0 = opaque        */
  int (*fill_abort)( void );  /* called by seed_fill()              */
 } LINEA;

See also \#linea_init\#().
\end

screen( capsensitive("VDIESC") )
VDI Parameters                                               <linea.h>
----------------------------------------------------------------------
typedef struct {
  long reserved6;            /* reserved for future use             */
  \#FONT_HDR\# *cur_font;        /* current font header                 */
  int reserved5[23];         /* reserved for future use             */
  int m_pos_hx, m_pos_hy;    /* offset to hot spot of mouse         */
  int m_planes;              /* VDIFM or XORFM                      */
  int m_cdb_bg;              /* mouse background color (\#Bit Planes\#) */
  int m_cdb_fg;              /* mouse foreground color (\#Bit Planes\#) */
  int mask_form[32];         /* mouse mask/image data (see \#SDB\#)     */
  int inq_tab[45];           /* \#VDI Extended\# parameters 0-44        */
  int dev_tab[45];           /* \#VDI Description\# parameters 0-44     */
  int gcurx, gcury;          /* current mouse image location        */
  int m_hid_ct;              /* mouse hide count (0 = visible)      */
  int mouse_bt;              /* mouse button bitmap:                */
                             /* 1 = left button down (bit 0)        */
                             /* 2 = right button down (bit 1)       */
  int req_col[3][16];        /* color pallette (see \#vq_color\#)       */
  int siz_tab[15];           /* \#VDI Description\# parameters 45-57    */
  int reserved4[2];          /* reserved for future use             */
  void *cur_work;            /* VDI workstation attribute table     */
  \#FONT_HDR\# *def_font;        /* default font header                 */
  \#FONT_HDR\# *font_ring[4];    /* start of font header linked lists   */
  int font_count;            /* total number of above fonts         */
  int reserved3[45];         /* reserved for future use             */
  char cur_ms_stat;          /* mouse status bits (since last intr.)*/
                             /* low nibble same as mouse_bt         */
                             /* 32 = mouse moved (bit 5)            */
                             /* 64 = right button changed (bit 6)   */
                             /* 128 = left button changed (bit 7)   */
  char reserved2;            /* reserved for future use             */
  int v_hid_cnt;             /* text cursor hide count (0 = visible)*/
  int cur_x, cur_y;          /* location to draw new mouse image    */
  char cur_flag;             /* !0 = redraw mouse at next vblank    */
  char mouse_flag;           /* !0 = disable mouse events           */
  long reserved1;            /* reserved for future use             */
  int v_sav_xy[2],           /* text cursor location                */
  int save_len;              /* height of mouse save buffer (16)    */
  void *save_addr;           /* screen raster address for save area */
  int save_stat;             /* save status bits:                   */
                             /* bit 0: valid buffer (1 = OK)        */
                             /* bit 1: width of save                */
                             /*        (0 = 16 bits, 1 = 32 bits)   */
  long save_area[4][16];     /* screen save area for mouse          */
  void (*user_tim)( void );  /* timer interrupt vector (\#vex_timv\#)   */
  void (*next_tim)( void );  /* original timer vector save area     */
  void (*user_but)( void );  /* button interrupt vector (\#vex_butv\#)  */
  void (*user_cur)( void );  /* mouse redraw vector (\#vex_curv\#)      */
  void (*user_mot)( void );  /* mouse moved vector (\#vex_motv\#)       */
  int v_cel_ht;              /* text cell height                    */
  int v_cel_mx;              /* max text column index (num col - 1) */
  int v_cel_my;              /* max text row index (num row - 1)    */
  int v_cel_wr;              /* text cell width in bytes            */
  int v_col_bg;              /* text background color (\#Bit Planes\#)  */
  int v_col_fg;              /* text foreground color (\#Bit Planes\#)  */
  void *v_cur_ad;            /* screen raster address for cursor    */
  int v_cur_off;             /* offset from \#Physbase\# to first cell  */
  int v_cur_xy[2];           /* cursor x,y location                 */
  char v_period;             /* cursor blink rate (see \#Cursconf\#)    */
  char v_cur_ct;             /* countdown timer for cursor blink    */
  void *v_fnt_ad;            /* system font image data (\#FONT_HDR\#)   */
  int v_fnt_nd;              /* last ASCII character in font image  */
  int v_fnt_st;              /* first ASCII character in font image */
  int v_fnt_wd;              /* width of font image in bytes        */
  int v_rez_hz;              /* screen width in pixels              */
  int *v_off_ad;             /* character offset table              */
  int reserved;              /* reserved for future use             */
  int v_rez_vt;              /* screen height in pixels             */
  int bytes_lin;             /* number bytes per screen line        */
 } VDIESC;

See also \#linea_init\#().
\end

screen( capsensitive("BITBLT") )
\#bit_blt\#() Parameters                                         <linea.h>
----------------------------------------------------------------------
typedef struct {
  int b_wd;              /* width of raster block in pixels         */
  int b_ht;              /* height of raster block in pixels        */
  int plane_ct;          /* number of bit planes                    */
  int fg_col;            /* foreground color (see \#Bit Planes\#)       */
  int bg_col;            /* background color (see \#Bit Planes\#)       */
  char op_tab[4];        /* \#Raster Mode\# for each bit plane.         */
  int s_xmin, s_ymin;    /* block location in source raster         */
  void *s_form;          /* source raster address                   */
  int s_nxwd;            /* number bits per pixel (source)          */
  int s_nxln;            /* width of source raster in bytes         */
  int s_nxpl;            /* byte offset between planes (2)          */
  int d_xmin, d_ymin;    /* block location in destination raster    */
  void *d_form;          /* destination raster address              */
  int d_nxwd,            /* number bits per pixel (destination)     */
  int d_nxln,            /* width of destination raset in bytes     */
  int d_nxpl;            /* byte offset between planes (2)          */
  void *p_addr;          /* address of pattern buffer (0 = none)    */
  int p_nxln;            /* number bytes of pattern per line        */
  int p_nxpl;            /* byte offset between planes              */
  int p_mask;            /* size of pattern buffer                  */
  char filler[24];       /* work array                              */
 } BITBLT;
\end

screen( capsensitive("FONTS") )
System Font Headers                                          <linea.h>
----------------------------------------------------------------------
typedef struct {
  \#FONT_HDR\# *font[3];       /* could be more than 3 entries */
} FONTS;

Array of pointers to the system font headers:
  font[0]->facename = "6x6 system font"
  font[1]->facename = "8x8 system font"
  font[2]->facename = "8x16 system font"
  font[3]->facename = "16x32 system font"
The array is terminated with a NULL pointer.

See \#linea_init\#().
\end

screen( capsensitive("LINEA_FUNP") )
Line A Function Jump Vectors                                 <linea.h>
----------------------------------------------------------------------
typedef struct {
  int (*funp[16])( void );
 } LINEA_FUNP;

Jump vectors for Line A commands (NOT the C bindings).

Vector   | Command | C Binding
---------+---------+-------------------
funp[0]  | $A000   | \#linea_init\#()
funp[1]  | $A001   | \#put_pixel\#()
funp[2]  | $A002   | \#get_pixel\#()
funp[3]  | $A003   | \#draw_line\#()
funp[4]  | $A004   | \#horizontal_line\#()
funp[5]  | $A005   | \#filled_rect\#()
funp[6]  | $A006   | \#filled_polygon\#()
funp[7]  | $A007   | \#bit_blt\#()
funp[8]  | $A008   | \#text_blt\#()
funp[9]  | $A009   | \#show_mouse\#()
funp[10] | $A00A   | \#hide_mouse\#()
funp[11] | $A00B   | \#transform_mouse\#()
funp[12] | $A00C   | \#undraw_sprite\#()
funp[13] | $A00D   | \#draw_sprite\#()
funp[14] | $A00E   | copy_raster() - not implemented
funp[15] | $A00F   | seed_fill() - not implemented
\end

screen( capsensitive("linea_init") )
#include <linea.h>

void linea_init( void );


Function initializes the following global structure pointers:

extern \#LINEA\# *Linea;
extern \#VDIESC\# *Vdiesc;
extern \#FONTS\# *Fonts;
extern \#LINEA_FUNP\# *Linea_funp;

See also \#Line A\# and \#v_opnvwk\#().
\end

screen( capsensitive("put_pixel") )
#include <linea.h>

void put_pixel( int x, int y, int color );

  <x> is the x coordinate of the pixel.
  <y> is the y coordinate of the pixel.
  <color> is the color bit map to be used.


Function sets one pixel of the screen raster to be a given color.

See \#Bit Planes\# to translate color indexes to bit maps.

See also \#Line A\# and \#v_pmarker\#().
\end

screen( capsensitive("get_pixel") )
#include <linea.h>

int get_pixel( int x, int y);

  <x> is the x coordinate of the pixel.
  <y> is the y coordinate of the pixel.


Function returns the color bit map for a pixel of the screen raster.

See \#Bit Planes\# to translate color indexes to bit maps.

See also \#Line A\# and \#v_get_pixel\#()
\end

screen( capsensitive("draw_line") )
#include <linea.h>

void draw_line( int x1, int y1, int x2, int y2 );

  <x1> is the starting x coordinate of the line.
  <y1> is the starting y coordinate of the line.
  <x2> is the ending x coordinate of the line.
  <y2> is the ending y coordinate of the line.


Function draws a straight line from (x1,y1) to (x2,y2) using the
attributes set by \#set_fg_bp\#(), \#set_ln_mask\#() and \#set_wrt_mode\#().

See also \#Line A\# and \#v_pline\#()
\end

screen( capsensitive("horizontal_line") )
#include <linea.h>

void horizontal_line( int x1, int y1, int x2 );

  <x1> is the starting x coordinate of the line.
  <y1> is the y coordinate of the line.
  <x2> is the ending x coordinate of the line.


Function draws a straight line from (x1,y1) to (x2,y1) using the
attributes set by \#set_fg_bp\#(), \#set_ln_mask\#() and \#set_wrt_mode\#().

See also \#Line A\# and \#v_pline\#()
\end

screen( capsensitive("filled_rect") )
#include <linea.h>

void filled_rect( int x1, int y1, int x2, int y2 );

  <x1> is the x coordinate for the left edge of the rectangle.
  <y1> is the y coordinate for the top edge of the rectangle.
  <x2> is the x coordinate for the right edge of the rectangle.
  <y2> is the y coordinate for the bottom edge of the rectangle.


Function draws a filled rectangle using the attributes set by
\#set_fg_bp\#(), \#set_pattern\#(), \#set_wrt_mode\#() and \#set_clip\#().

See also \#Line A\#, \#vr_recfl\#() and \#v_bar\#().
\end

screen( capsensitive("filled_polygon") )
#include <linea.h>

void filled_polygon( int *xy, int count );

  <xy> is an array of (x,y) coordinates.  The last pair must be the
       same as the first.
  <count> is the number of (x,y) pairs.


Function draws a filled rectangle using the attributes set by
\#set_fg_bp\#(), \#set_pattern\#(), \#set_wrt_mode\#() and \#set_clip\#().

See also \#Line A\#, \#v_pline\#() and \#v_fillarea\#().
\end

screen( capsensitive("bit_blt") )
#include <linea.h>

void bit_blt( \#BITBLT\# *bitblt );

  <bitblt> is the address of a structure containing the block, source
           and destination raster info.


Function copies a block from one raster image to another.

See also \#Line A\#, \#vro_cpyfm\#() and \#vrt_cpyfm\#().
\end

screen( capsensitive("text_blt") )

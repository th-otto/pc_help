#include <aes.h>

int objc_change( \#OBJECT\# *tree, int object, int resvd,
                 int xclip, int yclip, int wclip, int hclip,
                 int newstate, int redraw );

  <tree> is the \#Object Tree\# array.
  <object> is the array index for the object to be changed.
  <resvd> is not used.
  <xclip> is the left edge of the clipping window (screen coordinates).
  <yclip) is the top edge of the clipping window (screen coordinates).
  <wclip> is the width of the clipping window (pixels).
  <hclip> is the height of the clipping window (pixels).
  <newstate> is the new value of the \#Object State\#.
  <redraw> determines whether to redraw the object (1) or not (0).


Function modifies the \#Object State\# of an object and (optionally)
redraws it.

Only the portion of the object which is inside the clipping window
will be redrawn.

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 47

See also \#Object\#.
\end

screen( capsensitive("form_do") )
#include <aes.h>

int form_do( \#OBJECT\# *tree, int startob );

  <tree> is the \#Object Tree\# array.
  <startob> is the index of the editable object in which the cursor is
            to be placed, or 0 if there are no editable objects.


Function handles user interaction with a dialog box.
It will not return until an EXIT object is selected or a TOUCHEXIT
object is clicked.

It returns the index of the object which caused the exit.

\#AES Opcode\# 50

See also \#Form\#, \#Dialog Box\#, and \#objc_edit\#().
\end

screen( capsensitive("form_dial") )
#include <aes.h>

int form_dial( int flag,
               int smallx, int smally, int smallw, int smallh,
               int bigx, int bigy, int bigw, int bigh );

  <flag> selects the type of operation:
         FMD_START  reserve screen space for dialog box.
         FMD_GROW   animated box moves from 'small' to 'big' coord.
         FMD_SHRINK animated box moves from 'big' to 'small' coord.
         FMD_FINISH releases screen space (restores desktop).

  <smallx> ... <smallh> are screen coordinates used only by FMD_GROW
                        and FMD_SHRINK.  (Use 0 otherwise.)
  <bigx> ... <bigh> are the screen coordinates of the dialog box.


Function reserves/releases screen space for a dialog box.

After it is called using FMD_FINISH, the dialog box is erased and
replaced by the desktop (leaving a green rectangle).  It will then
send WM_REDRAW messages to any affected windows.

It does NOT restore the screen to its previous condition, nor will it
restore drop-down menu titles.

The FMD_GROW and FMD_SHRINK flags are optional.  If the dialog box was
initiated by selecting a button or icon, one could use these flags to
show the button or icon transforming into the dialog box and back.

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 51

See also \#Form\#, \#Dialog Box\#, \#graf_growbox\#() and \#graf_shrinkbox\#().
\end

screen( capsensitive("form_alert") )
#include <aes.h>

int form_alert( int default_button, char *form_string );

  <default_button> is the button number (1,2 or 3) which will be
                   selected by the RETURN key, or O for none.
  <form_string> is a NULL terminated text string which defines the
                dialog box to be created (see \#Form Alert Format\#).


Function is used primarily for error messages or alerts.
It creates and executes a dialog box with the following form:
  A choice of icons: 0=none, 1=!, 2=? and 3=STOP.
  Up to five lines of text, 30 characters max per line.
  Up to three exit buttons, 10 characters max per button.
When done, it restores the screen to its original condition.

It returns the number of the button selected (1,2 or 3).

\#AES Opcode\# 52

See also \#Form\# and \#sprintf\#().
\end

screen( capsensitive("form_error") )
#include <aes.h>

int form_error( int error_num );

  <error_num> is an MS_DOS error code:
              2,3,18 "This application cannot find the folder you just
                      tried to access"
              4 "This application does not have room to open another
                 document.  To make room, close any document you do
                 not need."
              5 "An item with this name already exits in the directory
                 or this item is set to Read-only status."
              8,10,11 "There is not enough memory for the application
                       you just tried to run."
              15 "The drive you specified does not exist."
              otherwise "TOS error #%u"


Function produces a limited number of error message dialogs.
It always returns 1 (the button selected).

\#AES Opcode\# 53

See also \#Form\#, \#errno\# and \#BIOS/GEMDOS Error Code\#s.
\end

screen( capsensitive("form_center") )
#include <aes.h>

int form_center( \#OBJECT\# *tree, int *x, int *y, int *w, int *h );

  <tree> is the \#Object Tree\# array.
  <x> returns the left edge of the clipping rectangle.
  <y> returns the top edge of the clipping rectangle.
  <w> returns the width of the clipping rectangle.
  <h> returns the height of the clipping rectangle.


Function changes the x,y coordinates of the root \#Object\# to center the
\#Object Tree\# on the screen.
It also returns the clipping rectangle coordinates.

It always returns 1.

\#AES Opcode\# 54

See also \#Form\# and \#Dialog Box\#.
\end

screen( capsensitive("form_keybd") )
#include <aes.h>

int form_keybd( \#OBJECT\# *tree, int object, int reserved, int code,
                int *obnext, int *retkey );

  <tree> is the \#Object Tree\# array.
  <object> is the index of the object being edited.
  <reserved> should be set to 1.
  <code> contains a character in the low byte and a keyboard scan code
         in the high byte.
  <obnext> returns the index of the next object to be edited.
  <retkey> returns <code> with the scan code removed.


Function checks for UP_ARROW and DOWN_ARROW keys, in which case it
returns the previous or next (respectively) editable object in the
\#Object Tree\#.

The return value is 1 normally, or 0 if the RETURN key was used
(in which case <obnext> returns the DEFAULT object).

Example (replaces form_do() in the \#Dialog Box\# example):

  ob = startob;
  objc_edit(tree, ob, 0, &cursor, ED_INIT);
  while(-1) {
    code = evnt_keybd();
    if(!form_keybd(tree, ob, 1, code, &nextob, &key)) break;
    if(nextob) {
      if(!key) {
        objc_edit(tree, ob, 0, &cursor, ED_END);
        objc_edit(tree, nextob, 0, &cursor, ED_INIT);
        ob = nextob;
       }
      else objc_edit(tree, ob, key, &cursor, ED_CHAR);
     }
   }
  button = nextob;

\#AES Opcode\# 55

See also \#Form\#, \#evnt_keybd\#(), \#objc_edit\#() and \link("%%GLOBAL%%")Scan Codes\#.
\end

screen( capsensitive("form_button") )
#include <aes.h>

int form_button( \#OBJECT\# *tree, int object, int clicks, int *nextob );

  <tree> is the \#Object Tree\# array.
  <object> is the index of the object clicked.
  <clicks> is the number of clicks (see \#evnt_button\#).
  <nextob> returns <object> unless it is a radio button, in which case
           it returns the parent object index.


Function handles a button event for SELECTABLE objects, including
radio buttons (RBUTTON).

It returns a positive number normally, or 0 when a DEFAULT or EXIT
object is selected (see \#Object Flag\#).

\#AES Opcode\# 56

See also \#Form\#, \#objc_find\#() and \#objc_change\#().
\end

screen( capsensitive("graf_rubberbox"),
		capsensitive("graf_rubbox") )
#include <aes.h>

int graf_rubberbox( int x, int y, int min_width, int min_height,
                    int *last_width, int *last_height );

  <x> is the x coordinate of the left edge.
  <y> is the y coordinate of the top edge.
  <min_width> is the box's smallest possible width in pixels.
  <min_height> is the box's smallest possible height in pixels.
  <last_width> returns the width when the mouse button is released.
  <last_height> returns the height when the mouse button is released.


Function draws a box with a fixed upper left corner while the lower
right hand corner follows the mouse pointer.  The left mouse button
must be down before this function is called, and it returns when the
left mouse button is released. 

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 70

See also \#Graphics\#.
\end

screen( capsensitive("graf_dragbox") )
#include <aes.h>

int graf_dragbox( int width, int height, int start_x, int start_y,
                  int bound_x, int bound_y, int bound_w, int bound_h,
                  int *last_x, int *last_y );

  <width> is the width of the box in pixels.
  <height> is the height of the box in pixels.
  <start_x> is the starting x coordinate for the box.
  <start_y> is the starting y coordinate for the box.
  <bound_x> ... <bound_h> defines a rectangle which limits the
                          movement of the box.
  <last_x> returns the x coordinate when the mouse button is released.
  <last_y> returns the y coordinate when the mouse button is released.


Function lets the user drag a box with the mouse pointer, so long as
the box remains completely inside the bounding rectangle.
The left mouse button must be down before this function is called, and
it returns when the left mouse button is released. 

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 71

See also \#Graphics\#.
\end

screen( capsensitive("graf_mbox"),
		capsensitive("graf_movebox") )
#include <aes.h>

int graf_movebox( int width, int height, int source_x, int source_y,
                  int dest_x, int dest_y);

  <width> is the width of the box in pixels.
  <height> is the height of the box in pixels.
  <source_x> is the starting x coordinate for the box.
  <source_y> is the starting y coordinate for the box.
  <dest_x> is the final x coordinate for the box.
  <dest_y> is the final y coordinate for the box.


Function draws a moving box (fixed size).
It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 72

See also \#Graphics\#.
\end

screen( capsensitive("graf_growbox") )
#include <aes.h>

int graf_growbox( int small_x, int small_y, int small_w, int small_h,
                  int big_x, int big_y, int big_w, int big_h);

  <small_x> is the starting x coordinate for the box.

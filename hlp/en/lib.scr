WF_OWNER                                                       <aes.h>
----------------------------------------------------------------------
  int apid;     /* is the application id for this window          */
  int status;   /* 0 = closed, 1 = open                           */
  int prev;     /* window handle of previous (above) window       */
  int next;     /* window handle of next (below) window           */

  \#wind_get\#(handle, WF_OWNER, &apid, &status, &prev, &next);

Note: Implemented starting with \#AES Version\# 4.00
\end


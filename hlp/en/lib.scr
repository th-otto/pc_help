#include <aes.h>

int graf_mkstate( int *mx, int *my, int *button, int *kstate );

  <mx> returns the mouse x coordinate.
  <my> returns the mouse y coordinate.
  <button> returns the mouse button state:
           0 = no buttons pressed
           1 = left button pressed
           2 = right button pressed
           3 = both buttons pressed
  <kstate> returns the keyboard state (bit flags):
           K_RSHIFT = right Shift
           K_LSHIFT = left Shift
           K_CNTL   = Control
           K_ALT    = Alternate


Function returns the current mouse location and status.
The return value is always 1.

\#AES Opcode\# 79

See also \#Graphics\#, \#evnt_mouse\#(), \#vq_mouse\#() and \#vq_key_s\#().
\end

screen( capsensitive("scrp_read") )
#include <aes.h>

int scrp_read( char *pscrap );

  <pscrap> is the buffer to be filled with a NULL terminated string.


Function reads the clipboard (scrap directory pathname).
It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 80

See also \#Scrap\#.
\end

screen( capsensitive("scrp_write") )
#include <aes.h>

int scrp_write( char *pscrap );

  <pscrap> is a NULL terminated string.


Function puts a new scrap directory pathname in the clipboard.
It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 81

See also \#Scrap\#.
\end

screen( capsensitive("fsel_input") )
#include <aes.h>

int fsel_input( char *path, char *file, int *button );

  <path> is a buffer which contains the directory pathname (input and
         output), including wildcard characters for the filename.
         Should be at least 65 bytes.
  <file> is a buffer which contains the filename.extension (input and
         output).  Should be at least 13 bytes.
  <button> returns 0 when the CANCEL button is selected, and 1 when
           the OK button is selected.


Function executes the standard file selector dialog box.
It returns a positive number normally, or 0 on an error.

Example:

  char path[65], file[13];
  int button, i, ret;

  path[0] = 'A' + \#Dgetdrv\#();    /* initialize directory pathname */
  path[1] = ':';
  \#Dgetpath\#( path+2, 0 );
  \#strcat\#( path, "\\\\*.*" );
  file[0] = 0;                    /* initialize filename           */

  fsel_input(path,file,&button);  /* execute file selector         */
  if(button == 0) goto abort;
                                  /* merge directory and filename  */
  for(i=\#strlen\#(path); i>2; i--) if(path[i] == '\\\\') break;
  \#strcpy\#( path+i+1, file);
  ret = \#Fsfirst\#(path,0);      /* does file exist?              */

\#AES Opcode\# 90

See also \#File Select\#.
\end

screen( capsensitive("fsel_exinput") )
#include <aes.h>

int fsel_exinput( char *path, char *file, int *button, char *label );

  <path> is a buffer which contains the directory pathname (input and
         output), including wildcard characters for the filename.
         Should be at least 65 bytes.
  <file> is a buffer which contains the filename.extension (input and
         output).  Should be at least 13 bytes.
  <button> returns 0 when the CANCEL button is selected, and 1 when
           the OK button is selected.
  <label> is a NULL terminated string to be displayed at the top of
          the file selector dialog box.  Max 30 characters.


Function executes the standard file selector dialog box with an
application specified label (e.g., "Save as ...");

It returns a positive number normally, or 0 on an error.

Note: Implemented starting with \#AES Version\# 1.40

\#AES Opcode\# 91

See also \#File Select\#.
\end

screen( capsensitive("wind_create") )
#include <aes.h>

int wind_create( int kind, int x, int y, int w, int h );

  <kind> consists of bit flags for the \#Window Features\#.
  <x> is the x coordinate for the full size window.
  <y> is the y coordinate for the full size window.
  <w> is the width for the full size window in pixels.
  <h> is the height for the full size window in pixels.


Function returns a window handle (negative if none available).

The 'full size window' coordinates are used when the window is FULLED,
which normally means the entire desktop if filled.  One can obtain the
desktop coordinates using:

  \#wind_get\#(0,WF_WORKXYWH,&x,&y,&w,&h);

\#AES Opcode\# 100

See also \#Window\#.
\end

screen( capsensitive("wind_open") )
#include <aes.h>

int wind_open( int handle, int x, int y, int w, int h );

  <handle> is the window handle returned by \#wind_create\#().
  <x> is the initial x coordinate for the window.
  <y> is the initial y coordinate for the window.
  <w> is the initial width for the window in pixels.
  <h> is the initial height for the window in pixels.


Function makes a window (frame) visible and enables message events
directed to this handle from the window manager (see \#Messages\#).

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 101

See also \#Window\#.
\end

screen( capsensitive("wind_close") )
#include <aes.h>

int wind_close( int handle );

  <handle> is the window handle returned by \#wind_create\#().


Function closes an open window.  The handle remains allocated and can
be re-opened later.

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 102

See also \#Window\#.
\end

screen( capsensitive("wind_delete") )
#include <aes.h>

int wind_delete( int handle );

  <handle> is the window handle returned by \#wind_create\#().


Function deallocates a window handle for a closed window.
It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 103

See also \#Window\#.
\end

screen( capsensitive("wind_get") )
#include <aes.h>

int wind_get( int handle, int field, \link("%%GLOBAL%%")...\# );

  <handle> is the window handle returned by \#wind_create\#(), or 0.
  <field> determines what values to return (see \#Window Get Options\#).

     The remaining parameters vary according to <field>,
     but are always pointers used to return values.


Function returns information about the window.
It returns a positive number normally, or 0 on an error.

Note: The handle 0 is used for the desktop.

\#AES Opcode\# 104

See also \#Window\#.
\end

screen( capsensitive("wind_set") )
#include <aes.h>

int wind_set( int handle, int field, \link("%%GLOBAL%%")...\# );

  <handle> is the window handle returned by \#wind_create\#(), or 0.
  <field> determines what values to set (see \#Window Set Options\#).

     The remaining parameters vary according to <field>.


Function sets various window values, including the title text and the
settings for the scroll bars.  It can also force a window to the top
or change its coordinates.

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 105

See also \#Window\#.
\end

screen( capsensitive("wind_find") )
#include <aes.h>

int wind_find( int mx, int my );

  <mx> is the mouse x coordinate.
  <my> is the mouse y coordinate.


Function returns the window handle for the window directly under the
mouse, or 0 for none found.

\#AES Opcode\# 106

See also \#Window\# and \#graf_mkstate\#.
\end

screen( capsensitive("wind_update") )
#include <aes.h>

int wind_update( int begend );

  <begend> turns the update state on or off:
           BEG_UPDATE - begin update
           END_UPDATE - end update
           BEG_MCTRL  - begin mouse control
           END_MCTRL  - end mouse control


Function is primarily used to update the work area of a window.
When the update state is turned on, no \#WM_REDRAW\# message events will
be generated by writing on top of the window.

When the mouse control state is turned on, menus, windows and dialogs
will not respond to the mouse.  This is particularly important in
multitasking environments.

\#AES Opcode\# 107

See also \#Window\# and \#graf_mkstate\#.
\end

screen( capsensitive("wind_calc") )
#include <aes.h>

int wind_calc( int ctype, int kind,
               int in_x, int in_y, int in_w, int in_h,
               int *out_x, int *out_y, int *out_w, int *out_h );

  <ctype> determines whether to compute the window coordinates from
          the work area coordinates (0), or vice-verses (1).
  <kind> consists of bit flags for the \#Window Features\#.
  <in_x> ... <in_h> are the given screen coordinates.
  <out_x> ... <out_h> return the calculated coordinates.


Function is used primarily to compute the window size needed to
provide a given work area.  Once the window is opened, one can obtain
the work area using \#wind_get\#().

It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 108

See also \#Window\# and \#WF_WORKXYWH\#.
\end


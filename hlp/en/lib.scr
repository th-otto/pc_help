screen( capsensitive("WF_FIRSTXYWH"),
		capsensitive("WF_NEXTXYWH") )
WF_FIRSTXYWH & WF_NEXTXYWH                                     <aes.h>
----------------------------------------------------------------------
These are used to redraw the work area of a partially obscured window.

  int x,y,w,h;  /* screen coordinates of visible rectangle */

  \#wind_get\#(handle, WF_FIRSTXYWH, &x, &y, &w, &h);
  while(w > 0 && h > 0) {
    redraw(handle, x,y,w,h);
    \#wind_get\#(handle, WF_NEXTXYWH, &x, &y, &w, &h);
   }

where redraw() redraws the work area using x,y,w,h as the clipping
rectangle.

Note: When responding to a \#WM_REDRAW\# message event, one should use the
      intersection of the visible rectangle with the redraw rectangle
      (if any) as the clipping rectangle.

See also \#wind_update\#(), \#vs_clip\#() and \#objc_draw\#().
\end

screen( capsensitive("WF_NEWDESK") )
WF_NEWDESK                                                     <aes.h>
----------------------------------------------------------------------
The window manager (and \#form_dial\#) automatically restore the
desktop when needed.

The default desktop is a green rectangle below the menu bar.

Using this option one can use an \#Object Tree\# as the desktop.

  \#OBJECT\# *tree;   /* address of desktop \#Object Tree\# array    */
  int startob;    /* array index of first object to draw (0) */

  \#wind_set\#(handle, WF_NEWDESK, tree, startob);

Note: Reset tree address to 0L before terminating application.
\end

screen( capsensitive("WF_HSLSIZE") )
WF_HSLSIZE                                                     <aes.h>
----------------------------------------------------------------------
  int hsize;  /* size of horizontal slider */

  \#wind_get\#(handle, WF_HSLSIZE, &hsize);
  \#wind_set\#(handle, WF_HSLSIZE, hsize);

  -1 = default minimum size (square box)
   1 = almost invisible
1000 = fills scroll bar.
\end

screen( capsensitive("WF_VSLSIZE") )
WF_VSLSIZE                                                     <aes.h>
----------------------------------------------------------------------
  int vsize;  /* size of vertical slider */

  \#wind_get\#(handle, WF_VSLSIZE, &vsize);
  \#wind_set\#(handle, WF_VSLSIZE, vsize);

  -1 = default minimum size (square box)
   1 = almost invisible
1000 = fills scroll bar.
\end

screen( capsensitive("WF_SCREEN") )
WF_SCREEN                                                      <aes.h>
----------------------------------------------------------------------
  void *addr;  /* address of internal menu/alert screen buffer */
  long size;   /* size of buffer in bytes */

  \#wind_get\#(0, WF_SCREEN, &addr, (int*) &addr + 1,
                             &size, (int*) &addr + 1);

This buffer is used to save the screen image behind drop-down menus
and \#form_alert\#() dialog boxes.

Note: Implemented starting with Rainbow TOS (\#Sversion\# = 0x1500).
      (Earlier versions returned the size of buffer in longs.)
\end

screen( capsensitive("WF_COLOR") )
WF_COLOR                                                       <aes.h>
----------------------------------------------------------------------
  int element;  /* specifies which \#Window Element\# to set  */
  int tcolor;   /* \#Color Spec\# when window is top (active) */
  int bcolor;   /* \#Color Spec\# when window is not topped   */

  \#wind_get\#(handle, WF_COLOR, &element, &tcolor, &bcolor);
  \#wind_set\#(handle, WF_COLOR, element, tcolor, bcolor);

One can use -1 for <tcolor> or <bcolor> to leave the previous value
unchanged.

Note: wind_set() implemented starting with \#AES Version\# 3.0
      wind_get() implemented starting with \#AES Version\# 3.30
\end

screen( capsensitive("WF_DCOLOR") )
WF_DCOLOR                                                      <aes.h>
----------------------------------------------------------------------
  int element;  /* specifies which \#Window Element\# to get/set  */
  int tcolor;   /* \#Color Spec\# when window is top (active)     */
  int bcolor;   /* \#Color Spec\# when window is not topped       */

  \#wind_get\#(0, WF_DCOLOR, &element, &tcolor, &bcolor);
  \#wind_set\#(0, WF_DCOLOR, element, tcolor, bcolor);

One can use -1 for <tcolor> or <bcolor> to leave the previous value
unchanged.

Applications should not use this option for \#wind_set\#(), as it causes a
permanent change.  It was intended for the Extensible Control Panel.

Note: wind_set() implemented starting with \#AES Version\# 3.00
      wind_get() implemented starting with \#AES Version\# 3.30
\end


screen( capsensitive("BCONMAP"),
		capsensitive("MAPTAB") )
Mapable I/O Port Vector Table                                  <tos.h>
----------------------------------------------------------------------
typedef struct
 {
  int   (*Bconstat) ();
  long  (*Bconin) ();
  int   (*Bcostat) ();
  void  (*Bconout) ();
  long  (*Rsconf) ();
  IOREC *iorec;
 } MAPTAB;

typedef struct
 {

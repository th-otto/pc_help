screen( capsensitive("vswr_mode") )
#include <vdi.h>

int vswr_mode( int handle, int mode );

  <handle> is the \#VDI Handle\#.
  <mode> is the new graphics writing mode:
         MD_REPLACE - replace foreground and background
         MD_TRANS   - replace foreground only
         MD_XOR     - change foreground to reverse video of old image
         MD_ERASE   - replace background only


Function changes the graphics writing mode for all subsequent VDI
graphics output on this workstation.

It returns the writing mode selected.

\#VDI Opcode\# 32

See also \#VDI Attributes\#.
\end

screen( capsensitive("vs_color") )
#include <vdi.h>

void vs_color( int handle, int index, int *rgb_in );

  <handle> is the \#VDI Handle\#.
  <index> is the color index (palette).
  <rgb_in> is a three entry int array:
           [0] = red   (0-1000)
           [1] = green (0-1000)
           [2] = blue  (0-1000)


Function changes the color definition for one color index in the
palette for this device.

Not all devices can modify the palette colors (see \#VDI Extended\#).

Note: When the palette is implemented in hardware, this will affect
      all virtual workstations for this device.

\#VDI Opcode\# 14

See also \#VDI Attributes\#, \#vq_color\#(), \#Setcolor\#() and \#EsetColor\#().
\end

screen( capsensitive("vsl_type") )
#include <vdi.h>

int vsl_type( int handle, int style );

  <handle> is the \#VDI Handle\#.
  <style> is the new line style:
          SOLID     ________   (0xFFFF)
          LONGDASH  ___ ___    (0xFFF0)
          DOT       . . . .    (0xE0E0)
          DASHDOT   _ . _ .    (0xFE38)
          DASH      __  __     (0xFF00)
          DASH2DOT  _.. _..    (0xF198)
          USERLINE  use bit pattern from \#vsl_udsty\#().


Function changes the line style for all line drawing functions.
It returns the line style selected.

Some devices only support line styles when the line width is 1 (see
\#VDI Extended\#).  This is true of the ROM screen driver. 

\#VDI Opcode\# 15

See also \#VDI Attributes\#, \#v_pline\#(), \#v_arc\#(), \#v_ellarc\#() and \#v_rbox\#().
\end

screen( capsensitive("vsl_udsty") )
#include <vdi.h>

void vsl_udsty( int handle, int pattern );

  <handle> is the \#VDI Handle\#.
  <pattern> is a 16 bit mask which is repeated to construct the line.
            See \#vsl_type\#() for examples.


Function changes the pattern corresponding to the USERLINE line style
implemented by \#vsl_type\#().

\#VDI Opcode\# 113

See also \#VDI Attributes\#, \#v_pline\#(), \#v_arc\#(), \#v_ellarc\#() and \#v_rbox\#().
\end

screen( capsensitive("vsl_width") )
#include <vdi.h>

int vsl_width( int handle, int width );

  <handle> is the \#VDI Handle\#.
  <width> is the desired width of the line in pixels (when scalable).
          Only odd numbered widths are implemented.


Function changes line width for all line drawing functions.
It returns the width implemented (nearest smaller value).

Some devices may only implement a fixed set of line widths, in which
case <width> is used as an index to that set.  (Some devices may only
implement one line width.)  See \#VDI Description\# for number of widths.

Some device draw wide lines as solid, regardless of the line style
setting (see \#VDI Extended\#).  This is true of the ROM screen driver.

\#VDI Opcode\# 16

See also \#VDI Attributes\#, \#v_pline\#(), \#v_arc\#(), \#v_ellarc\#() and \#v_rbox\#().
\end


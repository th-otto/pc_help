screen( "*kmalloc" )
\#kerinfo\# - kernal memory allocation
-----------------------------------------------------------------------
cdecl void* (*kmalloc)( long size );

  <size> is the number of bytes requested.


Function returns a pointer to the block of memory, or NULL if not
enough RAM is available.
\end

screen( "*kfree" )
\#kerinfo\# - free kernal memory
-----------------------------------------------------------------------
cdecl void (*kfree)( void *ptr );

  <ptr> points to a previously allocated block of kernal memory.


Function frees memory allocated by \#*kmalloc\#().
\end

screen( "*umalloc" )
\#kerinfo\# - allocate user memory
-----------------------------------------------------------------------
cdecl void* (*umalloc)( long size );

  <size> is the number of bytes requested.


Function returns a pointer to the block of memory, or NULL if not
enough RAM is available.  RAM when be freed when process ends.
\end

screen( "*ufree" )
\#kerinfo\# - free user memory
-----------------------------------------------------------------------
cdecl void (*ufree)( void *ptr );

  <ptr> points to a previously allocated block of user memory.


Function frees memory allocated by \#*umalloc\#().
\end

screen( "*strnicmp" )
\#kerinfo\# - string compare (ignore case)
-----------------------------------------------------------------------
cdecl short (*strnicmp)( char *s1, char *s2, short n );

  <s1> is a NULL terminated string.
  <s2> is a NULL terminated string.
  <n> is the maximum number of bytes to compare.


Function compares the first <n> bytes of two strings, unless the NULL
terminator is reached first.  Both strings are treated as if they were
converted to upper case.

Note: Shorter strings have less value.

It returns:
   0 if <s1> == <s2>
  <0 if <s1> < <s2>
  >0 if <s1> > <s2> 
\end

screen( "*stricmp" )
\#kerinfo\# - string compare (ignore case)
-----------------------------------------------------------------------
cdecl short (*stricmp)( char *s1, char *s2 );

  <s1> is a NULL terminated string.
  <s2> is a NULL terminated string.


Function compares the two string, treating them as if they were 
converted to upper case.

Note: Shorter strings have less value.

It returns:
   0 if <s1> == <s2>
  <0 if <s1> < <s2>
  >0 if <s1> > <s2> 
\end

screen( "*strlwr" )
\#kerinfo\# - convert to lower case
-----------------------------------------------------------------------
cdecl char* (*strlwr)( char *str );

  <str> is a NULL terminated string (will be modified).


Function converts upper case letters in a string to lower case.
It returns a pointer to <str>.
\end

screen( "*strupr" )
\#kerinfo\# - convert to upper case
-----------------------------------------------------------------------
cdecl char* (*strupr)( char *str );

  <str> is a NULL terminated string (will be modified).


Function converts lower case letters in a string to upper case.
It returns a pointer to <str>.
\end

screen( "*sprintf" )
\#kerinfo\# - create formatted string
-----------------------------------------------------------------------
cdecl short (*sprintf)( char *buff, const char *fmt, \link("%%GLOBAL%%")...\# );

  <buff> is a buffer used to return the formatted string.
  <fmt> is a NULL terminated string containing format info.


Function creates a formatted string.
Floating point formats are NOT supported.

It returns the number of characters generated, or EOF if an error
occurs.

See also \#sprintf\#() and \link("%%GLOBAL%%")printf/scanf Formats\#.
\end

screen( "*millis_time" )
\#kerinfo\# - convert milliseconds to \#DOSTIME\#
-----------------------------------------------------------------------
cdecl void (*millis_time)( unsigned long ms, short *td );

  <ms> is the time in milliseconds.
  <td> is a 2 entry array used to return the time in \#DOSTIME\#:
       [0] - number of seconds, minutes, and hours
       [1] - number of days, months, and years


Function converts time from milliseconds into \#DOSTIME\# format.
\end

screen( "*unixtim" )
\#kerinfo\# - convert \#DOSTIME\# to UNIX time.
-----------------------------------------------------------------------
cdecl long (*unixtim)( unsigned short time, unsigned short date );

  <time> is the \#DOSTIME\# time of day.
  <date> is the \#DOSTIME\# date.


Function returns the UNIX time stamp (seconds since 1/1/1970).
\end

screen( "*dostim" )
\#kerinfo\# - convert UNIX time to \#DOSTIME\#.
-----------------------------------------------------------------------
cdecl long (*dostim)(long unix);

  <unix> is the UNIX time stamp (seconds since 1/1/1970).


Function returns \#DOSTIME\# time stamp.
\end

screen( "*nap" )
\#kerinfo\# - pause
-----------------------------------------------------------------------
cdecl void (*nap)( unsigned short n );

  <n> is the nap time in milliseconds.


Function waits for approximately <n> milliseconds.
\end

screen( "*sleep" )
\#kerinfo\# - wait for condition
-----------------------------------------------------------------------
cdecl void (*sleep)( short que, long cond);

  <que> is the system queu index.
  <cond> is a condition code.


Function waits for a condition to occur on a system queu.
\end

screen( "*wake" )
\#kerinfo\# - stop waiting for condition
-----------------------------------------------------------------------
cdecl void (*wake)( short que, long cond);

  <que> is the system queu index.
  <cond> is a condition code.


Function causes all processes waiting for the given condition to stop
waiting.
\end

screen( "*wakeselect" )
\#kerinfo\# - stop waiting for (\#*select\#)()
-----------------------------------------------------------------------
cdecl void (*wakeselect)( long param );

  <param> is the <proc> argument passed to \#*select\#().


Function causes a given process waiting on \#*select\#() to stop waiting.
\end

screen( "*denyshare" )
\#kerinfo\# - check share mode against list
-----------------------------------------------------------------------
cdecl short (*denyshare)(\#FILEPTR\# *list, \#FILEPTR\# *f);

  <list> is an array of open files.
  <f> is a new file being opened.


Function checks the share modes of file <f> against <list>.
It returns 1 if there is a conflict, or 0 for none.
\end

screen( "*denylock" )
\#kerinfo\# - check lock status against list
-----------------------------------------------------------------------
cdecl \#LOCK\#* (*denylock)(\#LOCK\# *list, \#LOCK\# *new);

  <list> is a linked list of file locks.
  <new> is a file attempting to change its lock status.


Function checks the lock status of file <f> against <list>.
It returns a pointer to the conflicting lock, or NULL if none.

Note: Implemented starting with \#MiNT Version\# 0.94
\end

screen( "*addtimeout" )
\#kerinfo\# - device timeout
-----------------------------------------------------------------------
cdecl long (*addtimeout)(int delta, void (*func)(void));

  <delta> is the time in milliseconds.
  <func> is the function to be called at that time.


Function request the system to call <func> after a given time
interval.

It returns a magic number to be used by (\#*canceltimeout\#)().

Note: Implemented starting with \#MiNT Version\# 1.06
\end

screen( "*canceltimeout" )
\#kerinfo\# - cancel device timeout
-----------------------------------------------------------------------
cdecl void (*canceltimeout)(long magic);

  <magic> is the value previously returned by (\#*addtimeout\#)().


Function aborts a device timeout.

Note: Implemented starting with \#MiNT Version\# 1.06
\end

screen( "fs_desc" )
MiNT File System Description
----------------------------------------------------------------------
struct fs_desc {
  \#FILESYS\#   *file_system;   /* file system definition        */
  short     dev;            /* \#MiNT Device Number\#            */
  long      flags;          /* defined by file system driver */
  long      reserved[4];    /* reserved for kernal           */
 };

The 'dev' entry is filled by the \#kernel\# at mount time.

See \#FS_INSTALL\#, \#FS_MOUNT\#, \#FS_UNMOUNT\# and \#FS_UNINSTALL\#.
\end

screen( "FILESYS" )
MiNT File System Definition (created by driver)
----------------------------------------------------------------------
typedef unsigned short ushort;

typedef struct filesys {
  struct filesys *next;    /* set to NULL - filled by \#kernel\#        */
  long fsflags;  /* bit flags: 1 = no parsing, 2 = case sensitive,  */
                 /* 4 = no executable bit, 8 = size args used       */

  cdecl long (\#*root\#) (short, \#fcookie\#*);
  cdecl long (\#*lookup\#) (\#fcookie\#*, char*, \#fcookie\#*);
  cdecl long (\#*creat\#) (\#fcookie\#*, char*, ushort, short, \#fcookie\#*);
  cdecl \#DEVDRV\# *(\#*getdev\#) (\#fcookie\#*, long*);
  cdecl long (\#*getxattr\#) (\#fcookie\#*, \#XATTR\#*);
  cdecl long (\#*chattr\#) (\#fcookie\#*, short);
  cdecl long (\#*chown\#) (\#fcookie\#*, short, short);
  cdecl long (\#*chmode\#) (\#fcookie\#*, ushort);
  cdecl long (\#*mkdir\#) (\#fcookie\#*, char*, ushort);
  cdecl long (\#*rmdir\#) (\#fcookie\#*, char*);
  cdecl long (\#*remove\#) (\#fcookie\#*, char*);
  cdecl long (\#*getname\#) (\#fcookie\#*, \#fcookie\#*, char*, short);
  cdecl long (\#*rename\#) (\#fcookie\#*, char*, \#fcookie\#*, char*);
  cdecl long (\#*opendir\#) (\#DIR\#*, short);
  cdecl long (\#*readdir\#) (\#DIR\#*, char*, short, \#fcookie\#*);
  cdecl long (\#*rewinddir\#) (\#DIR\#*);
  cdecl long (\#*closedir\#) (\#DIR\#*);
  cdecl long (\#*pathconf\#) (\#fcookie\#*, short);
  cdecl long (\#*dfree\#) (\#fcookie\#*, \#DISKINFO\#*);
  cdecl long (\#*writelabel\#) (\#fcookie\#*, char*);
  cdecl long (\#*readlabel\#) (\#fcookie\#*, char*, short);
  cdecl long (\#*symlink\#) (\#fcookie\#*, char*, char*);
  cdecl long (\#*readlink\#) (\#fcookie\#*, char*, short);
  cdecl long (\#*hardlink\#) (\#fcookie\#*, char*, \#fcookie\#*, char*);
  cdecl long (\#*fscntl\#) (\#fcookie\#*, char*, short, long);
  cdecl long (\#*dskchng\#) (short);
  cdecl long (\#*release\#) (\#fcookie\#*);
  cdecl long (\#*dupcookie\#) (\#fcookie\#*, \#fcookie\#*);
 } FILESYS;

All driver functions should preserve registers D2-D7 and A2-A7.

See also \#Dcntl\#() and \#fs_desc\#.
\end

screen( "*root" )
\#FILESYS\# - locate root directory
-----------------------------------------------------------------------
cdecl long (*root)( short drv, \#fcookie\# *fc );

  <drv> is the \#MiNT Device Number\#.
  <fc> is used to return the root directory.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -46 = invalid drive.
\end

screen( "*lookup" )
\#FILESYS\# - translate filename into \#fcookie\#
-----------------------------------------------------------------------
cdecl long (*lookup)( \#fcookie\# *dir, char *name, \#fcookie\# *fc );

  <dir> is the current directory.
  <name> is the file or subdirectory name.
  <fc> is used to return the file cookie.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -33 = file not found.
 -200 = used ".." from root directory.

Note: Function should not attempt to follow symbolic links.
\end

screen( "*creat" )
\#FILESYS\# - create new file
-----------------------------------------------------------------------
cdecl long (*creat)( \#fcookie\# *dir, char *name, unsigned short mode,
                     short attrib, \#fcookie\# *fc );

  <dir> is the current directory.
  <name> is the file name.
  <mode> contains file type and access bit flags:
               1 = execute access for all
               2 = write access for all
               4 = read access for all
             010 = execute access for group
             020 = write access for group
             040 = read access for group
            0100 = execute access for user
            0200 = write access for user
            0400 = read access for user
           02000 = change effective group ID during execution
           04000 = change effective user ID during execution
          020000 = BIOS special file
         0100000 = regular file
         0120000 = FIFO
         0140000 = memory image or process
         0160000 = symbolic link

  <attrib> contains the TOS attributes bit flags (see \#Fattrib\#).
  <fc> is used to return the file cookie.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.

See also \#Fcreate\#().
\end

screen( "*getdev" )
\#FILESYS\# - get device driver to access file
-----------------------------------------------------------------------
cdecl \#DEVDRV\# *(*getdev)( \#fcookie\# *fc, long *devspecial );

  <fc> is the file to be accessed.
  <devspecial> is used to return the \#BIOS/GEMDOS Error Code\#, or
               can be used to pass driver dependent info.


Function should return the device driver definition normally, or NULL
on an error.
\end

screen( "*getxattr" )
\#FILESYS\# - get extended file attributes
-----------------------------------------------------------------------
cdecl long (*getxattr)( \#fcookie\# *fc, \#XATTR\# *xattr );

  <fc> is the file to be accessed.
  <xattr> is used to return the extended file attributes.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.

See \#Fxattr\#().
\end

screen( "*chattr" )
\#FILESYS\# - change TOS file attributes
-----------------------------------------------------------------------
cdecl long (*chattr)( \#fcookie\# *fc, short attr );

  <fc> is the file to be modified.
  <attr> contains the new TOS file attribures (see \#Fattrib\#).


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.
\end

screen( "*chown" )
\#FILESYS\# - change file ownership
-----------------------------------------------------------------------
cdecl long (*chown)( \#fcookie\# *fc, short uid, short gid );

  <fc> is the file to be modified.
  <uid> is the new user ID
  <gid> is the new group ID.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -32 = ownership not supported
\end

screen( "*chmode" )
\#FILESYS\# - change mode bit flags
-----------------------------------------------------------------------
cdecl long (*chmode)( \#fcookie\# *fc, unsigned short mode );

  <fc> is the file to be modified.
  <mode> contains the new access bit flags:
               1 = execute access for all
               2 = write access for all
               4 = read access for all
             010 = execute access for group
             020 = write access for group
             040 = read access for group
            0100 = execute access for user
            0200 = write access for user
            0400 = read access for user
           02000 = change effective group ID during execution
           04000 = change effective user ID during execution


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.

Note: This function should always add entries "." and "..".
\end

screen( "*mkdir" )
\#FILESYS\# - create new sub-directory
-----------------------------------------------------------------------
cdecl long (*mkdir)( \#fcookie\# *dir, char *name, unsigned short mode);

  <dir> is the current directory.
  <name> is the sub-directory name.
  <mode> contains file access bit flags:
               1 = execute access for all
               2 = write access for all
               4 = read access for all
             010 = execute access for group
             020 = write access for group
             040 = read access for group
            0100 = execute access for user
            0200 = write access for user
            0400 = read access for user
           02000 = change effective group ID during execution
           04000 = change effective user ID during execution
          040000 = sub-directory (set by \#kernel\#)


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.

Note: Directory entries "." and ".." are created at this time.

See also \#Dcreate\#().
\end

screen( "*rmdir" )
\#FILESYS\# - delete sub-directory
-----------------------------------------------------------------------
cdecl long (*rmdir)( \#fcookie\# *dir, char *name );

  <dir> is the parent directory (containing <name>).
  <name> is the sub-directory name.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.

Note: Function should also work on symbolic links.

See also \#Ddelete\#().
\end

screen( "*remove" )
\#FILESYS\# - delete file
-----------------------------------------------------------------------
cdecl long (*remove)( \#fcookie\# *dir, char *name );

  <dir> is the parent directory (containing <name>).
  <name> is the file name.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.

See also \#Fdelete\#().
\end

screen( "*getname" )
\#FILESYS\# - generate relative pathname for directory
-----------------------------------------------------------------------
cdecl long (*getname)( \#fcookie\# *relto, \#fcookie\# *dir, char *pathname,
                          short size );

  <relto> is the starting directory.
  <dir> is the ending directory.
  <pathname> is used to return the relative pathname (NULL terminated).
  <size> is the number of bytes in the <pathname> buffer.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -64 = <pathname> longer than <size> bytes.

Note: Return "" instead of "." when <dir> = <relto>.
      <size> was added in \#MiNT Version\# 0.97

See also \#Pathnames\#
\end

screen( "*rename" )
\#FILESYS\# - rename or move file
-----------------------------------------------------------------------
cdecl long (*rename)( \#fcookie\# *olddir, char *oldname,
                      \#fcookie\# *newdir, char *newname );

  <olddir> is the current directory (containing <oldname>).
  <oldname> is the current file name.
  <newdir> is the new directory (to contain <newname>).
  <newname> is new file name.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -32 = rename or move not supported
\end

screen( "*opendir" )
\#FILESYS\# - open directory for search
-----------------------------------------------------------------------
cdecl long (*opendir)( \#DIR\# *dirh, short tosflag );

  <dirh> contains directory search parameters.
         index and fsstuff fields should be initialized by this call.
  <tosflag> indicates calling function: 1 = \#Fsfirst\#(), 0 = \#Dopendir\#().


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.
\end

screen( "*readdir" )
\#FILESYS\# - read next file name in directory search
-----------------------------------------------------------------------
cdecl long (*readdir)( \#DIR\# *dirh, char *name, short namelen,
                       \#fcookie\# *fc );

  <dirh> contains directory search parameters.
  <name> is used to return the next file name (NULL terminated).
         A unique ID should be in the first four bytes when flags = 0.
  <namelen> is the size of the <name> buffer.
  <fc> is used to return the file cookie.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -49 = no more files.
  -64 = file name larger than <namelen> bytes.

See also \#Fsnext\#() and \#Dreaddir\#().
\end

screen( "*rewinddir" )
\#FILESYS\# - re-start directory search at beginning
-----------------------------------------------------------------------
cdecl long (*rewinddir)( \#DIR\# *dirh );

  <dirh> contains directory search parameters.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.
\end

screen( "*closedir" )
\#FILESYS\# - close directory
-----------------------------------------------------------------------
cdecl long (*closedir)( \#DIR\# *dirh );

  <dirh> contains directory search parameters.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.
\end

screen( "*pathconf" )
\#FILESYS\# - get path configuration information
-----------------------------------------------------------------------
cdecl long (*pathconf)( \#fcookie\# *dir, short which );

  <dir> is any directory in the file system.
  <which> selects the type of information to be returned:
          0 = internal limit on the number of open files.
          1 = max. number of links to a file.
          2 = max. length of a full path name.
          3 = max. length of an individual file name.
          4 = number of bytes that can be written atomically
          5 = information about file name truncation.
          6 = information about case sensitivity.


Function should return a positive number normally:
  0x7ffffffffL = no limit

For <n> == 5 (file name truncation), it returns:
  0 = file names are never truncated.
  1 = file names are automatically truncated to max. length.
  2 = file names are automatically converted to MS-DOS file names
      (eight characters with 3 character extension).

For <n> == 6 (case sensitivity), it returns:
  0 = file names are case sensitive.
  1 = file names are converted to upper case.
  2 = file names are case insensitive, but are saved in the directory
      preserving their original case.

See also \#Dpathconf\#().
\end

screen( "*dfree" )
\#FILESYS\# - get used and free space on disk
-----------------------------------------------------------------------
cdecl long (*dfree)( \#fcookie\# *dir, \#DISKINFO\# *buf );

  <dir> is any directory on the disk.
  <buf> is used to return the disk space information.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.

See also \#Dfree\#().
\end

screen( "*writelabel" )
\#FILESYS\# - write volume label
-----------------------------------------------------------------------
cdecl long (*writelabel)( \#fcookie\# *dir, char *name );

  <dir> is any directory on the disk.
  <name> is the new volume name.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -36 = access denied.
\end

screen( "*readlabel" )
\#FILESYS\# - read volume label
-----------------------------------------------------------------------
cdecl long (*readlabel)( \#fcookie\# *dir, char *name, short namelen );

  <dir> is any directory on the disk.
  <name> is used to return the volume name (NULL terminated).
  <namelen> is the size of the <name> buffer in bytes.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -32 = no volume label.
  -64 = name longer than <namelen> bytes.
\end

screen( "*symlink" )
\#FILESYS\# - create symbolic link
-----------------------------------------------------------------------
cdecl long (*symlink)( \#fcookie\# *dir, char *name, char *to );

  <dir> is the current directory.
  <name> is the name of the symbolic link to create.
  <to> is the pathname to be linked.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -32 = symbolic links not supported.

See also \#Fsymlink\#() and \#Pathnames\#.
\end

screen( "*readlink" )
\#FILESYS\# - read symbolic link
-----------------------------------------------------------------------
cdecl long (*readlink)( \#fcookie\# *fc, char *buf, short buflen );

  <fc> is the link.
  <buf> is used to return the link pathname.
  <buflen> is the size of <buf> in bytes.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -32 = sybolic links not supported.
  -64 = pathname longer than <buflen> bytes.

See also \#Freadlink\#().
\end

screen( "*hardlink" )
\#FILESYS\# - create hard link
-----------------------------------------------------------------------
cdecl long (*hardlink)( \#fcookie\# *fromdir, char *fromname,
                            \#fcookie\# *todir, char *toname );

  <fromdir> is the directory containing <fromname>.
  <fromname> is an existing file name (or hard link).
  <todir> is the directory to contain <toname>.
  <tonane> is the file name of the hard link to be create.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -32 = hard links not supported.
\end

screen( "*fscntl" )
\#FILESYS\# - extended \#Dcntl\#() command set.
-----------------------------------------------------------------------
cdecl long (*fscntl)( \#fcookie\# *dir, char *name, short cmd, long arg );

  <dir> is the directory containing <name>.
  <name> is a file name.
  <cmd> is a driver specified command code.
  <arg> depends on <cmd>

This function is called by \#Dcntl\#().  It should return -32 (command
not implemented) normally.
\end

screen( "*dskchng" )
\#FILESYS\# - check for (definite) media change.
-----------------------------------------------------------------------
cdecl long (*dskchng)( short drv );

  <drv> is the \#MiNT Device Number\#.


Function should return 0 if no change has occured, or 1 otherwise.
This function is responsible for all re-initializations etc. required
for such a change.
\end

screen( "*release" )
\#FILESYS\# - file cookie no longer active.
-----------------------------------------------------------------------
cdecl long (*release)( \#fcookie\# *fc );


Function should return 0.

Used to inform driver that a previously defined file cookie no longer
contains valid info.
\end

screen( "*dupcookie" )
\#FILESYS\# - copy file cookie.
-----------------------------------------------------------------------
cdecl long (*dupcookie)( \#fcookie\# *dest, \#fcookie\# *src );


Function should return 0.
(Used in case driver keeps track of how many cookies are active.)

See also \#*release\#.
\end

screen( "DIR" )
MiNT Directory Search Parameters
-----------------------------------------------------------------------
typedef struct dirstruct {
  \#fcookie\# fc;             /* cookie for this directory     */
  unsigned short index;   /* index of the current entry    */
  unsigned short flags;   /* 1 = \#Fsfirst\#(), 0 = \#Dopendir\#() */
  char fsstuff[60];       /* driver dependent info         */
} DIR;

See also \#*opendir\#, \#*readdir\#, \#*rewinddir\# and \#*closedir\#.
\end

screen( "fcookie" )
MiNT File System Cookie
-----------------------------------------------------------------------
typedef struct f_cookie {
  \#FILESYS\# *fs;          /* file system definition (jump vectors)    */
  unsigned short dev;   /* drive number (used by \#Rwabs\#)             */
  unsigned short aux;   /* reserved for file system driver          */
  long index;           /* unique ID number for file                */
} fcookie;
\end

screen( "FILEPTR" )
MiNT Open File Information
-----------------------------------------------------------------------
typedef struct fileptr {
  short links;               /* number of entries in linked list    */
  unsigned short flags;      /* bit fields (see below)              */
  long pos;                  /* seek position in file               */
  long devinfo;              /* reserved for device driver          */
  \#fcookie\# fc;                /* file system cookie                  */
  \#DEVDRV\# *dev;               /* device driver                       */
  struct fileptr *next;      /* link to next fileptr for this file  */
 } FILEPTR;

Bit field definitions:
  bits 0-2 (open mode):
    0 = read only
    1 = write only
    2 = read and write
    3 = execute
  bit 3 (append mode):
    8 = all writes go to end of file
  bits 4-6 (share mode):
    0x00 = TOS compatibility mode
    0x10 = deny both read and write access to others
    0x20 = deny write access to others
    0x30 = deny read access to others
    0x40 = no restrictions
  bits 7-31 (misc):
      0x80 = child processes don't inherit access
     0x100 = no delay (I/O blocking)
     0x200 = create file if it doesn't exist
     0x400 = truncate (delete) file if it does exist
     0x800 = do not open if old file exits
    0x2000 = file is a terminal
    0x4000 = file is a pseudo-terminal master
    0x8000 = file has been locked
\end

screen( "dev_desc" )
MiNT Device Driver Description
----------------------------------------------------------------------
struct dev_desc {
  \#DEVDRV\#    *driver;        /* device driver definition */
  short     dinfo;          /* same as 'aux' in \#fcookie\# */
  long      flags;          /* 0 normally, 0x2000 = TTY */
  long      reserved[4];
 };

See \#DEV_INSTALL\#.
\end

screen( "DEVDRV" )
MiNT Device Driver Definition (created by driver)
----------------------------------------------------------------------
typedef struct devdrv {
  cdecl long (\#*open\#) (\#FILEPTR\#*);
  cdecl long (\#*write\#) (\#FILEPTR\#*, char*, long);
  cdecl long (\#*read\#) (\#FILEPTR\#*, char*, long);
  cdecl long (\#*lseek\#) (\#FILEPTR\#*, long, short);
  cdecl long (\#*ioctl\#) (\#FILEPTR\#*, short, void*);
  cdecl long (\#*datime\#) (\#FILEPTR\#*, short*, short);
  cdecl long (\#*close\#) (\#FILEPTR\#*, short);
  cdecl long (\#*select\#) (\#FILEPTR\#*, long, short);
  cdecl void (\#*unselect\#) (\#FILEPTR\#*, long, short);

  long reserved[3];                             /* must be set to 0 */
} DEVDRV;

All driver functions should preserve registers D2-D7 and A2-A7.

See also \#Dcntl\#() and \#dev_desc\#.
\end

screen( "*open" )
\#DEVDRV\# - open file
-----------------------------------------------------------------------
cdecl long (*open)( \#FILEPTR\# *f );

  <f> contains the file status.
      Driver should check and/or reset values from \#kernel\#.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -36 = access denied
\end

screen( "*write" )
\#DEVDRV\# - write data
-----------------------------------------------------------------------
cdecl long (*write)( \#FILEPTR\# *f, char *buf, long bytes );

  <f> contains the file status.
  <buf> points to the data to be written.
  <bytes> is the number of bytes to write.


Function should return the number of bytes written, or a
\#BIOS/GEMDOS Error Code\#.

Note: The \#kernel\# will automatically call \#*lseek\# in append mode.
\end

screen( "*read" )
\#DEVDRV\# - read data
-----------------------------------------------------------------------
cdecl long (*read)( \#FILEPTR\# *f, char *buf, long bytes );

  <f> contains the file status.
  <buf> is a buffer used to store the data,
  <bytes> is the number of bytes to read.


Function should return the number of bytes read, or a
\#BIOS/GEMDOS Error Code\#.
\end

screen( "*lseek" )
\#DEVDRV\# - move to given loction in file
-----------------------------------------------------------------------
cdecl long (*lseek)( \#FILEPTR\# *f, long where, short whence );

  <f> contains the file status.
  <where> is the new starting location (in bytes).
  <whence> controls how the new location is determined using <where>:
           0 = from the beginning of the file.
           1 = relative to the current location.
           2 = from the end of the file.


Function should return the new absolute location, or a
\#BIOS/GEMDOS Error Code\#.
\end

screen( "*ioctl" )
\#DEVDRV\# - process \#Fcntl\#() commands
-----------------------------------------------------------------------
cdecl long (*ioctl)( \#FILEPTR\# *f, short mode, void *buf );

  <f> contains the file status.
  <mode> is the \#Fcntl Command Code\#.
  <buf> corresponds to the long <arg> parameter in \#Fcntl\#().

The return value and <buf> depend on <mode>.

All drivers should support \#FIONREAD\#, \#FIONWRITE\# and the file locking
commands.
\end

screen( "*datime" )
\#DEVDRV\# - modify file time/date stamp
-----------------------------------------------------------------------
cdecl long (*datime)( \#FILEPTR\# *f, short *timeptr, short rwflag );

  <f> contains the file status.
  <timeptr> is an array used to pass the file's \#DOSTIME\# stamp:
            [0] = time
            [1] = date
  <rwflag> is 0 to return the old value, or non-zero to change the
           file's creation time stamp.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.
\end

screen( "*close" )
\#DEVDRV\# - close file
-----------------------------------------------------------------------
cdecl long (*close)( \#FILEPTR\# *f, short pid );

  <f> contains the file status.
  <pid> is the process ID of the calling process.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.
\end

screen( "*select" )
\#DEVDRV\# - wait for I/O ready
-----------------------------------------------------------------------
cdecl long (*select)( \#FILEPTR\# *f, long proc, short mode );

  <f> contains the file status.
  <proc> is the value to be used for <param> of the \#*wakeselect\#
         function passed in the \#kerinfo\# structure.
  <mode> is 0 to wait for read, 1 to wait for write.


Function should return 1 is the device is ready, or 0 if not ready and
call \#*wakeselect\# when it becomes ready.
\end

screen( "*unselect" )
\#DEVDRV\# - stop waiting for I/O ready
-----------------------------------------------------------------------
cdecl void (*unselect)( \#FILEPTR\# *f, long proc, short mode );

  <f> contains the file status.
  <proc> is the value to be used for <param> of the \#*wakeselect\#
         function passed in the \#kerinfo\# structure.
  <mode> is 0 to stop waiting for read, 1 to stop waiting for write.


Function should return 0 normally, or a \#BIOS/GEMDOS Error Code\#.
\end


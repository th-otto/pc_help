screen( "FS_INSTALL" )
Install File System
----------------------------------------------------------------------
(struct \#kerinfo\#*) \#Dcntl\#( FS_INSTALL, "U:\\\\", (long) &desc );

  <desc> is the \#fs_desc\# structure (passed by address).


Function returns a pointer to a \#kerinfo\# structure if successful
(NULL otherwise).

Note: Implemented starting with \#MiNT Version\# 1.08
\end

screen( "FS_MOUNT" )
Mount Installed File System
----------------------------------------------------------------------
\#Dcntl\#( FS_MOUNT, path, (long) &desc );

  <path> is a NULL terminated string for the file system pathname.
         Must be 'U:\\name' where 'name' is the drive name.

  <desc> is the \#fs_desc\# structure (passed by address).


Function returns 0 normally.

Note: Implemented starting with \#MiNT Version\# 1.08
\end

screen( "FS_UNMOUNT" )
Remove Mounted File System
----------------------------------------------------------------------
\#Dcntl\#( FS_UNMOUNT, path, (long) &desc );

  <path> is a NULL terminated string for the file system pathname.
         Must be 'U:\\name' where 'name' is the drive name.

  <desc> is the \#fs_desc\# structure (passed by address).


Function returns 0 normally.

Note: Implemented starting with \#MiNT Version\# 1.08
\end

screen( "FS_UNINSTALL" )
Removes Installed File System
----------------------------------------------------------------------
\#Dcntl\#( FS_UNINSTALL, "U:\\\\", (long) &desc );

  <desc> is the \#fs_desc\# structure (passed by address).


Function returns 0 normally.

Note: Implemented starting with \#MiNT Version\# 1.08
\end

screen( "DEV_INSTALL" )
Install Device Driver
----------------------------------------------------------------------
(struct \#kerinfo\#*) \#Dcntl\#( DEV_INSTALL, path, (long) &desc );

  <path> is a NULL terminated string for the device pathname.
         Must be 'U:\\DEV\\name' where 'name' is the device name.

  <desc> is the \#dev_desc\# structure (passed by address).


Function returns a pointer to a \#kerinfo\# structure if successful
(NULL otherwise).
\end

screen( "DEV_NEWTTY" )
Install BIOS Terminal Device
----------------------------------------------------------------------
\#Dcntl\#( DEV_NEWTTY, path, dev );

  <path> is a NULL terminated string for the device pathname.
         Must be 'U:\\DEV\\name' where 'name' is the device name.

  <dev> is the \#MiNT Device Number\#.


Function returns positive normally, or -15 for bad <dev> number.

Note: Driver must have already been installed in the \#BCONMAP\# list.
\end

screen( "DEV_NEWBIOS" )
Install BIOS Raw Device
----------------------------------------------------------------------
\#Dcntl\#( DEV_NEWBIOS, path, dev );

  <path> is a NULL terminated string for the device pathname.
         Must be 'U:\\DEV\\name' where 'name' is the device name.

  <dev> is the \#MiNT Device Number\#.


Function returns 0 normally, or -15 for bad <dev> number.

Note: Driver must have already been installed in the \#BCONMAP\# list.
      Implemented starting with \#MiNT Version\# 1.08
\end

screen( "kerinfo" )
MiNT device driver kernal information - READ ONLY
----------------------------------------------------------------------
typedef long (*Func)( void, ... );
typedef unsigned short ushort;
typedef unsigned long ulong;

struct kerinfo {
  short maj_version;    /* \#kernel\# version number                    */
  short min_version;    /* minor \#kernel\# version number              */
  ushort default_mode;  /* default file access permissions          */
  short reserved1;      /* room for expansion                       */

  Func *bios_tab;       /* pointer to the BIOS jump vectors         */
  Func *dos_tab;        /* pointer to the GEMDOS jump vectors       */

  cdecl void (\#*drvchng\#) (ushort);
  cdecl void (\#*trace\#) (char *, ...);
  cdecl void (\#*debug\#) (char *, ...);
  cdecl void (\#*alert\#) (char *, ...);
  cdecl void (\#*fatal\#) (char *, ...);
  cdecl void* (\#*kmalloc\#) (long);
  cdecl void (\#*kfree\#) (void*);
  cdecl void* (\#*umalloc\#) (long);
  cdecl void (\#*ufree\#) (void*);
  cdecl short (\#*strnicmp\#) (char*, char*, short);
  cdecl short (\#*stricmp\#) (char*, char*);
  cdecl char* (\#*strlwr\#) (char*);
  cdecl char* (\#*strupr\#) (char*);
  cdecl short (\#*sprintf\#) (char*, const char*, ...);
  cdecl void (\#*millis_time\#) (ulong, short*);
  cdecl long (\#*unixtim\#) (ushort, ushort);
  cdecl long (\#*dostim\#) (long);
  cdecl void (\#*nap\#) (ushort);
  cdecl void (\#*sleep\#) (short, long);
  cdecl void (\#*wake\#) (short, long);
  cdecl void (\#*wakeselect\#) (long);
  cdecl short (\#*denyshare\#) (\#FILEPTR\#*, \#FILEPTR\#*);
  cdecl \#LOCK\#* (\#*denylock\#) (\#LOCK\#*, \#LOCK\#*);
  cdecl long (\#*addtimeout\#) (short, void (*func)(void));
  cdecl void (\#*canceltimeout\#) (long);

  long res2[7];         /* reserved for future use                  */
 };

Note: The reason for providing many of these functions is to avoid
      duplication for each device driver.

See also \link("%%GLOBAL%%")cdecl\#.
\end

screen( "LOCK" )
File Lock Linked List                                         \#kerinfo\#
----------------------------------------------------------------------
typedef struct ilock {
  \#FLOCK\#         lock;
  struct ilock  *next;
  long          reserved[4];
 } LOCK;
\end


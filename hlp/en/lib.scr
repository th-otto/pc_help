See also \#String & Character\#.
\end

screen( capsensitive("strncat") )
#include <string.h>

char* strncat( char *dest, const char *source, \#size_t\# n );

  <dest> is a buffer containing a NULL terminated string.
  <source> is a NULL terminated string.
  <n> is the maximum number of characters to append (not counting the
      NULL terminator).


Function concatenates (appends) at most <n> bytes from <source> to the
end of <dest> (plus a NULL terminator, if needed).
Buffer <dest> must have space for \#strlen\#(dest)+n+1 bytes.

It returns a pointer to <dest>.

See also \#String & Character\#.
\end

screen( capsensitive("strncmp") )
#include <string.h>

int strncmp( const unsigned char *s1, const unsigned char *s2,
             \#size_t\# n )

  <s1> is a NULL terminated string.
  <s2> is a NULL terminated string.
  <n> is the maximum number of bytes to compare.


Function compares the first <n> bytes of strings <s1> and <s2>,
unless a NULL terminator is reached first.

Note: Shorter strings have less value.

It returns:
   0 if <s1> == <s2>
  <0 if <s1> < <s2>
  >0 if <s1> > <s2> 

See also \#String & Character\#.
\end

screen( capsensitive("strncpy") )
#include <string.h>

char* strncpy( char *dest, const char *source, \#size_t\# n );

  <dest> is a buffer to be filled.
  <source> is a NULL terminated string.
  <n> is the minimum number of characters to copy.


Function copies <source> into <dest>.  If the length of <source> is
less than <n>, <dest> will be padded with blanks.

It returns a pointer to <dest>.

See also \#String & Character\#.
\end

screen( capsensitive("strpbrk") )
#include <string.h>

char* strpbrk( const char *s, const char *list );

  <s> is a NULL terminated string.
  <list> is a NULL terminated string (the order of the characters is
    unimportant).


Function returns a pointer to the first location in <s> which contains
any character found in the span of <list>.

See also \#String & Character\#.
\end

screen( capsensitive("strrchr") )
#include <string.h>

char* strrchr( const char *s, int c );

  <s> is a NULL terminated string.
  <c> is a character (0-255) passed as an int.


Function returns a pointer to the last location in <s> which contains
character <c>, or NULL if no match found.

See also \#String & Character\#.
\end

screen( capsensitive("strspn") )
#include <string.h>

\#size_t\# strspn( const char *s, const char *list );

  <s> is a NULL terminated string.
  <list> is a NULL terminated string (the order of the characters is
    unimportant).


Function returns the number of characters at the beginning of <s> all
found in the span of <list>.

See also \#String & Character\#.
\end

screen( capsensitive("strstr") )
#include <string.h>

char* strstr( const char *s, const char *sub );

  <s> is a NULL terminated string.
  <sub> is a NULL terminated string.


Function returns the first location in <s> which matches the entire
string <sub>, or NULL if no match found.

See also \#String & Character\#.
\end

screen( capsensitive("strtok") )
#include <string.h>

char* strtok( char *s, const char *sub );

  <s> is a NULL terminated string, or NULL (for next token).
  <sub> is a NULL terminated string (token delimiter).


Function replaces the first occurrence of <sub> in <s> with a NULL
terminator.  It returns a pointer to the first token (i.e.; <s>),
or NULL if strlen(s) == 0 (after replacement).

After strtok() has been called once, one can use a NULL pointer for
<s> to continue searching after the delimiter found by the last call.
In this case, it returns a pointer to the start of this new token
(or NULL):

  p = strtok(s,sub);             /* get first token      */
  while(p) p = strtok(0L,sub);   /* get remaining tokens */

See also \#String & Character\#.
\end

screen( capsensitive("strtod") )

screen( capsensitive("setgraphmode") )
#include <graphics.h>

void setgraphmode( int mode );

  <mode> is the new graphics mode (e.g. VDIMODE).


Function changes the graphics mode and erases the screen.
It can be used to restore graphics after \#restorecrtmode\#().

VDI: \#v_exit_cur\#()

See also \#BGI Control\#.
\end

screen( capsensitive("setlinestyle") )
#include <graphics.h>

void setlinestyle( int linestyle, unsigned upattern, int thickness );

  <linestyle> is the line style index:
              SOLID_LINE
              DOTTED_LINE
              CENTER_LINE  - dot dash
              DASHED_LINE
              USERBIT_LINE - use <upattern>
  <upattern> is a 16x1 bitmap used by the USERBIT_LINE style.
             For all other line styles it is not used.
  <thickness> is the line width (NORM_WIDTH or THICK_WIDTH).


Function selects the type of line to be drawn.

VDI: \#vsl_type\#(), \#vsl_udsty\#() and \#vsl_width\#().

See also \#BGI Attributes\# and \#graphresult\#().
\end

screen( capsensitive("setpalette") )
#include <graphics.h>

void setpalette( int index, int color );

  <index> is a BGI color index (0 - 15).
  <color> is a hardware color index (0 - 63).


Function changes the definition for one color in the BGI palette.

See also \#BGI Color\# & \#graphresult\#().
\end

screen( capsensitive("setrgbpalette") )
#include <graphics.h>

void setrgbpalette( int colornum, int red, int green, int blue );

  <colornum> is a BGI color index (0 - 15).
  <red> is the red intensity.
  <green> is the green intensity.
  <blue> is the blue intensity.


Function changes the definition for one color in the BGI palette.
It is NOT implemented on the Atari.

See also \#BGI Color\# & \#graphresult\#().
\end

screen( capsensitive("settextjustify") )
#include <graphics.h>

void settextjustify( int horiz, int vert );

  <horiz> is the horizontal justification:
          LEFT_TEXT    - text right of cursor
          CENTER_TEXT  - text centered on cursor
          RIGHT_TEXT   - text left of cursor

  <vert> is the vertical justification:
         BOTTOM_TEXT - text above cursor
         TOP_TEXT    - text below cursor


Function selects where the text will be drawn relative to the graphics
cursor (or x,y) location.

VDI: \#vst_alignment\#().

See also \#BGI Text\# and \#graphresult\#().
\end

screen( capsensitive("settextstyle") )
#include <graphics.h>

void settextstyle( int font, int direction, int charsize );

  <font> is the font index:  DEFAULT_FONT, TRIPLEX_FONT, SMALL_FONT,
         SANS_SERIF_FONT, or GOTHIC_FONT.
  <direction> is either HORIZ_DIR or VERT_DIR.
  <charsize> is the character magnification factor (1 - 10),
             or 0 to specify the size using \#setusercharsize\#().


Function selects the font, direction, and character size for text.

VDI: \#vst_font\#(), \#vst_rotation\#(), \#vst_height\#(), \#vst_point\#() &
     \#vst_setsize\#().

See also \#BGI Text\# and \#graphresult\#().
\end

screen( capsensitive("setusercharsize") )
#include <graphics.h>

void setusercharsize( int multx, int divx, int multy, int divy );

  <multx> / <divx> is the scale factor for character width.
  <multy> / <divy> is the scale factor for character height. 


Function specifies the scale factor for text fonts as a fraction.
Used only for size 0 specified by \#settextstyle\#().

VDI: \#vst_height\#(), \#vst_point\#() & \#vst_setsize\#().

See also \#BGI Text\# and \#graphresult\#().
\end

screen( capsensitive("setviewport") )
#include <graphics.h>

void setviewport( int left, int top, int right, int bottom, int clip );

  <left> is the horizontal position of the left side.
  <top> is the vertical position of the top.
  <right> is the horizontal position of the right side.
  <bottom> is the vertical position of the bottom.
  <clip> is the clipping flag: 1 = clip, 0 = no clip.


Function sets the clipping rectangle.

VDI: \#vs_clip\#()

See also \#BGI Attributes\# and \#graphresult\#().
\end

screen( capsensitive("setvisualpage") )
#include <graphics.h>

void setvisualpage( int page );

  <page> is the graphics page index (IBM only).


For graphics devices which support more than one displayable page,
this function is used to control which page will be displayed.

Atari VDI does not support multiple pages.

See also \#BGI Service\# and \#graphresult\#().
\end


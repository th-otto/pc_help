screen( capsensitive("Fdelete") )
#include <tos.h>

int Fdelete( const char* pathname );

  <pathname> is a NULL terminated string containing the name of the
             file to be deleted (see \#Pathnames\#).


Function deletes a file.
It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

\#GEM Opcode\# 65

See also \#GEMDOS\#.
\end

screen( capsensitive("Fseek") )
#include <tos.h>

long Fseek( long offset, int handle, int seekmode );

  <offset> is the location to seek (relative to starting point).
  <handle> is an \#I/O handle\#.
  <seekmode> controls the starting point:
             0 = start of file
             1 = current position
             2 = end of file


Function resets the current position for \#Fread\#() or \#Fwrite\#().
It returns the absolute position (after seek), or a
\#BIOS/GEMDOS Error Code\#.

Note: To get the current position, use Fseek(0L,handle,1);

\#GEM Opcode\# 66

See also \#GEMDOS\#.
\end

screen( capsensitive("Fattrib") )
#include <tos.h>

int Fattrib( const char pathname, int wflag, int attrib );

  <pathname> is a NULL terminated string containing the filename
             (see \#Pathnames\#).
  <wflag> is the get/set option:
          0 = return attributes.
          1 = set attributes (return value undefined).
  <attrib> contains the new file attributes (when used).


Function either sets or returns file attributes (0 = normal):
  FA_READONLY  write protected
  FA_HIDDEN    hidden (will not normally appear in file list)
  FA_SYSTEM    system (will not normally appear in file list)
  FA_VOLUME    11 byte volume label (exclusive)
  FA_SUBDIR    subdirectory (exclusive)
               Does not apply to root directory of drive.
  FA_ARCHIVE   archive bit (set when file written to and closed).
               Not correctly handled prior to \#Sversion\#() == 0x1500.
Attributes can be combined (unless exclusive) using logical or.

\#GEM Opcode\# 67

See also \#GEMDOS\#.
\end

screen( capsensitive("Mxalloc") )
#include <tos.h>

void* Mxalloc( long size, int mode);

  <size> is the number of bytes to reserve, or -1L to return the size
         of the largest free block.
  <mode> determines which type of RAM to use:
         0  ST RAM only
         1  TT RAM only
         2  either, ST RAM if available
         3  either, TT RAM if available


Function reserves a block of heap memory.  Similar to \#Malloc\#() except
that one can specify whether to use \link("%%GLOBAL%%")ST RAM\# or \link("%%GLOBAL%%")TT RAM\#.

It returns a pointer to the start of the block, or a NULL pointer if
not enough memory is available (or <size> invalid).
If <size> == -1L, it returns the size of the largest free block (cast
as void*) of the specified type (<mode>=3 or 4, of either type).

Note: Implemented starting with \#GEM Version\# 0.19

\#GEM Opcode\# 68

See also \#GEMDOS\# and \link("%%GLOBAL%%")TT RAM\#.
\end

screen( capsensitive("Fdup") )
#include <tos.h>

long Fdup( int stdh );

  <stdh> is a standard \#I/O handle\# (0-5).


Function creates a duplicate non-standard \#I/O handle\# ( >6 ).
This handle can be closed with no affect to the original handle <stdh>.

It returns an \#I/O handle\# (int), or a \#BIOS/GEMDOS Error Code\#
(negative long).

\#GEM Opcode\# 69

See also \#GEMDOS\#.
\end

screen( capsensitive("Fforce") )
#include <tos.h>

long Fforce( int stdh, int handle );

  <stdh> is a standard \#I/O handle\# (0-5).
  <handle> is an \#I/O handle\# returned by \#Fcreate\#() or \#Fopen\#().


Function redirects file I/O to a standard \#I/O handle\#.
It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

\#GEM Opcode\# 70

See also \#GEMDOS\#.
\end

screen( capsensitive("Dgetpath") )
#include <tos.h>

int Dgetpath( char* buf, int drv_p1 );

  <buf> is an array to be filled with the current directory (for the
        selected drive).
  <drv_p1> is the drive number plus 1 (A=1, B=2, ...), or 0 for the
           current drive.


Function puts the current directory pathname into <buf> (NULL
terminated).  For the complete pathname, use:

  buf[0] = 'A' + \#Dgetdrv\#();
  buf[1] = ':'
  Dgetpath(buf+2,0);

It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

\#GEM Opcode\# 71

See also \#GEMDOS\# and \#Pathnames\#.
\end

screen( capsensitive("Malloc") )
#include <tos.h>

void* Malloc( long size );

  <size> is the number of bytes to reserve, or -1L to return the size
         of the largest free block.


Function reserves a block of heap memory.  (\#PCSTART\# automatically
frees up heap memory.)

It returns a pointer to the start of the block, or a NULL pointer if
not enough memory is available (or <size> invalid).
This pointer will be word boundary aligned.

If <size> == -1L, it returns the size of the largest free block (cast
as void*).

Note: Each block reserved by Malloc() uses up system storage.  After
      a certain number of allocations (e.g. 20), Malloc() will return
      NULL whether there is available memory or not.
      If you intend to make lots of small allocations, use \#malloc\#().

\#GEM Opcode\# 72

See also \#GEMDOS\#.
\end

screen( capsensitive("Mfree") )
#include <tos.h>

int Mfree( void *block );

  <block> points to the start of a memory block previously allocated
          by \#Malloc\#() or \#Mxalloc\#()


Function releases a previously reserved block of heap memory.
It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

\#GEM Opcode\# 73

See also \#GEMDOS\#.
\end

screen( capsensitive("Mshrink") )
#include <tos.h>

int Mshrink( int zero, void *block, long newsiz );

  <zero> must be set to 0.
  <block> points to the start of a memory block previously allocated
          by \#Malloc\#() or \#Mxalloc\#().
  <newsiz> is the new size in bytes (must be less than old size).


Function releases part of a previously reserved block of heap memory
(off the end).
It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

\#GEM Opcode\# 74

See also \#GEMDOS\#.
\end

screen( "PE_LOADGO" )
PE_LOADGO
----------------------------------------------------------------------
ret = \#Pexec\#( 0, prgm, cmd, envp );

  <prgm> is a NULL terminated string containing the pathname of the
         program to be executed.
  <cmd>  is a Pascal string containing the command line to be used.
         The first byte contains the string length, max 127 bytes.
  <envp> points to the environment parameters, or is NULL to use
         the default (parent's) environment parameters.
         These consist of one or more contiguous NULL terminated
         strings, terminated by a NULL string.

Waits until program <prgm> has terminated.  Returns the program's
return code (int), or a \#BIOS/GEMDOS Error Code\# (negative long).
\end

screen( "PE_LOAD" )
PE_LOAD
----------------------------------------------------------------------
base = (\#BASPAG\# *) \#Pexec\#( 3, prgm, cmd, envp );

  <prgm> is a NULL terminated string containing the pathname of the
         program to be loaded.
  <cmd>  is a Pascal string containing the command line to be used.
         The first byte contains the string length, max 127 bytes.
  <envp> points to the environment parameters, or is NULL to use
         the default (parent's) environment parameters.
         These consist of one or more contiguous NULL terminated
         strings, terminated by a NULL string.

Load the program and returns the program's basepage address.
\end

screen( "PE_GO" )
PE_GO
----------------------------------------------------------------------
ret = \#Pexec\#( 4, 0L, base, 0L );

  <base> is the basepage address of a previously loaded program.

Waits until the program terminates and returns the program's return
code (int), or a \#BIOS/GEMDOS Error Code\# (negative long).

Does NOT free program's memory.
\end

screen( "PE_BASEPAGE" )
PE_BASEPAGE
----------------------------------------------------------------------
base = (\#BASPAG\# *) \#Pexec\#( 5, prgm, cmd, envp );

  <prgm> is a NULL terminated string containing the pathname of the
         program.
  <cmd>  is a Pascal string containing the command line to be used.
         The first byte contains the string length, max 127 bytes.
  <envp> points to the environment parameters, or is NULL to use
         the default (parent's) environment parameters.
         These consist of one or more contiguous NULL terminated
         strings, terminated by a NULL string.

Allocate all remaining (contiguous) RAM and construct a basepage at
the starting address.

It returns the basepage address.
\end

screen( "PE_GOTHENFREE" )
PE_GOTHENFREE
----------------------------------------------------------------------
ret = \#Pexec\#( 6, 0L, base, 0L );

  <base> is the basepage address of a previously loaded program.

Waits until the program terminates and returns the program's return
code (int), or a \#BIOS/GEMDOS Error Code\# (negative long).

The program's memory is released on termination.

Note: Implemented starting with \#Sversion\#() == 0x1500
\end

screen( "PE_PRGFLAGS" )
PE_PRGFLAGS
----------------------------------------------------------------------
base = (\#BASPAG\# *) \#Pexec\#( 5, (char *) flags, cmd, envp );

  <flags> is a \link("%%GLOBAL%%")long\# containing the program flags for fastload, etc.
  <cmd>  is a Pascal string containing the command line to be used.
         The first byte contains the string length, max 127 bytes.
  <envp> points to the environment parameters, or is NULL to use
         the default (parent's) environment parameters.
         These consist of one or more contiguous NULL terminated
         strings, terminated by a NULL string.

Allocate RAM according to <flags> and construct a basepage at
the starting address.

It returns the basepage address.

Note: Implemented starting with \#Sversion\#() == 0x1900
\end

screen( "PE_CLOADGO" )
PE_CLOADGO
----------------------------------------------------------------------
id = \#Pexec\#( 100, prgm, cmd, envp );

  <prgm> is a NULL terminated string containing the pathname of the
         program to be executed.
  <cmd>  is a Pascal string containing the command line to be used.
         The first byte contains the string length, max 127 bytes.
  <envp> points to the environment parameters, or is NULL to use
         the default (parent's) environment parameters.
         These consist of one or more contiguous NULL terminated
         strings, terminated by a NULL string.

Returns MiNT id of program, which executes concurrently.

Note: Requires Multitasking OS.
\end

screen( "PE_CGO" )
PE_CGO
----------------------------------------------------------------------
id = \#Pexec\#( 104, prgm, base, 0L );

  <prgm> is a NULL terminated string to use for the name of the
         child process, or 0L to use the parent's name.
  <base> is the basepage address of a previously loaded program.

Returns MiNT id of program, which executes concurrently.
Parent and child share memory access rights.

Note: Requires Multitasking OS.
\end

screen( "PE_NOSHARE" )
PE_NOSHARE
----------------------------------------------------------------------
id = \#Pexec\#( 106, prgm, base, 0L );

  <prgm> is a NULL terminated string to use for the name of the
         child process, or 0L to use the parent's name.
  <base> is the basepage address of a previously loaded program.

Returns MiNT id of program, which executes concurrently.
Parent and child do NOT share memory access rights.

Note: Requires Multitasking OS.
\end

screen( "PE_REPLACE" )
PE_REPLACE
----------------------------------------------------------------------
\#Pexec\#( 200, prgm, cmd, envp );

  <prgm> is a NULL terminated string containing the pathname of the
         program to be executed.
  <cmd>  is a Pascal string containing the command line to be used.
         The first byte contains the string length, max 127 bytes.
  <envp> points to the environment parameters, or is NULL to use
         the default (parent's) environment parameters.
         These consist of one or more contiguous NULL terminated
         strings, terminated by a NULL string.

Terminates parent program.  Child program retains parent's MiNT id.

Note: Requires Multitasking OS.
\end

screen( capsensitive("Pexec") )
#include <tos.h>

long Pexec( int mode, void* prgm, void* cmd, void* envp );

  <mode> is the process option:
           0 = \#PE_LOADGO\#
           3 = \#PE_LOAD\#
           4 = \#PE_GO\#
           5 = \#PE_BASEPAGE\#
           6 = \#PE_GOTHENFREE\#
           7 = \#PE_PRGFLAGS\#
         100 = \#PE_CLOADGO\#
         104 = \#PE_CGO\#
         106 = \#PE_NOSHARE\#
         200 = \#PE_REPLACE\#

  Remaining parameters and the return value depend on <mode>.


Function is used to load and execute other programs.

\#GEM Opcode\# 75

See also \#GEMDOS\#, \#shel_write\#(), \#BASPAG\# and \#Pathnames\#.
\end

screen( capsensitive("Pterm") )
#include <tos.h>

void Pterm( int retcode );

  <retcode> is the program return code.


Function terminates the application, returning error code <retcode>.
All open files are closed and all heap memory is freed.

Note: All this is handled by \#PCSTART\#.

\#GEM Opcode\# 76

See also \#GEMDOS\# and \#exit\#().
\end

screen( capsensitive("Fsfirst"),
		capsensitive("Fsnext") )
#include <tos.h>

int Fsfirst( const char *filename, int attrib );
int Fsnext( void );

  <filename> is a NULL terminated string containing the pathname of
             the file(s) sought (see \#Pathnames\#).
  <attrib> contains the allowed file attribute bitflags (0 = normal):
           FA_HIDDEN    hidden
           FA_SYSTEM    system
           FA_VOLUME    volume label (exclusive)
           FA_SUBDIR    subdirectory (exclusive)
           Other bitflags are ignored.


Fsfirst() can be used to put all directory info about a particular
file into the \#DTA\# buffer (see \#Fgetdta\# and \#Fsetdta\#).
By using wildcards and repeatedly calling Fsnext(), one can construct
a directory listing:

main( void )
 {
  \#DTA\# *pdta;
  int ret;

  pdta = Fgetdta();
  ret = Fsfirst("*.*",0);
  while(ret == 0) {
    printf("%12s %ld\\n", pdta->d_fname, pdta->d_length);
    ret = Fsnext();
   }
  return(0);
 }

Files will be returned in the order in which they are stored in the
directory, so must be sorted by the user.  When <attrib> = FA_SUBDIR,
virtual subdirectories "." and ".." will be included in the list.

Both functions return 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -49 = no more matching files in directory

Note: The state of the search is stored in the reserved bytes of the
      \#DTA\# structure.  Also, the default \#DTA\# buffer shares the same
      RAM as the command line (see \link("%%GLOBAL%%")main\#).

Opcodes: 78 Fsfirst
         79 Fsnext

See also \#GEMDOS\# and \#Dreaddir\#().
\end

screen( capsensitive("Frename") )
#include <tos.h>

int Frename( int zero, const char *oldname, const char *newname );

  <zero> must be 0.
  <oldname> is a NULL terminated string containing the pathname of
            the file to be renamed (see \#Pathnames\#).
  <newname> is a NULL terminated string containing the new pathname
            (see \#Pathnames\#).  Must be on same drive.


Function changes the name of a file and/or moves it into another
directory (on the same drive).  Cannot be used to rename directories.
Will not replace an existing file <newname>.

It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

\#GEM Opcode\# 86

See also \#GEMDOS\# and \#Fdelete\#().
\end

screen( capsensitive("Fdatime") )
#include <tos.h>

int Fdatime( \#DOSTIME\# *timeptr, int handle, int wflag );

  <timeptr> is a structure buffer used to set or get the MS-DOS
            format timestamp for an open file.
  <handle> is an \#I/O handle\# returned by \#Fcreate\#() or \#Fopen\#().
  <wflag> determines whether to get or set the timestamp:
          0 = get timestamp.
          1 = set timestamp.


Function can be used to get or set an open file's timestamp.
It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

\#GEM Opcode\# 87

See also \#GEMDOS\#.
\end

screen( capsensitive("Flock") )
#include <tos.h>

long Flock( int handle, int mode, long start, long length );

  <handle> is an \#I/O handle\# returned by \#Fcreate\#() or \#Fopen\#().
  <mode> is 0 to create a lock, or 1 to remove it.
  <start> is the byte offset to the start of the lock.
  <length> is the number of bytes to be protected, or
           0 to lock the rest of the file.


Function can be used to prevent other processes from accessing part
or all of a file.  The <start> and <length> parameters must match
exactly to remove a lock.

It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#:
  -58 = conflicts with another lock (when locking)
  -59 = no matching lock found (when unlocking)

\#GEM Opcode\# 92

Note: Available when the '_FLK' cookie exists (see \#Cookies\#).

See also \#GEMDOS\#.

\end

screen( capsensitive("bios") )
#include <tos.h>

long bios( void, \link("%%GLOBAL%%")...\# );


Function performs a \#BIOS\# function call by \#BIOS Opcode\#.
The argument list consists of the function number followed by the
corresponding function arguments.  For example, one could call
\#Bconstat\#() using:

  ret = (int) bios(1, dev);

The only difference is that \#Bconstat\#() would push its argument
(D0) and function number (1) onto the stack, perform the \link("%%GLOBAL%%")TRAP\# #13
instruction then return, whereas bios already has that information
on the stack.  However, it must pop its return address off the stack
and save it in a static variable before performing the \link("%%GLOBAL%%")TRAP\# #13, then
push the return address back onto the stack before returning.

(Both must save and restore register A2.)
\end

screen( capsensitive("Getmpb") )
#include <tos.h>

void Getmpb( \#MPB\# *ptr );

  <ptr> is a \#MPB\# structure buffer.


Function fills the buffer with the system's memory parameter block.
This gives the starting locations of OS pool linked lists for free
blocks and allocated blocks.

Note: Intended for use by GEMDOS.

\#BIOS Opcode\# 0

See also \#BIOS\#.
\end

screen( capsensitive("Bconstat") )
#include <tos.h>

int Bconstat( int dev );

  <dev> is the \#BIOS Device Number\#.  (NOT the standard handle!)


Function returns input status on device <dev>.  It returns TRUE (-1)
if at least one character is available, and FALSE (0) otherwise.

\#BIOS Opcode\# 1

See also \#BIOS\#.
\end

screen( capsensitive("Bconin") )
#include <tos.h>

long Bconin( int dev );

  <dev> is the \#BIOS Device Number\#.  (NOT the standard handle!)


Function returns one character from input device <dev>, or waits until
one is available.

For <dev> = 2 (CON:), the scan code is included in bits 16-23.
If bit 3 of the system variable 'conterm' is set, then bits 24-31 will
contain the value of the system variable 'kbshift' for that keystroke.
(Default is to clear bit 3 of conterm.)

\#BIOS Opcode\# 2

See also \#BIOS\# and \link("%%GLOBAL%%")Scan Codes\#.
\end

screen( capsensitive("Bconout") )
#include <tos.h>

void Bconout( int dev, int c );

  <dev> is the \#BIOS Device Number\#.  (NOT the standard handle!)
  <c> is a character (0-255) passed as an int.


Function outputs one character to device <dev>.  If the device is
busy, it will wait (so check the output status first).

Note: When <dev> = 0, Bconout actually returns 0 on a timeout error.
      However, you will need to define Bconout() as long or use
      \#bios\#(3,0,<c>) to access this return value.

\#BIOS Opcode\# 3

See also \#BIOS\#.
\end

screen( capsensitive("Rwabs") )
#include <tos.h>

long Rwabs( int rwflag, void *buf, int cnt, int recno, int dev );

  <rwflag> read/write flag:
           0  read
           1  write
           2  read, do not affect media change
           3  write, do not affect media change
  <buf> is the input/output buffer (<cnt> * sector size).
  <cnt> is the number of sectors to read/write.
  <recno> is the (starting) logical sector number.
  <dev> is the drive number (A=0, B=1, C=2, ...)


Function reads or writes one or more sectors for either a hard or
floppy disk drive.

It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

Note: AHDI 3.0 provides a revised definition for Rwabs() which uses
      additional bit flags for <rwflag> and adds an extra argument.
      See \#Rwabs Extended Features\#.

Also: Rwabs() does NOT support high density floppies.

\#BIOS Opcode\# 4

See also \#BIOS\#, \#Floprd\#(), \#Flopwr\#() and \#Disk Format\#.
\end

screen( "Rwabs Extended Features" )
AHDI 3.0  \#Rwabs\#()  Extended Features
----------------------------------------------------------------------
long \link("BIOS")Bios\#( 4, int rwflag, void *buf, int cnt, int recno, int dev,
            long lrecno );

  <rwflag> bit flags:
           bit 0 - read (0) or write (1)
           bit 1 - ignore media change (1)
           bit 2 - no retry (1)
           bit 3 - physical (1) or logical (0) mode
  <buf> is the input/output buffer (<cnt> * sector size).
        In physical mode, sector size = 512.
  <cnt> is the number of sectors to read/write.
  <recno> is the (starting) sector number:
        Logical sector numbers start at 0 for each drive or partition.
        -1 = use <lrecno>
  <dev> is the drive number:
        Logical drive numbers are A=0, B=1, C=2, ...
        Physical drive numbers are 2-9 for ACSI drives 0-7 and 10-17
        for SCSI drives 0-7.
  <lrecno> long record number (for partitions larger than 16 Mbytes).


Function read or writes one or more sectors to disk.  It returns 0
normally, or a \#BIOS/GEMDOS Error Code\#.

See also \#DMAread\#() and \#DMAwrite\#().
\end

screen( capsensitive("Setexc") )
#include <tos.h>

void (*Setexc( int number, void (*exchdlr)() )) ();

  <number> is the exception vector number (2-255).
  <exchdlr> is an exception handler (function pointer).


Function inserts a new exception handler for exception vector <number>.
It returns the address of the old exception handler.

extern void newvector();  /* usually written in assembly language */

main( void )
 {
  void (*oldvector)();
  oldvector = Setexc(5,newvector);  /* trap 'divide by zero' errors */
... 
  Setexc(5,oldvector);  /* restore original handler */
  return(0);
 }

\#BIOS Opcode\# 5

See also \#BIOS\#, \#Supexec\#() and \link("%%GLOBAL%%")Exception Vectors\#.
\end

screen( capsensitive("Tickcal") )
#include <tos.h>

long Tickcal( void );


Function returns the number of milliseconds per system timer increment.
(Unless the timer is changed from 50 Hz, this value will be 20.)

\#BIOS Opcode\# 6

See also \#BIOS\#.
\end

screen( capsensitive("Getbpb") )
#include <tos.h>

\#BPB\# *Getbpb( int dev );

  <dev> is the drive number (A=0, B=1, C=2, ...)


Function returns a pointer to the Bios Parameter Block structure, or a
NULL pointer on error (no such drive).

Note: Calling Getbpb() will clear the media change flag (if set)
      so that GEMDOS will never know it was set.

\#BIOS Opcode\# 7

See also \#BIOS\#.
\end

screen( capsensitive("Bcostat") )
#include <tos.h>

long Bcostat( int dev );

  <dev> is the \#BIOS Device Number\#.  (NOT the standard handle!)
        Note: 3 = IKBD and 4 = MIDI


Function returns output status on device <dev>.  It returns TRUE (-1)
if the device is ready to send, and FALSE (0) otherwise.

\#BIOS Opcode\# 8

See also \#BIOS\#.
\end

screen( capsensitive("Mediach") )
#include <tos.h>

long Mediach( int dev );

  <dev> is the drive number (A=0, B=1, C=2, ...)


Function indicates whether a new floppy has been inserted or if a hard
drive has been reformatted:
  0  Media definitely has not changed.
  1  Media might have been changed.
  2  Media definitely has changed.

GEMDOS keeps certain directory information in RAM.  When a media
change is detected, it must re-read this info.

Mediach() is also used when swapping disks between drives A and B on
a system with a single floppy drive.

Note: Calling Mediach() will clear the media change flag (if set)
      so that GEMDOS will never know it was set.

\#BIOS Opcode\# 9

See also \#BIOS\#.
\end

screen( capsensitive("Drvmap") )
#include <tos.h>

long Drvmap( void );


Function returns a bitmap of all active drives (1=A, 2=B, 4=C, ...).
A value of 3 would indicate drives A and B only.

Note: Drive B is always active, even on systems with one floppy drive.

\#BIOS Opcode\# 10

See also \#BIOS\#.
\end

screen( capsensitive("Kbshift") )
#include <tos.h>

long Kbshift( int mode );

  <mode> is the new shift bit setting, or -1 to inquire only. 
          1 (bit 0) right Shift key
          2 (bit 1) left Shift key
          4 (bit 2) Control key
          8 (bit 3) ALT key
         16 (bit 4) Caps Lock (set)
         32 (bit 5) right mouse button (or Clr/Home)
         64 (bit 6) left mouse button (or Insert)


Function returns the current 'shift' key status bitmap.  It can also
be used to set a new value.

Note: Setting these bits when the corresponding keys are not pressed
      cannot be cleared by then pressing and releasing the keys
      (except for Caps Lock).  Clearing the bits causes no problems.

\#BIOS Opcode\# 11

See also \#BIOS\# and \#graf_mkstate\#.
\end

screen( capsensitive("xbios") )
#include <tos.h>

long xbios( void, \link("%%GLOBAL%%")...\# );


Function performs an \#XBIOS\# function call by function number.
The argument list consists of the function number followed by the
corresponding function arguments.  For example, one could call
\#Settime\#() using:

  xbios(22, datetime);

The only difference is that \#Settime\#() would push its argument
(D0) and function number (22) onto the stack, perform the \link("%%GLOBAL%%")TRAP\# #14
instruction then return, whereas xbios already has that information
on the stack.  However, it must pop its return address off the stack
and save it in a static variable before performing the \link("%%GLOBAL%%")TRAP\# #14, then
push the return address back onto the stack before returning.

(Both must save and restore register A2.)
\end

screen( capsensitive("Initmouse") )
#include <tos.h>

void Initmouse( int type, \#MOUSE\# *par. void (*mousvec)() );

  <type> controls the function's operation:
         0  disable mouse
         1  enable mouse, in relative mode (default)
         2  enable mouse, in absolute mode
         4  enable mouse, in keycode mode
  <par> is a \#MOUSE\# structure (passed by address).
  <mousvec> is an interrupt handler for a mouse report.
            One can use \#Kbdvbase\#() to obtain the default vector.


Function controls the mouse system, including the type of reports
generated by the keyboard, the 'resolution' of these reports, and
the handler to process these reports.

The jump vector routine will be passed a pointer to the report packet
in register A0 and on the stack at 4(SP).  Terminate the routine with
an RTS instruction (not RTE).  

\#XBIOS Opcode\# 0

See also \#XBIOS Console\#, \link("%%GLOBAL%%")IKBD\#, \#vex_butv\#(), \#vex_motv\#() and \#vex_curv\#().
\end

screen( capsensitive("Ssbrk") )
#include <tos.h>

void *Ssbrk( int count );

  <count> is the number of bytes to reserve.


Function reserves memory for the screen image at boot time.  Can only
be used from ROM, since the memory manager must be active before any
programs can be loaded from disk.

\#XBIOS Opcode\# 1

See also \#XBIOS Misc\#.
\end

screen( capsensitive("Physbase") )
#include <tos.h>

void *Physbase( void );


Function returns the base address of the screen image being displayed.

\#XBIOS Opcode\# 2

See also \#XBIOS Video\#.
\end

screen( capsensitive("Logbase") )
#include <tos.h>

void *Logbase( void );


Function returns the base address of the screen image being created
(possibly different from screen image being displayed).

\#XBIOS Opcode\# 3

See also \#XBIOS Video\#.
\end

screen( capsensitive("Getrez") )
#include <tos.h>

int Getrez( void )


Function returns the screen resolution:
  0 = ST Low    ( 320 W x 200 H,  16 colors) 
  1 = ST Medium ( 640 W x 200 H,   4 colors)
  2 = ST High   ( 640 W x 400 H,  duochrome)
  4 = TT Medium ( 640 W x 480 H,  16 colors)
  6 = TT High   (1280 W x 960 H, monochrome)
  7 = TT Low    ( 320 W x 480 H, 256 colors)

Note: This value is relatively unimportant for the Falcon.
      To get the Falcon color mode, use \#Vsetmode\#().

\#XBIOS Opcode\# 4

See also \#XBIOS Video\#.
\end

screen( capsensitive("Setscreen") )
#include <tos.h>

void Setscreen( void *laddr, void *paddr, int rez );

  <laddr> points to the new logical screen base, or negative to keep
          the old value.  (Used to draw images.)
  <paddr> points to the new physical screen base, or negative to keep
          the old value.  (Used to display images.)
  <rez> is the new screen resolution, or negative to keep the old
        value:
        0 = ST Low    ( 320 W x 200 H,  16 colors)
        1 = ST Medium ( 640 W x 200 H,   4 colors)
        2 = ST High   ( 640 W x 400 H,  duochrome)
        4 = TT Medium ( 640 W x 480 H,  16 colors)
        6 = TT High   (1280 W x 960 H, monochrome)
        7 = TT Low    ( 320 W x 480 H, 256 colors)


Function changes the logbase and physbase immediately, and implements
the new resolution at the next vertical blank.  When the resolution is
changed, the screen is cleared, the cursor is set to home, and the
\#VT52\# emulator state is reset.

ST screen images consist of 32,000 bytes of contiguous RAM aligned
to a 256 byte boundary on the ST or a 2 byte boundary on the STE.

TT screen images consist of 153,600 bytes of contiguous \link("%%GLOBAL%%")ST RAM\# aligned
to an 8 byte boundary (even for resolutions 0-2).

Note: Changing the resolution in an application will cause problems
      with \#AES\# and \#VDI\# (see \#shel_write\#).

Also: Use \#Vsync\#() for smooth transitions.

\#XBIOS Opcode\# 5

See also \#XBIOS Video\# and \#VsetScreen\#().
\end

screen( capsensitive("VsetScreen") )
Falcon binding for \#Setscreen\#()
----------------------------------------------------------------------
#define VsetScreen(laddr,paddr,mode) \#xbios\#(5,laddr,paddr,3,mode)

  <laddr> points to the new logical screen base, or NULL to allocate
          reserved RAM.  (Used to draw images.)
  <paddr> points to the new physical screen base, or NULL to allocate
          reserved RAM.  (Used to display images.)
  <mode> contains the Falcon color mode bit flags, or -1 to keep the
         old mode:
         BPS1  = monochrome
         BPS2  = 2 bit planes = 4 colors
         BPS4  = 4 bit planes = 16 colors
         BPS8  = 8 bit planes = 256 colors
         BPS16 = 16 bits/pixel RGB colors

         COL80 = 80 columns 
         COL40 = 40 columns
         VGA_FALCON = multisync monitor
         TV = TV or video monitor
         PAL = PAL (as opposed to NTSC) TV
         OVERSCAN = overscan on
         STMODES = ST compatible resolutions
         VERTFLAG = interlace or double line on

Note: Not all bit flag combinations are legal (or meaningful).

See also \#XBIOS Video\#.
\end

screen( capsensitive("Setpalette") )
#include <tos.h>

void Setpalette( void *pallptr );

  <pallptr> points to an array of 16 \#Color Definition\#s (aligned to a
            2 byte boundary).


Function loads the 16 ST color registers, or the current bank of 16
TT color registers, during the next vertical blank.

\#XBIOS Opcode\# 6

See also \#XBIOS Video\#.
\end

screen( capsensitive("Setcolor") )
#include <tos.h>

int Setcolor( int colornum, int color );

  <colornum> is the color index number (0-15).
  <color> is the new \#Color Definition\# for this index, or
          -1 to keep the current value.


Function loads the selected color register during the next vertical
blank.  It returns the old \#Color Definition\#.

\#XBIOS Opcode\# 7

See also \#XBIOS Video\#.
\end

screen( capsensitive("Floprd") )
#include <tos.h>

int Floprd( void *buf, long filler, int devno, int sectno,
            int trackno, int sideno, int count );

  <buf> is the input buffer (aligned to 2 byte boundary).
  <filler> is not used.
  <devno> is floppy drive number (0 or 1).
  <sectno> is the (starting) sector number (1 to 9).
  <trackno> is the track number (0 to 79).
  <sideno> is the side number (0 or 1).
  <count> is the number of sectors to read ( <=9 ).


Function reads one or more sectors from a specific track.
It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

Note: The above limits are given for a disk with 9 sectors/track
      and 80 tracks/side.  Other values are possible.

\#XBIOS Opcode\# 8

See also \#XBIOS I/O\#, \#Rwabs\#() and \#Disk Format\#.
\end

screen( capsensitive("Flopwr") )
#include <tos.h>

int Flopwr( void *buf, long filler, int devno, int sectno,
            int trackno, int sideno, int count );

  <buf> is the output buffer (aligned to 2 byte boundary).
  <filler> is not used.
  <devno> is floppy drive number (0 or 1).
  <sectno> is the (starting) sector number (1 to 9).
  <trackno> is the track number (0 to 79).
  <sideno> is the side number (0 or 1).
  <count> is the number of sectors to read ( <=9 ).


Function writes one or more sectors from a specific track.
It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

Note: The above limits are given for a disk with 9 sectors/track
      and 80 tracks/side.  Other values are possible.

\#XBIOS Opcode\# 9

See also \#XBIOS I/O\#, \#Rwabs\#() and \#Disk Format\#.
\end

screen( capsensitive("Flopfmt") )
#include <tos.h>

int Flopfmt( void *buf, long filler, int devno, int spt, int trackno,
             int sideno, int interlv, long magic, int virgin );

  <buf> is the track image buffer (aligned to 2 byte boundary)
        including room for gap info.  Requires about 8K for 9 sectors.
        It will be filled with a null terminated list of bad sector
        numbers (int array) on return.
  <filler> is not used.
  <devno> is floppy drive number (0 or 1).
  <spt> is the number of sectors per track (9 is IBM standard).
  <trackno> is the track number (0 to 79).
  <sideno> is the side number (0 or 1).
  <interlv> is the sector interleaf factor (usually 1).
  <magic> must be 0x87654321.
  <virgin> is the initial fill value for the sectors.
           One must NOT use 0xF in the high nibble of either byte.
           0xE5E5 is recommended (0 is NOT recommended).


Function formats one track on a floppy.  A null terminated list of
bad sector numbers is returned in the buffer.  The media definitely
changed flag (2) will returned by the next call to \#Mediach\#().

It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

Note: The above limits are given for a disk with 9 sectors/track
      and 80 tracks/side.  Other values are possible.

\#XBIOS Opcode\# 10

See also \#XBIOS I/O\# and \#Disk Format\#.
\end

screen( capsensitive("Midiws") )
#include <tos.h>

void Midiws( int cnt, void *ptr );

  <cnt> is the number of bytes to writes (minus one).
  <ptr> points to the string to write. 


Function writes a string to the MIDI port.

\#XBIOS Opcode\# 12

See also \#XBIOS I/O\# and \#Kbdvbase\#().
\end

screen( capsensitive("Mfpint") )
#include <tos.h>

void Mfpint( int erno, void (*vector)() );

  <erno> is an \#MFP Interrupt\# number.
  <vector> is an exception handler (usually written in assembly).


Function inserts a new interrupt handler into the MFP exception
vector list (see \link("%%GLOBAL%%")Exception Vectors\#).

\#XBIOS Opcode\# 13

See also \#XBIOS Misc\#.
\end

screen( capsensitive("Iorec") )
#include <tos.h>

\#IOREC\# *Iorec( int dev );

  <dev> is the device code:
        0 = AUX:
        1 = Keyboard
        2 = MIDI


Function returns the address of the \#IOREC\# buffer structure for the
corresponding device.  When <dev> = 0, it returns the address of an
array of two \#IOREC\# structures, the first for input and the second
for output.

\#XBIOS Opcode\# 12

See also \#XBIOS I/O\#.
\end

screen( capsensitive("Rsconf") )
#include <tos.h>

long Rsconf( int baud, int ctr, int ucr, int rsr, int tsr, int scr );

  <baud> is the baud rate code (-1 = keep old value):
         0 = 19200 baud             8 =   600 baud
         1 =  9600 baud             9 =   300 baud
         2 =  4800 baud            10 =   200 baud
         3 =  3600 baud            11 =   150 baud
         4 =  2400 baud            12 =   134 baud
         5 =  2000 baud            13 =   110 baud
         6 =  1800 baud            14 =    75 baud
         7 =  1200 baud            15 =    50 baud

  <ctr> is the flow control (-1 = keep old value):
         0 = No flow control (default)
         1 = XON/XOFF
         2 = RTS/CTS
  <ucr> is the MFP USART control register (-1 = keep old value).
        See \link("%%GLOBAL%%")UCR\#.  (Bits 1-6 are emulated for the SCC.)
  <rsr> is the MFP receiver status register (-1 = keep old value).
        See \link("%%GLOBAL%%")RSR\#.  (Not defined for the SCC.)
  <tsr> is the MFP transmitter status register (-1 = keep old value).
        See \link("%%GLOBAL%%")TSR\#.  (Bit 3 emulated for the SCC.)
  <scr> is the MFP synchronous character register (-1 = keep old value).
        (Not defined for the SCC.)


Function sets the RS232 configuration for AUX: (BIOS device 3).
On the TT it refers to the BIOS device currently mapped to AUX: by
\#Bconmap\#().

It returns the previous values of \link("%%GLOBAL%%")UCR\#, \link("%%GLOBAL%%")RSR\# and \link("%%GLOBAL%%")TSR\# packed
into a long (see \#RSCONF\#).  For the special case of

  baud = Rsconf(-2,-1,-1,-1,-1,-1);

it returns the baud code (starting with \#TOS Version\# = 1.04).

\#XBIOS Opcode\# 15

See also \#XBIOS I/O\#.
\end

screen( capsensitive("Keytbl") )
#include <tos.h>

\#KEYTAB\# *Keytbl( void *unshift, void *shift, void *capslock );

  <unshift> is the normal key translation table.
            (-1L = keep old table).
  <shift> is the key translation table used with the shift key.
          (-1L = keep old table).
  <capslock> is the key translation table used with the caps lock.
             (-1L = keep old table).


Function sets up new translation tables between \link("%%GLOBAL%%")Scan Codes\# and
the \link("%%GLOBAL%%")ASCII Character Set\#.

It returns a pointer to a \#KEYTAB\# structure, which consists of the
three key translation table pointers.

Each key translation table is a 128 element character array.
Each element consists of the ASCII equivalent for the corresponding
scan code.
For example, unshift[0]=0, unshift[1]=0x1b, unshift[2]='1', ...
(Use 0 when no ASCII value exists.)

\#XBIOS Opcode\# 16

See also \#XBIOS Console\#.
\end

screen( capsensitive("Random") )
#include <tos.h>

long Random( void );


Function returns a pseudo-random 24 bit number (uniformly distributed
between 0 to 16777215L).

The algorithm is from Knuth:
  long seed;
  seed = (seed * 3141592621L) + 1;
  return(seed >> 8);
The initial seed value is taken from the frame counter.

\#XBIOS Opcode\# 17

See also \#XBIOS Misc\#.
\end

screen( capsensitive("Protobt") )
#include <tos.h>

void Protobt( void *buf, long serialno, int disktype, int execflag );

  <buf> is a 512 byte buffer containing the boot sector.
  <serialno> is the serial number for the disk.
             -1L = keep original value in <buf>.
             > 0xFFFFFFL = create random number.
  <disktype> is the standard format type:
             0 = 40 tracks, 1 side,  9 sectors/track (180K)
             1 = 40 tracks, 2 sides, 9 sectors/track (360K)
             2 = 80 tracks, 1 side,  9 sectors/track (360K)
             3 = 80 tracks, 2 sides, 9 sectors/track (720K)
             4 = 80 tracks, 2 sides, 18 sectors/track (1.44M)
            -1 = use disk description already in <buf>.
  <execflag> is used to make the boot sector executable.
             0 = not executable.
             1 = executable.
            -1 = use setting in <buf>.


Function creates a prototype boot sector for a standard format floppy
which is compatible with MS-DOS 2.x.  In particular, it can be used
to make a boot sector executable (even with a non-standard format).

If the 16 bit checksum = 0x1234, the boot sector is executable, which
means that the sector contains a \link("%%GLOBAL%%")BRA\# instruction starting in the
byte 0 which jumps to executable code contained in bytes 58 to 509.
Bytes 510 & 511 are filled with the appropriate values needed to
achieve this checksum result.  Any change made to the boot sector
after Protobt() will (almost certainly) disable it.

Note: The serial number is used by \#Mediach\#() to determine whether
      the disk was definitely changed, so using a random number is a
      good idea.

\#XBIOS Opcode\# 18

See also \#XBIOS I/O\#, \#Disk Format\# and \#Cookies\#.
\end

screen( capsensitive("Flopver") )
#include <tos.h>

int Flopver( void *buf, long filler, int devno, int sectno,
            int trackno, int sideno, int count );

  <buf> is the verification buffer (aligned to 2 byte boundary).
        It will be filled with a null terminated list of bad sector
        numbers (int array) on return.
  <filler> is not used.
  <devno> is floppy drive number (0 or 1).
  <sectno> is the (starting) sector number (1 to 9).
  <trackno> is the track number (0 to 79).
  <sideno> is the side number (0 or 1).
  <count> is the number of sectors to read ( <=9 ).


Function reads one or more sectors from a specific track and compares
the result to the contents in <buf>.  A list of bad sector numbers
will be returned in <buf>.

It returns 0 normally, or a \#BIOS/GEMDOS Error Code\#.

Note: The above limits are given for a disk with 9 sectors/track
      and 80 tracks/side.  Other values are possible.

\#XBIOS Opcode\# 19

See also \#XBIOS I/O\# and \#Disk Format\#.
\end

screen( capsensitive("Scrdmp") )
#include <tos.h>

void Scrdmp( void );


Function causes a screen image to be sent to the printer using the
current printer settings.  Can only be used with dot matrix printers
and ST high resolution.  Serial printer must be connected to Modem 1
on TT.

Note: The screen dump does not use the \#Bconout\#() jump vectors.

\#XBIOS Opcode\# 20

See also \#XBIOS Console\#.
\end

screen( capsensitive("Cursconf") )
#include <tos.h>

int Cursconf( int func, int rate );

  <func> is the control code:
         0 = hide cursor.
         1 = show cursor.
         2 = set cursor to blink.
         3 = set cursor to not blink.
         4 = set blink timer to <rate>.
         5 = return current blink time value.
  <rate> is the new blink timer value (used when <func> = 4 only).


Function controls the \#VT52\# text cursor.
It returns the blink rate when <func> = 5 only.

The blinking rate corresponds to the number of frames between turning
the cursor on and off again, and therefore depends on the screen
frequency: 50 Hz for Europe, 60 Hz for the U.S., and 70 Hz for
monochrome.  For a 1 second blinking rate (default), use 25, 30 or 35
(respectively).

\#XBIOS Opcode\# 21

See also \#XBIOS Console\#.
\end

screen( capsensitive("Settime") )
#include <tos.h>

void Settime( unsigned long time );

  <time> contains a time/date stamp in MS-DOS format
         (date in high word, time in low word).


Function sets the real time clock in the keyboard.  Starting with
\#TOS Version\# 1.02, it also resets the system clock/calendar.
It also resets the internal real time clock on the TT.

\#XBIOS Opcode\# 22

See also \#XBIOS Console\# and \#DOSTIME\#.
\end


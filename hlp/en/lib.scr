screen( capsensitive("lseek") )
#include <stdio.h>

\#size_t\# lseek( int handle, \#size_t\# offset, int from );

  <handle> is a \#GEMDOS handle\# for an open file.
  <offset> is the distance in bytes from the starting point.
  <from> defines the starting point:
         SEEK_SET (0)  from start of file (L_SET)
         SEEK_CUR (1)  from current position (L_INCR)
         SEEK_END (2)  from end of file (L_XTND)


Function positions I/O at a specific location within a file relative
to the starting point.

It returns the resulting position relative to the start of the file.

Note: lseek(handle, 0L, SEEK_CUR) returns the current position.

See also \#UNIX I/O\# and \#Fseek\#().
\end

screen( capsensitive("assert") )

See also \#Line A\#, \#v_show_c\#() and \#graf_mouse\#().
\end

screen( capsensitive("hide_mouse") )
#include <linea.h>

void hide_mouse( void );


Function stops drawing the mouse sprite and restores the screen image
from the save buffer (see \#VDIESC\#).

Note: Always hide the mouse before performing graphics operations.

See also \#Line A\#, \#v_hide_c\#() and \#graf_mouse\#().
\end

screen( capsensitive("transform_mouse") )
#include <linea.h>

void transform_mouse( \#MFORM\# *mform );



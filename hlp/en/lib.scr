screen( capsensitive("EsetGray") )
#include <tos.h> 

int EsetGray( int swtch );

  <swtch> turns gray mode on or off:
          0 turn gray mode off.
          1 = turn gray mode on.
         -1 = keep current setting.


Function turns gray mode on or off.  It returns the old setting.

Note: Gray mode uses the lower 8 bits of the color register to set a
      gray level (0 = black, 255 = white).  See \#Color Definition\#.
      Does not require a monochrome monitor.

Note: Available when '_VDO' cookie >= 0x20000L (see \#Cookies\#).

\#XBIOS Opcode\# 86

See also \#XBIOS Video\#.
\end

screen( capsensitive("EsetSmear") )
#include <tos.h> 

int EsetSmear( int swtch );

  <swtch> turns smear mode on or off:
          0 turn smear mode off.
          1 = turn smear mode on.
         -1 = keep current setting.


Function turns smear mode on or off.  It returns the old setting.

Note: Smear mode affects only color index 0, which is replaced
      by whatever color was last used.  The \#Color Definition\# for
      index 0 is still used for the border color.
      Available when '_VDO' cookie >= 0x20000L (see \#Cookies\#).

\#XBIOS Opcode\# 87

See also \#XBIOS Video\#.
\end

screen( capsensitive("VsetMode"),
		capsensitive("Vsetmode") )
#include <tos.h> 

int Vsetmode( int modecode );

  <modecode> is the Falcon color mode bit flags (or -1 for no change):
             BPS1  = monochrome
             BPS2  = 2 bit planes = 4 colors
             BPS4  = 4 bit planes = 16 colors
             BPS8  = 8 bit planes = 256 colors
             BPS16 = 16 bits/pixel RGB colors

             COL80 = 80 columns 
             COL40 = 40 columns (NULL)
             VGA_FALCON = multisync monitor
             TV = TV or video monitor (NULL)
             PAL = PAL (as opposed to NTSC) TV
             OVERSCAN = overscan on
             STMODES = ST compatible resolutions
             VERTFLAG = interlace or double line on


Function sets the Falcon color mode.  It returns the previous mode.

Note: Not all bit flag combinations are legal.
      Available when '_VDO' cookie >= 0x30000L (see \#Cookies\#).

\#XBIOS Opcode\# 87

See also \#XBIOS Video\# and \#VsetScreen\#().
\end


screen( capsensitive("exception") )
Floating Point Exception Structure                            <math.h>
----------------------------------------------------------------------
typedef enum
 {
  DOMAIN = 1,    /* argument domain error -- log (-1)      */
  SING,          /* argument singularity  -- pow (0,-2))   */
  OVERFLOW,      /* overflow range error  -- exp (1000)    */
  UNDERFLOW      /* underflow range error -- exp (-1000)   */
 } mexcep;

struct exception
 {
  mexcep type;   /* type of error (1-4) */
  char   *name;  /* name of operation   */
  double arg1;   /* first argument      */
  double arg2;   /* second argument     */
  double retval; /* return value        */
 };

See \#setmatherr\#().
\end


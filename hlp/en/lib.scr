#include <vdi.h>

void v_clear_disp_list( int handle );

  <handle> is the \#VDI Handle\#.


Function clears any pending printer graphics output.
(Applies only to GDOS printer device workstations.)
Does not eject page.

\#VDI Subopcode\# 5,22

See also \#VDI Printer Escapes\# and \#v_clrwk\#().
\end

screen( capsensitive("v_bit_image") )
#include <vdi.h>

void v_bit_image( int handle, const char *filename, int aspect,
                  int x_scale, int y_scale, int h_align, int v_align,
                  int *xyarray );

  <handle> is the \#VDI Handle\#.
  <filename> is a NULL terminated \link("Pathnames")pathname\#.
  <aspect> selects whether to honor the pixel aspect ratio (1) or not.
  <x_scale> selects whether to use integer (1) or fractional (0)
            scaling along the x axis (horizontal).
  <y_scale> selects whether to use integer (1) or fractional (0)
            scaling along the y axis (vertical).
  <h_align> controls the horizontal placement within the rectangle:
            0 = left
            1 = center
            2 = right
  <v_align> controls the vertical placement within the rectangle:
            0 = top
            1 = middle
            2 = bottom
  <xyarray> is a 4 entry int array defining a clipping rectangle:
            [0] = x coordinate of left (or right) edge.
            [1] = y coordinate of bottom (or top) edge.
            [2] = x coordinate of right (or left) edge.
            [3] = y coordinate of top (or bottom) edge.


Function causes a bit image file (\#IMG\#) to be copied to the printer.
(Applies only to GDOS printer device workstations.)

\#VDI Subopcode\# 5,23

See also \#VDI Printer Escapes\# and \#VDI Coordinates\#.
\end

screen( capsensitive("vq_scan") )
#include <vdi.h>

void vq_scan( int handle, int *g_slice, int *g_page,
              int *a_slice, int *a_page, int *div_fac);

  <handle> is the \#VDI Handle\#.
  <g_slice> returns the number of graphic passes per page.
  <g_page>/<div_fac> returns the number of scan lines per pass.
  <a_slice>/<div_fac> returns the number of scan lines per text line.
  <a_page> returns the number of text lines per page.
  <div_fac> returns the divisor for the above ratios (usually 1).


Function returns information about printer resolution and banding
(i.e., the number of pins in a dot matrix printer).

Note: There has been some confusion about this function's operation.
      The above was tested with SpeedoGDOS 5.x

\#VDI Subopcode\# 5,24

See also \#VDI Printer Escapes\# and \#VDI Coordinates\#.
\end

screen( capsensitive("vs_palette") )
#include <vdi.h>

void vs_palette( int handle, int palette );

  <handle> is the \#VDI Handle\#.
  <palette> selects an IBM standard 4 color palette:
            0 = red, green, brown (default).
            1 = cyan, magenta, white


Function sets up an IBM standard color palette.
(Applies only to 4 color devices.)

\#VDI Subopcode\# 5,60

See also \#VDI Printer Escapes\#, \#vs_color\#(), \#Setpalette\#() and \#EsetPalette\#().
\end

screen( capsensitive("vqp_films") )
#include <vdi.h>

void vqp_films( int handle, char *file_names );

  <handle> is the \#VDI Handle\#.
  <film_names> is a buffer array[5][25] to return a list of film
               names (25 bytes each, blank padded).


Function returns a list of up to 5 film types that the driver is
capable of exposing.

(Applies only to GDOS Poloroid Palette Image Recorder.)

\#VDI Subopcode\# 5,91

See also \#VDI Poloroid Escapes\#.
\end

screen( capsensitive("vqp_state") )
#include <vdi.h>

void vqp_state( int handle, int *port, char *file_name,
                int *lightness, int *interlace, int *planes,
                int *indexes);

  <handle> is the \#VDI Handle\#.
  <port> returns the comm port (0 = first).
  <film_name> is a 25 byte buffer array used to return the current
              film name.
  <lightness> returns the exposure level (-3 to 3).
  <interlace> returns 0 for noninterlaced, or 1 for interlaced image.
  <planes> returns the number of color bit planes (1 to 4).
           1 = 2 colors, 2 = 4 colors, 3 = 8 colors, 4 = 16 colors.
  <indexes> is an int array[N][2] where N is the number of colors,
            which is used to return the color chart indexes.
            [0] returns 'A' ... 'H' (65...72).
            [1] returns '1' ... '9' (49...57).


Function returns the current settings for the Poloroid Palette Image
Recorder.

Each film comes with a chart showing the 72 possible colors, arranged
in columns A-H and rows 1-9.  Colors are defined in terms of the
ASCII values of the chart indexes.

\#VDI Subopcode\# 5,92

See also \#VDI Poloroid Escapes\#.
\end

screen( capsensitive("vsp_state") )
#include <vdi.h>

void vsp_state( int handle, int port, int file_num,
                int lightness, int interlace, int planes,
                int *indexes);

  <handle> is the \#VDI Handle\#.
  <port> is the comm port (0 = first).
  <film_name> is a 25 byte buffer array used to return the current
              film name.
  <lightness> is the exposure level (-3 to 3).
  <interlace> is 0 for noninterlaced, or 1 for interlaced images.
  <planes> is the number of color bit planes (1 to 4).
           1 = 2 colors, 2 = 4 colors, 3 = 8 colors, 4 = 16 colors.
  <indexes> is an int array[N][2] where N is the number of colors,
            containing the new  color chart indexes.
            [0] contains 'A' ... 'H' (65...72).
            [1] contains '1' ... '9' (49...57).


Function sets the parameters for the Poloroid Palette Image Recorder.

Each film comes with a chart showing the 72 possible colors, arranged
in columns A-H and rows 1-9.  Colors are defined in terms of the two
ASCII values for these chart indexes.

\#VDI Subopcode\# 5,93

See also \#VDI Poloroid Escapes\#.
\end

screen( capsensitive("vsp_save") )
#include <vdi.h>

void vsp_save( int handle );

  <handle> is the \#VDI Handle\#.


Function saves the current settings to disk (default settings).


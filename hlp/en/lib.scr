screen( "Window Element" )
Window Elements (\#Object Tree\# indexes for window frame)         <aes.h>
----------------------------------------------------------------------
W_BOX       IBOX     root object of tree
W_TITLE     IBOX     parent of title bar objects
W_CLOSER    BOXCHAR  close icon
W_NAME      BOXTEXT  mover bar (visible title bar)
W_FULLER    BOXCHAR  full size icon
W_INFO      BOXTEXT  info bar
W_DATA      IBOX     parent of remaining objects
W_WORK      IBOX     work area
W_SIZER     BOXCHAR  resize icon
W_VBAR      BOX      parent of vertical bar objects
W_UPARROW   BOXCHAR  up arrow
W_DNARROW   BOXCHAR  down arrow
W_VSLIDE    BOX      vertical scroll bar
W_VELEV     BOX      vertical slider
W_HBAR      BOX      parent of horizontal bar objects
W_LFARROW   BOXCHAR  left arrow
W_RTARROW   BOXCHAR  right arrow
W_HSLIDE    BOX      horizontal scroll bar
W_HELEV     BOX      horizontal slider

See also \#wind_set\#(), \#WF_COLOR\# and \#WF_DCOLOR\#.
\end

screen( "Resource File Data Types" )
Resource File Data Types - \#rsrc_gaddr\#()                        <aes.h>
----------------------------------------------------------------------
<type>       <index>      <addr>
------       -------      ------
R_TREE       tree         \#OBJECT\#*
R_OBJECT     object       \#OBJECT\#*
R_TEDINFO    tedinfo      \#TEDINFO\#*
R_ICONBLK    icon         \#ICONBLK\#*
R_BITBLK     image        \#BITBLK\#*
R_STRING     free string  char*
R_IMAGEDATA  free image   \#BITBLK\#*
R_OBSPEC     object       \#OBSPEC\#*
R_TEPTEXT    tedinfo      char**
R_TEPTMPLT   tedinfo      char**
R_TEPVALID   tedinfo      char**
R_IBPMASK    icon         int**
R_IBPDATA    icon         int**
R_IPBTEXT    icon         char**
R_FRSTR      free string  char**
R_FRIMG      free image   \#BITBLK\#**
\end

screen( "AES_LARGEFONT" )
AES_LARGEFONT
----------------------------------------------------------------------
\#appl_getinfo\#( 0, &point, &font_id, &ftype, &unused );

  <point> returns the AES large font size in points (1/72 inch).
  <font_id> returns the font id (see \#vst_font\#).
  <ftype> returns the font type (0 = system font, 1 = outline font)

Note: Implemented starting with \#AES Version\# 4.00

See also \#GEM.CNF\# and \#TEDINFO\#.
\end

screen( "AES_SMALLFONT" )
AES_SMALLFONT
----------------------------------------------------------------------
\#appl_getinfo\#( 1, &point, &font_id, &ftype, &unused );

  <point> returns the AES small font size in points (1/72 inch).
  <font_id> returns the font id (see \#vst_font\#).
  <ftype> returns the font type (0 = system font, 1 = outline font)

Note: Implemented starting with \#AES Version\# 4.00

See also \#GEM.CNF\# and \#TEDINFO\#.
\end

screen( "AES_SYSTEM" )
AES_SYSTEM
----------------------------------------------------------------------
\#appl_getinfo\#( 2, &rez, &ncolors, &icon, &rsc );

  <rez> returns the (hardware dependent) screen resolution number.
  <ncolors> returns the number of colors.
  <icon> returns 1 if color icons are supported, 0 otherwise.
  <rsc> returns 1 if the extended resource file format is support, 
        0 otherwise.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "AES_LANGUAGE" )
AES_LANGUAGE
----------------------------------------------------------------------
\#appl_getinfo\#( 3, &language, &unused, &unused, &unused );

  <language> returns the AES language code:
             0 = English
             1 = German
             2 = French
             4 = Spanish
             5 = Italian
             6 = Swedish

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "AES_PROCESS" )
AES_PROCESS
----------------------------------------------------------------------
\#appl_getinfo\#( 4, &preemptive, &find, &search, &rcfix );

  <preemptive> returns 1 if using pre-emptive multitasking,
               0 otherwise.
  <find> returns 1 if \#appl_find\#() can convert between AES and MiNT
         id's, 0 otherwise.
  <search> returns 1 if \#appl_search\#() is implemented, 0 otherwise.
  <rcfix> returns 1 if \#rsrc_rcfix\#() is implemented, 0 otherwise.

Note: Implemented starting with \#AES Version\# 4.01
\end

screen( "AES_INQUIRE" )
AES_INQUIRE
----------------------------------------------------------------------
\#appl_getinfo\#( 6, &read, &get, &bar1, &bar2 );

  <read> returns 1 if \#appl_read\#() implements ap_rid = -1, 0 otherwise.
  <get> returns 1 if \#shel_get\#() implements len = -1, 0 otherwise.
  <bar1> returns 1 if \#menu_bar\#() implements show = -1, 0 otherwise.
  <bar2> returns 1 if \#menu_bar\#() implements show = 1, 0 otherwise.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "AES_MOUSE" )
AES_MOUSE
----------------------------------------------------------------------
\#appl_getinfo\#( 8, &save, &multi, &unused, &unsued );

  <save> returns 1 if \#graf_mouse\#() implements form = 258 to 260,
         0 otherwise.
  <multi> returns 1 if AES supports multiple application dependent
          mouse forms.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "AES_MENU" )
AES_MENU
----------------------------------------------------------------------
\#appl_getinfo\#( 9, &submenu, &popup, &scroll, &select );

  <submenu> returns 1 if sub-menus are supported, 0 otherwise.
  <popup> returns 1 if pop up menus are supported, 0 otherwise.
  <scroll> returns 1 if scrollable menus are supported, 0 otherwise.
  <select> returns 1 if the \#MN_SELECTED\# message uses words 5-7,
           0 otherwise.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "AES_SHELL" )
AES_SHELL
----------------------------------------------------------------------
\#appl_getinfo\#( 10, &mode, &cancle, &now, &cancel );

  <mode> returns information about \#shel_write\#() mode:
         The low byte contains the highest legal value.
         The high byte indicates which mode bits are supported.
  <cancel> returns 1 if \#shel_write\#() using mode = 0 cancels the
           previous call, 0 otherwise.
  <now> returns 1 if \#shel_write\#() using mode = 1 launches a
        concurrent application, or 0 it it waits until the current
        application exits.
  <argv> returns 1 if ARGV style parameters passing is supported,
         0 otherwise.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "AES_WINDOW" )
AES_WINDOW
----------------------------------------------------------------------
\#appl_getinfo\#( 11, &wf, &unused, &gagets, &unused );

  <wf> returns bit flags showing which options for \#wind_get\#() and/or
       \#wind_set\#() are supported:
          1 = \#WF_TOP\# get returns next window handle.
          2 = \#WF_NEWDESK\# get supported
          4 = \#WF_COLOR\# get/set supported
          8 = \#WF_DCOLOR\# get/set supported
       0x10 = \#WF_OWNER\# get/set supported
       0x20 = \#WF_BEVENT\# get/set supported
       0x40 = \#WF_BOTTOM\# get supported

  <gadgets> returns bit flags showing which window gadgets are
            supported:
            1 = iconifier
            2 = bottomer
            4 = shift-click bottomer
            8 = hot closer

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "AES_MESSAGE" )
AES_MESSAGE
----------------------------------------------------------------------
\#appl_getinfo\#( 12, &wm, &unused, &unused, &unused );

  <wm> returns bit flags showing which \#Messages\# are supported:
          1 = WM_NEWTOP
          2 = WM_UNTOPPED
          4 = WM_ONTOP
          8 = AP_TERM
       0x10 = SHUT_COMPLETED & RESCHG_COMPLETED
       0x20 = CH_EXIT

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "AES_OBJECT" )
AES_OBJECT
----------------------------------------------------------------------
\#appl_getinfo\#( 13, &obj3d, &unused, &gdos, &unused );

  <obj3d> returns 1 if 3D objects are supported, 0 otherwise.
  <gdos> returns 1 if AES supports GDOS fonts, 0 otherwise.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "AES_FORM" )
AES_FORM
----------------------------------------------------------------------
\#appl_getinfo\#( 14, &fly, &keytab, &cursor, &unused );

  <fly> returns 1 if flying dialogs are supported, 0 otherwise.
  <keytab> returns 1 if keyboard tables are supported, 0 otherwise.
  <cursor> returns 1 if \#objc_edit\#() returns the last cursor position,
           0 otherwise.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "SWM_LAUNCH" )
SWM_LAUNCH
----------------------------------------------------------------------
id = \#shel_write\#( flags, 0, iscr, cmd, tail );

  <flags> are the bit flags:
          0x100 = set RAM limit
          0x200 = set process priority
          0x400 = set default directory
          0x800 = set environment string
  <isgr> is not used.
  <iscr> selects to parse the command string and use ARGV (1)
         or not (0).
  <cmd> points to the process filename,
        or a \#SHELW\# structure when <flags> != 0
  <tail> points to the command string.


Function launches a child process using the filename extension
(PRG, TOS, TPP or ACC) to determine the type of process.

It returns the application id of the child process, or 0 on a error.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "SWM_LAUNCHNOW" )
SWM_LAUNCHNOW
----------------------------------------------------------------------
id = \#shel_write\#( 1 + flags, iscr, iscr, cmd, tail );

  <flags> are the bit flags:
          0x100 = set RAM limit
          0x200 = set process priority
          0x400 = set default directory
          0x800 = set environment string
  <isgr> is 1 for a GEM application, or 0 for a TOS application.
  <iscr> selects to parse the command string and use environment
         variable ARGV (1) or not (0).
  <cmd> points to the process filename,
        or a \#SHELW\# structure when <flags> != 0
  <tail> points to the command string.


Function launches a child process and waits for it to complete.

It returns the application id, or 0 on an error.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "SWM_LAUNCHACC" )
SWM_LAUNCHACC
----------------------------------------------------------------------
id = \#shel_write\#( 3 + flags, 1, iscr, cmd, tail );

  <flags> are the bit flags:
          0x100 = set RAM limit
          0x200 = set process priority
          0x400 = set default directory
          0x800 = set environment string
  <iscr> selects to parse the command string and use environment
         variable ARGV (1) or not (0).
  <cmd> points to the process filename,
        or a \#SHELW\# structure when <flags> != 0
  <tail> points to the command string.


Function launches a GEM desk accessory.

It returns the accessory id, or 0 on an error.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "SWM_SHUTDOWN" )
SWM_SHUTDOWN
----------------------------------------------------------------------
\#shel_write\#( 4, 0, iscr, 0L, 0L );

  <iscr> is the type of shutdown requested:
         0 = abort shutdown (originator only)
         1 = partial shutdown
         2 = complete shutdown (accessories too)


Function requests total control of the computer.
Other processes will be sent \#AP_TERM\# messages.

Note: Implemented starting with \#AES Version\# 4.00

See also \#SHUT_COMPLETED\#.
\end

screen( "SWM_REZCHANGE" )
SWM_REZCHANGE
----------------------------------------------------------------------
\#shel_write\#( 5, rez, 0, 0L, 0L );

  <rez> is the VDI screen device id corresponding to the desired
        resolution:
        2 = ST Low Rez
        3 = ST Med Rez
        4 = ST High Rez
        5-9 = undocumented resolutions


Function requests a change in resolution.
Other processes will be sent \#AP_TERM\# messages.

Note: Implemented starting with \#AES Version\# 4.00

See also \#RESCH_COMPLETED\#.
\end

screen( "SWM_BROADCAST" )
SWM_BROADCAST
----------------------------------------------------------------------
\#shel_write\#( 7, 0, 0, (char*) messag, 0L );

  <messag> is an 8 element int array containing the message.


Function sends a message to every process.

Note: Implemented starting with \#AES Version\# 4.00

See also \#appl_write\#().
\end

screen( "SWM_ENVIRON" )
SWM_ENVIRON
----------------------------------------------------------------------
\#shel_write\#( 8, mode, len, buffer, 0L );

  <mode> is the operation mode:
         0 = return value is length of current environment string.
         1 = add, modify, or delete environment variable in <buffer>.
             ("PATH=" will delete variable PATH)
         2 = copy <len> bytes from the environment string into
             <buffer>.  Return value is number of bytes left.
  <len> = max size of buffer (<mode> = 2 only).
  <buffer> is a NULL terminated string (<mode> = 1), or returns the
           environment string (<mode> = 2).


Function modifies or copies the environment string.

Note: Implemented starting with \#AES Version\# 4.00

See also \#shel_envrn\#().
\end

screen( "SWM_NEWMSG" )
SWM_NEWMSG
----------------------------------------------------------------------
\#shel_write\#( 9, 1, 0, 0L, 0L );


Function informs AES that it supports the \#AP_TERM\# message.

Note: Implemented starting with \#AES Version\# 4.00
\end

screen( "SWM_AESMSG" )
SWM_AESMSG
----------------------------------------------------------------------
\#shel_write\#( 10, 0, 0, (char*) messag, 0L );

  <messag> is an 8 element int array containing the message.


Function sends a message to AES.

Note: Implemented starting with \#AES Version\# 4.00

See also \#AP_TFAIL\# and \#appl_write\#().
\end

screen( "SHELW" )
typedef struct
 {
  char *newcmd;       /* -> program pathname             */
  long ramlimit;      /* maximum memory size for process */
  long priority;      /* child process priority level    */
  char *defdir;       /* -> default directory pathname   */
  char *env;          /* -> environment string           */
 } SHELW;

See also \#SWM_LAUNCH\#, \#SWM_LAUNCHNOW\# and \#SWM_LAUNCHACC\#.
\end

screen( "GEM.CNF" )
GEM.CNF File Format
----------------------------------------------------------------------
Environment variables are set using the 'setenv' command:

  setenv PATH=C:

System variables are set using '=':

  AE_FONTID=1001         ;use Speedo Font 1001 for AES text
  AE_PNTSIZE=9           ;set font point size
  AE_SREDRAW=1           ;send redraw message when application starts
  AE_TREDRAW=1           ;send redraw message when application ends

Implemented starting with \#AES Version\# 4.1
\end

screen( "Application" )
Application Library                                            <aes.h>
----------------------------------------------------------------------
\#appl_exit\#     - must be called before termination
\#appl_find\#     - return id of another application (given name)
\#appl_getinfo\#  - return info about AES features
\#appl_init\#     - must be called before any other \#AES\# or \#VDI\# function
\#appl_read\#     - read message pipe
\#appl_search\#   - list all processes and id's
\#appl_tplay\#    - execute previously recorded events
\#appl_trecord\#  - record user events
\#appl_write\#    - write to message pipe

See also \#Event\#, \#Menu\#, \#Object\#, \#Form\#, \#Graphics\#, \#Window\#, \#Resource\#,
         \#Scrap\#, \#Shell\# and \#File Select\#.
\end

screen( "Event" )
Event Library                                                  <aes.h>
----------------------------------------------------------------------
\#evnt_button\# - wait for mouse button event
\#evnt_dclick\# - get/set double click speed
\#evnt_keybd\#  - wait for keyboard event
\#evnt_mesag\#  - wait for message event (see \#Messages\#)
\#evnt_mouse\#  - wait for mouse movement event
\#evnt_timer\#  - wait for GEM timer

\#evnt_multi\# or \#EvntMulti\# - wait for multiple events

Note: Events which occur while the program is busy will be stored in a
      pipe until the next call.

See also \#Application\#, \#Menu\#, \#Object\#, \#Form\#, \#Graphics\#, \#Window\#, \#Resource\#,
         \#Scrap\#, \#Shell\# and \#File Select\#.
\end

screen( "Menu" )
Menu Library                                                   <aes.h>
----------------------------------------------------------------------
\#menu_attach\#    - attach/change/remove sub-menu
\#menu_bar\#       - display/erase menu bar
\#menu_icheck\#    - display/erase check marks for menu item
\#menu_ienable\#   - enable/disable menu item
\#menu_istart\#    - re-align sub-menu
\#menu_popup\#     - display/process popup menu
\#menu_settings\#  - set parameters for popup & scrollable menus
\#menu_register\#  - insert accessory into menu
\#menu_text\#      - change text of menu item
\#menu_tnormal\#   - display title in normal or reverse video

A drop-down menu is defined by a special type of \#Object Tree\#.
The root must be a G_IBOX object, its children are G_TITLE objects,
and their children are selectable G_STRING objects.

The width and height of the G_TITLE object defines the size of the
drop-down menu outline.  Its children should totally fill this space.

The left-most title must include dummy strings for the accessory items
to be inserted.  These will not show up unless used.

Selecting an item from a drop-down menu causes a message event
(see \#Messages\#).

If a sub-menu is attached to a menu item, it will appear whenever the
mouse passes over that item.  Selecting a sub-menu item produces an
extended \#MN_SELECTED\# message.

See also \#Application\#, \#Event\#, \#Object\#, \#Form\#, \#Graphics\#, \#Window\#, \#Resource\#,
         \#Scrap\#, \#Shell\# and \#File Select\#.
\end

screen( "Object" )
Object Library                                                 <aes.h>
----------------------------------------------------------------------
\#objc_add\#     - add an object to a tree
\#objc_change\#  - change object state (and redraw)
\#objc_delete\#  - remove an object from a tree
\#objc_draw\#    - display all or part of an object tree
\#objc_edit\#    - perform formatted text edit operations
\#objc_find\#    - locate object under mouse (given x,y location)
\#objc_offset\#  - return screen coordinates for object
\#objc_order\#   - change position of child object

See \#OBJECT\#, \#Object Tree\#, \#Object Type\#, \#Object Flag\# and \#Object State\#.

See also \#Application\#, \#Event\#, \#Menu\#, \#Form\#, \#Graphics\#, \#Window\#, \#Resource\#,
         \#Scrap\#, \#Shell\# and \#File Select\#.
\end

screen( "Form" )
Form Library                                                  <aes.h>
----------------------------------------------------------------------
\#form_alert\#  - special purpose dialog box
\#form_center\# - center object tree and return clipping rectangle
\#form_dial\#   - reserve/release screen area
\#form_do\#     - execute dialog box (wait for EXIT or TOUCHEXIT)
\#form_error\#  - special purpose dialog box for TOS errors
\#form_keybd\#  - handle keyboard event
\#form_button\# - handle mouse button event

See \#Dialog Box\# and \#Form Alert Format\#.

See also \#Application\#, \#Event\#, \#Menu\#, \#Object\#, \#Graphics\#, \#Window\#, \#Resource\#,
         \#Scrap\#, \#Shell\# and \#File Select\#.
\end

screen( "Graphics" )
Graphics Library                                               <aes.h>
----------------------------------------------------------------------
\#graf_dragbox\#    - moves a box using the mouse
\#graf_growbox\#    - draw an expanding box
\#graf_handle\#     - return \#VDI\# handle for screen workstation
\#graf_mkstate\#    - return location and button status of mouse
\#graf_mouse\#      - change mouse form
\#graf_movebox\#    - draw a moving box
\#graf_rubberbox\#  - change a boxes size & shape using the mouse
\#graf_shrinkbox\#  - draw a shrinking box
\#graf_slidebox\#   - moves a box inside a boundary using the mouse
\#graf_watchbox\#   - change object state when mouse is over it

See also \#Application\#, \#Event\#, \#Menu\#, \#Object\#, \#Form\#, \#Window\#, \#Resource\#,
         \#Scrap\#, \#Shell\# and \#File Select\#.
\end

screen( "Window" )
Window Library                                                 <aes.h>
----------------------------------------------------------------------
\#wind_calc\#   - compute inner/outer window coordinates
\#wind_close\#  - closes an open window
\#wind_create\# - allocate window and return handle
\#wind_delete\# - free handle for a closed window
\#wind_find\#   - return handle of window under mouse (given x,y)
\#wind_get\#    - return information about window
\#wind_new\#    - closes and deletes all windows
\#wind_open\#   - opens a window (displays the window frame)
\#wind_set\#    - set window characteristics
\#wind_update\# - inform GEM that window contents are being redrawn

These functions are used to define the size, shape and features of a
window (everything except the contents).  Clicking or dragging various
window features with the mouse causes message events (see \#Messages\#).

See also \#Application\#, \#Event\#, \#Menu\#, \#Object\#, \#Form\#, \#Graphics\#, \#Resource\#,
         \#Scrap\#, \#Shell\# and \#File Select\#.
\end

screen( "Resource" )
Resource Library                                               <aes.h>
----------------------------------------------------------------------
\#rsrc_load\#  - load resource file into memory
\#rsrc_free\#  - free memory
\#rsrc_gaddr\# - return address of specified data structure
\#rsrc_saddr\# - replace a data structure
\#rsrc_obfix\# - convert object to screen coordinates
\#rsrc_rcfix\# - initialize resource file data (in RAM)

Resource files are created by a resource file editor program (not
included with Pure C).  They consists of predefined object trees,
all of the data structures needed to define these object trees, free
strings and free images (strings and \#BITBLK\#s not part of an object
tree).  These editors generally provide a C language header file which
defines named tree and object indexes.

A resource file begins with a \#RSHDR\# data structure, which contains
pointers to arrays of various data structures (relative to the start
of the file).  Pointers inside the data structures also contain the
location relative to the start of the file.

The x, y, width and height coordinates of objects are coded using the
low byte for the number of characters and the high byte for a signed
offset in pixels.  These are converted into screen coordinates when
loaded.

See also \#Application\#, \#Event\#, \#Menu\#, \#Object\#, \#Form\#, \#Graphics\#, \#Window\#,
         \#Scrap\#, \#Shell\# and \#File Select\#.
\end

screen( "Scrap" )
Scrap Library                                                  <aes.h>
----------------------------------------------------------------------
\#scrp_read\#  - read clipboard
\#scrp_write\# - write clipboard (replaces old contents)

The clipboard is accessible to all applications/accessories.  It is
normally used to keep the directory pathname for scrap files:

SCRAP.TXT - ASCII text (CR/LF at end of each line)
SCRAP.ASC - ASCII text (CR/LF at end of each paragraph)
SCRAP.RTF - Microsoft Rich Text Format
SCRAP.1WP - First Word Plus format text
SCRAP.WP  - Word Perfect format text
SCRAP.DIF - Data Interchange Format (spreadsheet/database)
SCRAP.GEM - Graphics Metafile
SCRAP.IMG - Bit Image
SCRAP.TIF - Tagged Interchange Format (graphics image)
SCRAP.EPS - Encapsulated Postscript
SCRAP.CVG - Calamus Vector Graphic

The format SHOULD be to end the path with a '\\', as in "C:\\CLIPBRD\\".
However, there is no guarantee that will be returned by \#scrp_read\#().

See also \#Application\#, \#Event\#, \#Menu\#, \#Object\#, \#Form\#, \#Graphics\#, \#Window\#,
         \#Resource\#, \#Shell\# and \#File Select\#.
\end

screen( "Shell" )
Shell Library                                                  <aes.h>
----------------------------------------------------------------------
\#shel_envrn\#  - search for environment parameter
\#shel_find\#   - search subdirectories for filename
\#shel_get\#    - read from AES internal buffer
\#shel_put\#    - write to AES internal buffer
\#shel_read\#   - return command line
\#shel_write\#  - terminate this application and run another

See also \#Application\#, \#Event\#, \#Menu\#, \#Object\#, \#Form\#, \#Graphics\#, \#Window\#,
         \#Resource\#, \#Scrap\# and \#File Select\#.
\end

screen( "File Select" )
File Selector Library                                          <aes.h>
----------------------------------------------------------------------
\#fsel_input\#   - standard dialog box to search for a file
\#fsel_exinput\# - uses supplied title for dialog box

See also \#Application\#, \#Event\#, \#Menu\#, \#Object\#, \#Form\#, \#Graphics\#, \#Window\#,
         \#Resource\#, \#Scrap\# and \#Shell\#.
\end

screen( capsensitive("vq_aes") )
#include <aes.h>

int vq_aes( void );


Function returns 0 normally, or -1 if \#AES\# is not available
(e.g. when a program in the AUTO folder is run at boot time).

See also \#Puntaes\#().
\end

screen( capsensitive("_crystal") )
#include <aes.h>

void _crystal( \#AESPB\# *aespb );

  <aespb> is used to pass all input and output parameters.
          It can be initialized as a global or static variable:

\#AESPB\# aespb = { _GemParBlk.contrl, _GemParBlk.global,
                _GemParBlk.intin, _GemParBlk.intout,
                _GemParBlk.addrin, _GemParBlk.addrout };

(You don't HAVE to use the arrays in \#_GemParBlk\#.)


Function can be used to create new AES bindings.  The opcode and
numbers of input and output parameters are stored in aespd.contrl[].
The aespd.global array is initialized by \#appl_init\#().

You will also need to know the exact order in which the input and
output parameters are packed into the arrays.

See also \#AES Control Array\# and \#AES Global Array\#.
\end

screen( capsensitive("appl_init") )
#include <aes.h>

int appl_init( void );


Function must be called before any other \#AES\# or \#VDI\# function.
It initializes the arrays in \#GEMPARBLK\# used for parameter passing.

It returns the application id.

\#AES Opcode\# 10

See also \#Application\# and \#menu_register\#().
\end

screen( capsensitive("appl_exit") )
#include <aes.h>

int appl_exit( void );


Function must be called before the application terminates.
It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 19

See also \#Application\#.
\end

screen( capsensitive("appl_read") )
#include <aes.h>

int appl_read( int ap_rid, int ap_rlength, void *ap_rpbuff );

  <ap_rid> is the application id for the message pipe.
  <ap_rlength> is the number of bytes to read.
  <ap_rpbuff> is the input buffer to be filled.


Function reads a message, possibly from another application.
It returns a positive number normally, or 0 on an error.

\#AES Opcode\# 11

See also \#Application\# and \#evnt_mesag\#().
\end

screen( capsensitive("appl_write") )
#include <aes.h>

int appl_write( ap_wid, int ap_wlength, void *ap_wpbuff );

  <ap_wid> is the application id to be sent the message.
  <ap_wlength> is the number of bytes to write.
  <ap_wpbuff> is the message to be written.


Function writes a message to another application.
It returns a positive number normally, or 0 on an error.

Note: The message will be sent 'as is', which may or may not conform
      to the standard message format (see \#Messages\#).

\#AES Opcode\# 12

See also \#Application\# and \#evnt_mesag\#().
\end

screen( capsensitive("appl_find") )
#include <aes.h>

int appl_find( const char *ap_fname );

  <ap_fname> is a NULL terminated string containing the filename of
             the application whose id is sought.
             It must be at least 8 bytes long (pad blanks if needed).


Function returns the application id for an application given its
filename, or -1 if no such application is currently running.

*** After \#AES Version\# 4.00 ***

int appl_find(0L);

Function returns the application id for the current application.

*** \#MiNT\# Extensions ***

int appl_find( (char*) (0xFFFF0000L | (int) id) );

  <id> is the MiNT process id.

Function returns the application id for an application given its
process id.


int appl_find( (char*) (0xFFFE0000L | (int) id) );

  <id> is the application process id.

Function returns the process id for an application given its
application id.

\#AES Opcode\# 13

See also \#Application\# and \#AES_PROCESS\#.
\end

screen( capsensitive("appl_tplay") )
#include <aes.h>

int appl_tplay( void *ap_tpmem, int ap_tpnum, int ap_tpscale );

  <ap_tpmem> contains a previously recorded set of user events.
  <ap_tpnum> is the number of user events to play back.
  <ap_tpscale> is a time scale factor (1 - 10,000) which determines
               how fast the playback occurs (100 is 'normal').


Function replays a set of previously recorded user events.
It always returns 1.

\#AES Opcode\# 14

See also \#Application\#.
\end

screen( capsensitive("appl_trecord") )
#include <aes.h>

int appl_trecord( void *ap_trmem, int ap_trcount );

  <ap_trmem> is a buffer to be filled with user events.
             It requires 6 bytes for each event.
  <ap_trcount> is the maximum number of events to record.


Function records a set of user events.
It returns the number of events recorded.

There doesn't seem to be any way to terminate the recording process
until <ap_trcount> events occur, so it would probably be best to
record them one event at a time.

The first 2 bytes for each event contains a code for the type of
event: 0=timer, 1=button, 2=mouse and 3=keyboard.
The remaining 4 bytes describe the results of the event:
  timer    - elapsed time in milliseconds (4 bytes)
  button   - number of clicks (2 bytes), button state (2 bytes)
  mouse    - y coordinate (2 bytes), x coordinate (2 bytes)
  keyboard - keyboard state (2 bytes), character (2 bytes)

\#AES Opcode\# 15

See also \#Application\# and \#Event\#.
\end

screen( capsensitive("appl_search") )
#include <aes.h>

int appl_search( int ap_smode, char *ap_sname, int *ap_stype,
                 int *ap_sid );

  <ap_smode> is the search mode (0 = first, 1 = next).
  <ap_sname> is a 9 byte buffer to return the filename (no extension).
  <ap_stype) returns the type of process (bit flags):
             1 = system
             2 = application
             4 = accessory
             8 = shell (desktop)
  <ap_id> returns the application id.


Function can be used to generate a list of all currently running
processes.

It returns 1 normally, and 0 when there are no more processes.

Note: Implemented starting with \#AES Version\# 4.0

\#AES Opcode\# 18

See also \#Application\# and \#AES_PROCESS\#.
\end

screen( capsensitive("appl_getinfo") )
#include <aes.h>

int appl_getinfo( int ap_gtype, int *ap_gout1, int *ap_gout2,
                  int *ap_gout3, int *ap_gout4 );

  <ap_gtype> is the type of information to be returned:
              0 = \#AES_LARGEFONT\#
              1 = \#AES_SMALLFONT\#
              2 = \#AES_SYSTEM\#
              3 = \#AES_LANGUAGE\#
              4 = \#AES_PROCESS\#
              6 = \#AES_INQUIRE\#
              8 = \#AES_MOUSE\#
              9 = \#AES_MENU\#
             10 = \#AES_SHELL\#
             11 = \#AES_WINDOW\#
             12 = \#AES_MESSAGE\#
             13 = \#AES_OBJECT\#
             14 = \#AES_FORM\#

  The meaning of the remaining arguments depends on <ap_gtype>.


Function returns information about AES features.
It returns 1 normally, or 0 on an error.

Note: Implemented starting with \#AES Version\# 3.40

\#AES Opcode\# 130

See also \#Application\#.
\end

screen( capsensitive("evnt_keybd") )
#include <aes.h>

int evnt_keybd( void );


Function waits for a keyboard event (any key to be pressed).
It returns the ASCII character for the key pressed in the low byte,
and the keyboard scan code in the high byte.

\#AES Opcode\# 20

See also \#Event\# and \link("%%GLOBAL%%")Scan Codes\#.
\end

screen( capsensitive("evnt_button") )
#include <aes.h>

int evnt_button( int bclicks, int bmask, int bstate,
                 int *mx, int *my, int *button, int *kstate );

  <bclicks> is the maximum number of clicks allowed (1 or 2).
            Adding 0x100 inverts the return logic.
  <bmask> is a bit mask applied to the mouse state.
  <bstate> is the desired mouse button state (after mask).
  <mx> returns the x coordinate of the mouse.
  <my> returns the y coordinate of the mouse.
  <button> returns the mouse button state:
           0 = both buttons up
           1 = left button down
           2 = right button down
           3 = both buttons down
  <kstate> returns the keyboard state (bit flags):
           K_RSHIFT = right Shift
           K_LSHIFT = left Shift
           K_CNTL   = Control
           K_ALT    = Alternate


Function waits until (button & bmask == bstate):
 bmask = bstate = 1 will wait until the left button is down.
 bmask = 1 and bstate = 0 will wait until the left button is up.
 bmask = bstate = 3 will wait until both buttons are down.

Using bclicks = 0x101 or 0x102 (button & bmask != bstate):
 bmask = 3 and bstate = 0 will wait until either button is down.

It returns the number of clicks performed in the allowed time.

Note: Increasing bclicks increases the delay between the button click
      and the function return.

\#AES Opcode\# 21

See also \#Event\# and \#graf_mkstate\#().
\end

screen( capsensitive("evnt_mouse") )
#include <aes.h>

int evnt_mouse( int moflags, int x, int y, int width, int height,
                int *mx, int *my, int *button, *kstate );

  <moflags> selects return on entry (0) or exit (1) of rectangle.
  <x> is the left edge of the rectangle (screen coordinates).
  <y> is the top edge of the rectangle (screen coordinates).
  <width> is the width of the rectangle (in pixels).
  <height> is the height of the rectangle (in pixels).
  <mx> returns the x coordinate of the mouse.
  <my> returns the y coordinate of the mouse.
  <button> returns the mouse button state:
           0 = both buttons up
           1 = left button down
           2 = right button down
           3 = both buttons down
  <kstate> returns the keyboard state (bit flags):
           K_RSHIFT = right Shift
           K_LSHIFT = left Shift
           K_CNTL   = Control
           K_ALT    = Alternate


Function waits for a mouse pointer to enter (or leave) a given
rectangle on the screen.  It always returns 1.

\#AES Opcode\# 22

See also \#Event\# and \#graf_mkstate\#().
\end

screen( capsensitive("evnt_mesag") )
#include <aes.h>

int evnt_mesag( int *mgpbuff );

  <mgpbuff> is a 16 byte buffer (8 element int array) to be filled
            with the message.  For messages longer than 16 bytes,
            use \#appl_read\#() to get the rest.


Function waits for a message event (see \#Messages\#).
It always returns 1.

\#AES Opcode\# 23

See also \#Event\# and \#appl_write\#().
\end

screen( capsensitive("evnt_timer") )
#include <aes.h>

int evnt_timer( int locount, int hicount );

  <locount> + (<hicount> * 65536L) = time delay in msec.


Function waits for a specified length of time.
It always returns 1.

\#AES Opcode\# 24

See also \#Event\# and \#Xbtimer\#().
\end

screen( capsensitive("evnt_multi") )
#include <aes.h>

int evnt_multi( int evflags,
  int bclicks, int bmask, int bstate,
  int m1flags, int m1x, int m1y, int m1width, int m1height,
  int m2flags, int m2x, int m2y, int m2width, int m2height,
  int *mgpbuff, int locount, int hicount,
  int *mx, int *my, int *button, int *kstate,
  int *kreturn, int *breturn );

  <evflags> is used to select which events to process:
            MU_KEYBD  for keyboard events (see \#evnt_keybd\#)
            MU_BUTTON for mouse button events (see \#evnt_button\#)
            MU_M1     for mouse event rectangle #1 (see \#evnt_mouse\#)
            MU_M2     for mouse event rectangle #2 (ditto)
            MU_MESAG  for message events (see \#evnt_mesag\#)
            MU_TIMER  for timer events (see \#evnt_timer\#)
      (Flags can be combined using logical or.)

  <bclicks> is the maximum number of clicks allowed (1 or 2).
  <bmask> is a bit mask applied to the mouse state.
  <bstate> is the desired mouse button state (after mask).

  <m1flags> selects return on entry (0) or exit (1) of rectangle #1.
  <m1x> is the left edge of rectangle #1 (screen coordinates).
  <m1y> is the top edge of rectangle #1 (screen coordinates).
  <m1width> is the width of rectangle #1 (in pixels).
  <m1height> is the height of rectangle #1 (in pixels).

  <m2flags> selects return on entry (0) or exit (1) of rectangle #2.
  <m2x> is the left edge of rectangle #2 (screen coordinates).
  <m2y> is the top edge of rectangle #2 (screen coordinates).
  <m2width> is the width of rectangle #2 (in pixels).
  <m2height> is the height of rectangle #2 (in pixels).

  <mgpbuff> returns a message event.

  <locount> + (<hicount> * 65536L) = timer event delay in msec.

  <mx> returns the x coordinate of the mouse.
  <my> returns the y coordinate of the mouse.
  <button> returns the mouse button state:
           0 = both buttons up
           1 = left button down
           2 = right button down
           3 = both buttons down
  <kstate> returns the keyboard state (bit flags):
           K_RSHIFT = right Shift
           K_LSHIFT = left Shift
           K_CNTL   = Control
           K_ALT    = Alternate
  <kreturn> returns the ASCII character for a key event in
            the low byte, and the keyboard scan code in the high byte.
  <breturn> returns the number of mouse button clicks
            performed in the allowed time.


Function waits for any combination of selected events.
It returns the bit flags for ALL selected events which occurred.

Do NOT test for events using a \link("%%GLOBAL%%")switch\# statement, since one call
can return multiple events.

Note: One can include a timer event with 0 delay to see if there are
      any events waiting to be processed.

\#AES Opcode\# 25

See also \#Event\# and \link("%%GLOBAL%%")Scan Codes\#.
\end

screen( capsensitive("EvntMulti") )
#include <aes.h>

int EvntMulti( \#EVENT\# *evnt_struct );

  <evnt_struct> points to a data structure containing all of the
                parameters used by \#evnt_multi\#().


Function waits for any combination of selected events.
It returns the bit flags for ALL selected events which occurred.

EvntMulti() is simply an alternate binding for \#evnt_multi\#() which
has less overhead associated with the parameter passing.
(It runs faster.)

\#AES Opcode\# 25

See also \#Event\#.
\end

screen( capsensitive("evnt_dclick") )
#include <aes.h>

int evnt_dclick( int dnew, int dgetset );

  <dnew> is the new double-click speed (0 - 4):
         0 = slowest speed
         4 = fastest speed
  <dgetset> selects whether to return the old speed (0) or set the
            speed to <dnew> (1).


Function gets or sets the double-click speed.
It returns the current speed (new speed if set).

\#AES Opcode\# 26

See also \#Event\#.
\end

screen( capsensitive("menu_bar") )
#include <aes.h>

int menu_bar( \#OBJECT\# *tree, int show );


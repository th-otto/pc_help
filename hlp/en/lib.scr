screen( capsensitive("Pwaitpid") )
#include <tos.h>

long Pwaitpid( int pid, int flag, long *rusage );

  <pid> is the process ID of the child process (if positive), or
        -1 for any child processes, or
        0 for any child with the same group ID as the parent, or
        -gid for any child with group ID 'gid'.

  <flag> is a bit mask:
         0x1 = return immediately.
         0x2 = include terminated processes.

  <rusage> is an array used to return info about stopped processes,
           or NULL:
           [0] = number of milliseconds used by code.
           [1] = number of milliseconds used by \#kernel\#.


Function (optionally) waits for a child process to be stopped (or
terminated) and returns execution times.

It returns the process ID of the child in the left 16 bits and the
exit code in the right 16 bits, or 0 if no child is currently
stopped (see <flag>).

  0xnn00 = exit code for process stopped by signal 'nn'
  0xnn7F = exit code for process terminated by signal 'nn'

\#MiNT Opcode\# 313

Note: Implemented starting with \#MiNT Version\# 0.96

See also \#MiNT\# and \#Pwait3\#().
\end

screen( "Fcntl Command Code" )
\#Fcntl\#() Command List
----------------------------------------------------------------------
Files:
       0 = \#F_DUPFD\#            4 = \#F_GETLK\#       0x4601 = \#FIONREAD\#
       1 = \#F_GETFD\#            5 = \#F_SETLK\#       0x4602 = \#FIONWRITE\#
       2 = \#F_SETFD\#            7 = \#F_SETLKW\#
       3 = \#F_GETFL\#       0x4600 = \#FSTAT\#

Shared Memory:
  0x4E00 = \#SHMGETBLK\#     0x4E01 = \#SHMSETBLK\#

Processes:
  0x5001 = \#PPROCADDR\#     0x5005 = \#PGETFLAGS\#     0x5009 = \#PTRACEFLOW\#
  0x5002 = \#PBASEADDR\#     0x5006 = \#PTRACESFLAGS\#  0x500A = \#PTRACESTEP\#
  0x5003 = \#PCTXTSIZE\#     0x5007 = \#PTRACEGFLAGS\#  0x500C = \#PLOADINFO\#
  0x5004 = \#PSETFLAGS\#     0x5008 = \#PTRACEGO\#

Terminals:
  0x5400 = \#TIOCGETP\#      0x540A = \#TIOCSTART\#     0x5416 = \#TIOCGFLAGS\#
  0x5401 = \#TIOCSETP\#      0x540B = \#TIOCGWINSZ\#    0x5417 = \#TIOCSFLAGS\#
  0x5402 = \#TIOCGETC\#      0x540C = \#TIOCSWINSZ\#    0x6300 = \#TCURSOFF\#
  0x5403 = \#TIOCSETC\#      0x540D = \#TIOCGXKEY\#     0x6301 = \#TCURSON\#
  0x5404 = \#TIOCGLTC\#      0x540E = \#TIOCSXKEY\#     0x6302 = \#TCURSBLINK\#
  0x5405 = \#TIOCSLTC\#      0x5412 = \#TIOCIBAUD\#     0x6303 = \#TCURSSTEADY\#
  0x5406 = \#TIOCGPGRP\#     0x5413 = \#TIOCOBAUD\#     0x6304 = \#TCURSSRATE\#
  0x5407 = \#TIOCSPGRP\#     0x5414 = \#TIOCCBRK\#      0x6305 = \#TCURSGRATE\#
  0x5409 = \#TIOCSTOP\#      0x5415 = \#TIOCSBRK\#
\end

screen( "F_DUPFD" )
Duplicate File Descriptor                           \#Fcntl Command Code\#
----------------------------------------------------------------------
fd = \#Fcntl\#( F_DUPFD, arg, f );

  <f> is an open \#I/O handle\#.
  <arg> is a number less than 32.


Function returns a new file handle in the range (arg <= fd <= 32).
\end

screen( "F_GETFD" )
Get File Descriptor Inheritance Flag                \#Fcntl Command Code\#
----------------------------------------------------------------------
flag = \#Fcntl\#( F_GETFD, 0L, f );

  <f> is an open \#I/O handle\#.


Function returns 1 if child processes will inherit this file handle,
or 0 otherwise.
\end

screen( "F_SETFD" )
Set File Descriptor Inheritance Flag                \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( F_SETFD, flag, f );

  <flag> is 1 to enable child processes to inherit this file handle,
         or 0 to disable inheritance.
  <f> is an open \#I/O handle\#.
\end

screen( "F_GETFL" )
Get File Flags                                      \#Fcntl Command Code\#
----------------------------------------------------------------------
mode = \#Fcntl\#( F_GETFL, 0L, f );

  <f> is an open \#I/O handle\#.


Function returns the access mode bit flags (see \#Fopen\#).
\end

screen( "F_SETFL" )
Set File Flags                                      \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( F_SETFL, mode, f );

  <mode> contains user bit flags to be set (bits 8-15).
         Bits 0-7 should be zero.
  <f> is an open \#I/O handle\#.
\end

screen( "F_GETLK" )
Get Conflicting File Lock                           \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( F_GETLK, (long) &lock, f );

  <lock> is an \#FLOCK\# structure (two-way parameter).
  <f> is an open \#I/O handle\#.

If there is no conflict with the requested lock, function returns 3.
Otherwise, the conflicting lock is copied into <lock>.
\end

screen( "F_SETLK" )
Set File Lock                                       \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( F_SETLK, (long) &lock, f );

  <lock> is an \#FLOCK\# structure.
  <f> is an open \#I/O handle\#.


Function returns 0 if successful.
\end

screen( "F_SETLKW" )
Set File Lock and Wait                              \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( F_SETLKW, (long) &lock, f );

  <lock> is an \#FLOCK\# structure.
  <f> is an open \#I/O handle\#.


Function waits until conflicting locks are removed.
\end

screen( "FSTAT" )
File Status                                         \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( FSTAT, (long) &xattr, f );

  <xattr> is an \#XATTR\# structure buffer.
  <f> is an open \#I/O handle\#.


Function returns extended file attributes in <xattr>.

See also \#Fxattr\#().
\end

screen( "FIONREAD" )
File I/O Read Buffer                                \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( FIONREAD, (long) &len, f );

  <len> returns the number of bytes left (long).
  <f> is an open \#I/O handle\#.


Function returns the number of bytes which can be read from the I/O
buffer before the physical device must be accessed.
\end

screen( "FIONWRITE" )
File I/O Write Buffer                               \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( FIONWRITE, (long) &len, f );

  <len> returns the number of bytes left (long).
  <f> is an open \#I/O handle\#.


Function returns the number of bytes which can be written to the I/O
buffer before the physical device must be accessed.
\end

screen( "SHMGETBLK" )
Get Shared Memory Block                             \#Fcntl Command Code\#
----------------------------------------------------------------------
addr = (void*) \#Fcntl\#( SHMGETBLK, 0L, f );

  <f> is an open \#I/O handle\# of a shared memory pseudo-file.


Function returns the address of a shared memory block.

See also \#MiNT Shared Memory\#.
\end

screen( "SHMSETBLK" )
Set Shared Memory Block                             \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( SHMSETBLK, addr, f );

  <addr> points to an allocated memory block.
  <f> is an open \#I/O handle\# of a shared memory pseudo-file.


Function attaches the memory block to the pseudo-file.  This replaces
the previous block.

See also \#MiNT Shared Memory\#.
\end

screen( "PPROCADDR" )
Get Process Structure Address                       \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( PPROCADDR, (long) &addr, f );

  <addr> returns a pointer to the process control structure.
  <f> is an open \#I/O handle\# for a process pseudo-file.

Note: The user context structure is located immediately ahead of this
      address.

See also \#MiNT Process\#.
\end

screen( "PBASEADDR" )
Get Process Structure Address                       \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( PBASEADDR, (long) &addr, f );

  <addr> returns a pointer to the process \#BASPAG\# structure.
  <f> is an open \#I/O handle\# for a process pseudo-file.

See also \#MiNT Process\#.
\end

screen( "PCTXTSIZE" )
Get Process Structure Address                       \#Fcntl Command Code\#
----------------------------------------------------------------------
\#Fcntl\#( PCTXTSIZE, (long) &size, f );

  <size> returns the size of the context structure in bytes.
  <f> is an open \#I/O handle\# for a process pseudo-file.


Note: The user context structure is located immediately ahead of the
      process control structure.  The system context structure is
      located immediately ahead of the user context structure.

See also \#MiNT Process\#.
\end

screen( "PSETFLAGS" )
Set PRGFLAGS                                        \#Fcntl Command Code\#
----------------------------------------------------------------------

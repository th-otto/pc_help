  <type> is a data type.  Do NOT use \link("%%GLOBAL%%")char\# or \link("%%GLOBAL%%")float\#.

This macro returns the next argument from a variable argument list.
It must first be initialized by \#va_start\#().

See also \#Standard Library\#.
\end

screen( capsensitive("va_end") )
#include <stdarg.h>

void va_end( void* ap );

  <ap> is the va_list pointer.


This macro is called after the last call to \#va_arg\#().  Actually,
it is there for portability (with Pure C it does nothing).

See also \#Standard Library\#.
\end

screen( capsensitive("exec") )
#include <process.h>

int exec( char *filename, char *cmdlstr, char *envstr, int *retcode );

  <filename> is a NULL terminated string containing the \link("Pathnames")pathname\# for
             the program to be executed.
  <cmdlstr> is a Pascal string containing the command line.
            The first byte contains the number of characters (max 127).
  <envstr> points to the environment parameters, or is NULL to use
           the default (parent's) environment parameters.
           These consist of one or more contiguous NULL terminated
           strings, terminated by a NULL string.
  <retcode> returns the program's return value.


Function executes another program and returns when it is done.
It returns 0 normally, or -1 on an error (see \#errno\#).

See also \#Standard Library\#, \#Pexec\#() and \#shel_write\#().
\end

screen( capsensitive("memchr") )
#include <string.h>

void* memchr( const void *mem, int c, \#size_t\# n );

  <mem> points to the data to be searched.
  <c> is a character (0-255) passed as an int.
  <n> is the number of bytes to search.


Function returns a pointer to the first location in <mem> which
contains the character <c>, or NULL if no match found after <n> bytes.

See also \#String & Character\#.
\end

screen( capsensitive("memcmp") )
#include <string.h>

int memcmp( const void *p1, const void *p2, \#size_t\# n );

  <p1> points to a block of RAM.
  <p2> points to another block of RAM.
  <n> is the number of bytes to compare.


Function compares the first <n> bytes of blocks <p1> and <p2>,
treating them like \link("%%GLOBAL%%")unsigned\# \link("%%GLOBAL%%")char\# strings.

It returns:
   0 if <p1> == <p2>
  <0 if <p1> < <p2>
  >0 if <p1> > <p2> 

See also \#String & Character\#.
\end

screen( capsensitive("memcpy") )
#include <string.h>

void* memcpy( void *dest, const void *source, \#size_t\# n );

  <dest> points to the buffer to be filled.
  <source> points to the data to be copied.
  <n> is the number of bytes to copy.


Function copies <n> bytes from <source> to <dest>.
It returns a pointer to <dest>.

Note: On some systems, if <source> and <dest> are less than <n> bytes
      apart, the results of memcpy() may be different (unpredictable).
      Pure C's memcpy() is the same as \#memmove\#().

See also \#String & Character\#.
\end

screen( capsensitive("memmove") )
#include <string.h>

void* memmove( void *dest, const void *source, \#size_t\# n );

  <dest> points to the buffer to be filled.
  <source> points to the data to be copied.
  <n> is the number of bytes to copy.


Function copies <n> bytes from <source> to <dest>.
It returns a pointer to <to>.

Note: memmove() is more portable than \#memcpy\#().

See also \#String & Character\#.
\end

screen( capsensitive("memset") )

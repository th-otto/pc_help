screen( capsensitive("v_ftext_offset") )
#include <vdi.h>

void v_ftext_offset( int handle, int x, int y, char *string,
                     int *offset );

  <handle> is the \#VDI Handle\#.
  <x> is the x coordinate for the starting alignment point.
  <y> is the y coordinate for the starting alignment point.
  <string> is a NULL terminated text string.
  <offset> is an array of offsets for the next character:
           [0] = x offset from first to second character.
           [1] = y offset from first to second character.
           [2] = x offset from second to third character.
           [3] = y offset from second to third character.
           ...


Function writes a string using the current text attributes, where the
offset from each character to the next is specified.

It only works on outline fonts, and blanks will be ignored.  If blanks
are included in <string>, the <offset> array will be out of sync.

When using MD_REPLACE mode (see \#vswr_mode\#), the background will
not necessarily match the text.

WARNING: The binding in PCGEMLIB is incorrect and will do nothing.
         Copy \#v_ftext_offset bugfix\# for correct binding.

\#VDI Opcode\# 241

See also \#SpeedoGDOS\# and \#VDI Coordinates\#.
\end

screen( "v_ftext_offset bugfix" )
#include <vdi.h>

VDIPB vdipb = {_VDIParBlk.contrl, _VDIParBlk.intin, _VDIParBlk.ptsin,
  _VDIParBlk.intout, _VDIParBlk.ptsout};

void v_ftext_offset(int handle, int x, int y, char *str, int *offset)
 {
  int i,j;

  for(i=0; str[i]; i++) vdipb.intin[i] = (int) str[i];

  vdipb.contrl[0] = 241;
  vdipb.contrl[1] = i + 1;
  vdipb.contrl[3] = i;
  vdipb.contrl[6] = handle;

  vdipb.ptsin[0] = x;
  vdipb.ptsin[1] = y;

  i *= 2;
  for(j=0; j<i; j++) vdipb.ptsin[2+j] = offset[j];

  vdi(&vdipb);
 }
\end


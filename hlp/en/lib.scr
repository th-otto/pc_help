screen( "AES Control Array" )
AES Control Array
----------------------------------------------------------------------
contrl[0]  - \#AES Opcode\# for function
contrl[1]  - number entries in intin[]
contrl[2]  - number entries in intout[]
contrl[3]  - number entries in addrin[]
contrl[4]  - number entries in addrout[]
...        - reserved

See also \#GEMPARBLK\#, \#AESPB\# and \#_crystal\#().
\end

screen( "AES Global Array" )
AES Global Array                                               <aes.h>
----------------------------------------------------------------------
global[0]    - \#AES Version\# number
global[1]    - maximum number of applications supported concurrently
global[2]    - application id
global[3-4]  - application specific info (long)
global[5-6]  - resource file tree base address or 0L
global[7-12] - reserved

This array is filled by \#appl_init\#() and \#rsrc_load\#().

See also \#GEMPARBLK\#, \#AESPB\# and \#_crystal\#().
\end

screen( capsensitive("RSHDR"),
		capsensitive("rshdr") )
\#Resource\# File Header                                           <aes.h>
----------------------------------------------------------------------
typedef struct rshdr
 {
  unsigned  rsh_vrsn;     /* version number (0,1, or 4)           */
  unsigned  rsh_object;   /* offset to \#OBJECT\# array               */
  unsigned  rsh_tedinfo;  /* offset to \#TEDINFO\# array              */
  unsigned  rsh_iconblk;  /* offset to \#ICONBLK\# array              */
  unsigned  rsh_bitblk;   /* offset to \#BITBLK\# array               */
  unsigned  rsh_frstr;    /* offset to free string (char*) array  */
  unsigned  rsh_string;   /* offset to text data                  */
  unsigned  rsh_imdata;   /* offset to image data                 */
  unsigned  rsh_frimg;    /* offset to free image (\#BITBLK\#*) array */
  unsigned  rsh_trindex;  /* offset to tree (\#OBJECT\#*) array       */
  unsigned  rsh_nobs;     /* number objects                       */
  unsigned  rsh_ntree;    /* number trees                         */
  unsigned  rsh_nted;     /* number tedinfos                      */
  unsigned  rsh_nib;      /* number icons                         */
  unsigned  rsh_nbb;      /* number images                        */
  unsigned  rsh_nstring;  /* number free strings                  */
  unsigned  rsh_nimages;  /* number free images                   */
  unsigned  rsh_rssize;   /* size of resource file (bytes), or    */
                          /* offset to \#RSEXT\# structure when       */
                          /* rsh_vrsn == 4                        */
 } RSHDR;

Offsets are given relative to the start of the file, as are all
addresses in the various data structures and pointer arrays.

See also \#RSEXT\# and \#AES_SYSTEM\#.
\end

screen( "RSEXT" )
Resource File Extension
----------------------------------------------------------------------
typedef struct
 {
  long full_size;         /* actual size of resource file (bytes) */
  long rsx_cicon;         /* offset to \#CICONBLK\#* array            */
  long rsx_term;          /* 0L                                   */
 } RSEXT;

Actually, the \#CICONBLK\# array contains NULLs in the resource file,
and is filled when the resource file is loaded into memory.  The array
is terminated with a entry containing -1L.

Immediately following this array is the first color icon definition:

\#CICONBLK\# icon;            /* pointers not filled               */
int mono_data[?];         /* standard icon image               */
int mono_mask[?];         /* standard mask image               */
char icon_text[12];       /* icon text field                   */

For each supported resolution there follows:

\#CICON\# res;                /* pointers not filled               */
int color_data[?];        /* VDI device independent image      */
int color_mask[?];        /* single bit plane image            */
int select_data[?];       /* VDI device independent image      */
int select_mask[?];       /* single bit plane image            */

Some of the pointers in the above structure contain other information:
icon.mainlist contains the number of resolutions supported.
res.sel_data == 0 when there is no separate "selected" image.
res.next_res == 1 when there are more icons following.

After the last resolution, the sequence repeats for the next icon.

Implemented starting with \#AES Version\# 3.30 (rsh_vrsn = 4).

See also \#RSHDR\# and \#AES_SYSTEM\#.
\end

screen( capsensitive("EVENT") )
\#EvntMulti\# Parameter Structure                                  <aes.h>
----------------------------------------------------------------------
typedef struct
 {
/* input parameters */

  int     ev_mflags;        /* MU_KEYBD | MU_BUTTON | MU_M1  */
                            /* MU_M2 | MU_MESAG | MU_TIMER   */
  int     ev_mbclicks;      /* max number button clicks      */
  int     ev_bmask;         /* mouse button mask             */
  int     ev_mbstate;       /* desired mouse button state    */

  int     ev_mm1flags;      /* mouse event #1 flags          */
  int     ev_mm1x;          /* mouse event rectangle #1      */
  int     ev_mm1y;
  int     ev_mm1width;
  int     ev_mm1height;

  int     ev_mm2flags;      /* mouse event #2 flags          */
  int     ev_mm2x;          /* mouse event rectangle #2      */
  int     ev_mm2y;
  int     ev_mm2width;
  int     ev_mm2height;

  int     ev_mtlocount;     /* msec delay for timer event    */
  int     ev_mthicount;     /* 65535 msec delay              */

/* output parameters */

  int     ev_mwich;         /* event flags returned          */
  int     ev_mmox;          /* mouse screen x location       */
  int     ev_mmoy;          /* mouse screen y location       */
  int     ev_mmobutton;     /* mouse button state            */
  int     ev_mmokstate;     /* keyboard state                */
  int     ev_mkreturn;      /* key pressed (scan code/ASCII) */
  int     ev_mbreturn;      /* number button clicks          */
  int     ev_mmgpbuf[8];    /* message buffer                */
} EVENT;

See also \#Event\#, \#evnt_multi\#() and \link("%%GLOBAL%%")Scan Codes\#.
\end

screen( capsensitive("MFORM"),
		capsensitive("mfstr") )
Mouse Form Definition                                          <aes.h>
----------------------------------------------------------------------
typedef struct mfstr
 {
  int     mf_xhot;      /* x location of action point */
  int     mf_yhot;      /* y location of action point */
  int     mf_nplanes;   /* number bit planes (1)      */
  int     mf_fg;        /* foreground color index     */
  int     mf_bg;        /* background color index     */
  int     mf_mask[16];  /* 16x16 bit mask             */
  int     mf_data[16];  /* 16x16 bit image data       */
 } MFORM;

The action point location is given relative to the upper left corner
of the 16x16 space.

The mask determines what part of the 16x16 space will be transparent
(0) or opaque (1).

The image data determines where to use the foreground color (1) or the
background color (0).  The image must fit within the mask.

See also \#graf_mouse\#() and \#vsc_form\#().
\end


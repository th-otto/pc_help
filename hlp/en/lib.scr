screen( "Pathnames" )
Pathnames
----------------------------------------------------------------------
filename.ext             - for files in the current directory
folder.ext\\filename.ext  - for files in a subdirectory
..\\filename.ext          - for files in the parent directory
\\filename.ext            - for files in the root directory of the
                           current drive
x:\\filename.ext          - for files in the root directory of
                           drive 'x'

and any combination thereof, such as

C:\\AUTO\\..\\CPX\\GENERAL.CPX

One can also use device names "\#CON\#:", "\#AUX\#:" and "\#PRN\#:".

One can use wildcards '?' (one character) and '*' (entire field) in
the filename to locate files using partial descriptions.  (It is
possible to create a file which includes wildcards in its name, and
almost impossible to rename or delete it!)

Note: C Language string constants require a "\\\\" sequence to produce
      a single "\\".

Also: One can use "." to refer to the current directory:

C:\\.\\.\\.\\.\\DESKTOP.INF
\end

screen( "mode" )
\#fopen\#() mode strings
----------------------------------------------------------------------
"r"   - read
"w"   - write (erase current contents)
"a"   - append (position stream to end of file)

"rb"  - read binary
"wb"  - write binary (erase current contents)
"ab"  - append binary (position stream to end of file)

"r+"  - read or write
"w+"  - read or write (erase contents)
"a+"  - read or write (position stream to end of file)

In text mode, carriage return (13)/line feed (10) combinations are
  converted into newlines (10) on input, and the opposite conversion
  on output.  Also, the buffer is flushed on newlines.

In binary mode, no conversions are performed on the data and the
  buffer is flushed when full.
\end

screen( "GEMDOS handle",
		"I/O handle" )
GEMDOS file handles
-----------------------------------------------------------------------
Files opened by \#Fopen\# or \#Fcreate\# are assigned an int handle
value greater than 5.

Devices opened using \#Fopen\# will be assigned the following handles:
  \#CON\#:  0xffff (int -1 or long 65535)
  \#AUX\#:  0xfffe (int -2 or long 65534)
  \#PRN\#:  0xfffd (int -3 or long 65533)

Handles 0 to 5 are reserved for standard handles:
  0  \#stdin\#
  1  \#stdout\#
  2  \#stdaux\#
  3  \#stdprn\#
  4  not used
  5  not used

Note: A negative long returned by \#Fopen\# or \#Fcreate\# is used for
      \#BIOS/GEMDOS Error Code\#s.

See also \#Fdup\#() and \#Fforce\#().
\end

screen( capsensitive("sigfunc_t") )
#include <signal.h>

  typedef void (*sigfunc_t)( int );

Example:

void sig_report(int sig)
 {
    printf("sig = %d\\n",sig);
 }

main( void )
 {
  \#signal\#(88, sig_report);
  \#raise\#(88);
  return(0);
 }

See also \#signal number\#.
\end

screen( "signal number" )
Signal Numbers                                              <signal.h>
----------------------------------------------------------------------
Signals 80-89 correspond to ANSI or UNIX signals.
  These can only be initiated by software requests (see \#raise\#).

  SIGABRT   80   /* ANSI, abort */
  SIGTERM   81   /* ANSI, termination */
  SIGFPE    82   /* ANSI, floating point error */
  SIGINT    83   /* ANSI, break request: CNTL-D */
  SIGALRM   84   /* UNIX, Alarm clock */
  SIGKILL   85   /* UNIX, Kill Process */
  SIGUSR1   88   /* UNIX, User defined Signal 1 */
  SIGUSR2   89   /* UNIX, User defined Signal 2 */

Signals 2-79 correspond to the CPU's exception vectors.
  The program's exception handler will be inserted into the requested
  exception vector to save the registers and handle the exception
  stack frame.  It will call the selected signal handler (passing
  the signal number) then restore the registers and return from the
  exception (\link("%%GLOBAL%%")RTE\#).

  SIGSEGV    2   /* ANSI, bus error (segment violation) */
  SIGADR     3   /* adress error */
  SIGILL     4   /* ANSI, illegal instruction */
  SIGDIV0    5   /* division by zero */
  SIGCHK     6   /* CHK */
  SIGTRAPV   7   /* TRAPV */
  SIGPRIV    8   /* privilege violation */
  SIGTRACE   9   /* TRACE */
  SIGLINEA  10   /* LINEA */
  SIGLINEF  11   /* LINEF */
  SIGCPVIO  13   /* Coprocessor Protocol Violation (resd.) */
  SIGFORMAT 14   /* Format Error (reserved) */
  SIGUNINT  15   /* Uninitialized Interrupt (reserved) */
  SIGSPURI  24   /* spurious interrupt */
  SIGAUTO1  25   /* auto interrupt #1 */
  SIGAUTO2  26   /* auto interrupt #2, Hblank */
  SIGAUTO3  27   /* auto interrupt #3 */
  SIGAUTO4  28   /* auto interrupt #4, Vblank */
  SIGAUTO5  29   /* auto interrupt #5 */
  SIGAUTO6  30   /* auto interrupt #6 */
  SIGAUTO7  31   /* auto interrupt #7 */
  SIGTRAP0  32   /* TRAP # 0 */
  SIGTRAP1  33   /* TRAP # 1, GEMDOS */
  SIGTRAP2  34   /* TRAP # 2, AES/VDI */
  SIGTRAP3  35   /* TRAP # 3 */
  SIGTRAP4  36   /* TRAP # 4 */
  SIGTRAP5  37   /* TRAP # 5 */
  SIGTRAP6  38   /* TRAP # 6 */
  SIGTRAP7  39   /* TRAP # 7 */
  SIGTRAP8  40   /* TRAP # 8 */
  SIGTRAP9  41   /* TRAP # 9 */
  SIGTRAP10 42   /* TRAP #10 */
  SIGTRAP11 43   /* TRAP #11 */
  SIGTRAP12 44   /* TRAP #12 */
  SIGTRAP13 45   /* TRAP #13, BIOS */
  SIGTRAP14 46   /* TRAP #14, XBIOS */
  SIGTRAP15 47   /* TRAP #15 */
  SIGFPU0   48   /* FPU Unordered Condition (reserved) */
  SIGFPU1   49   /* FPU Inexact result (reserved) */
  SIGFPU2   50   /* FPU Divide by zero (reserved) */
  SIGFPU3   51   /* FPU Underflow (reserved) */
  SIGFPU4   52   /* FPU Operand Error (reserved) */
  SIGFPU5   53   /* FPU Overflow (reserved) */
  SIGFPU6   54   /* FPU Signaling NaN (reserved) */
  SIGMMU0   56   /* MMU Configuration Error (reserved) */
  SIGMMU1   57   /* MMU (reserved) */
  SIGMMU2   58   /* MMU (reserved) */
  SIGMFP0   64   /* MFP  0, CENTRONICS (disabled) */
  SIGMFP1   65   /* MFP  1, RS232 CD (disabled) */
  SIGMFP2   66   /* MFP  2, RS232 CTS (disabled) */
  SIGMFP3   67   /* MFP  3, Blitter (disabled) */
  SIGMFP4   68   /* MFP  4, RS232 Baud Rate (disabled) */
  SIGMFP5   69   /* MFP  5, 200Hz Clock (enabled) */
  SIGMFP6   70   /* MFP  6, KEYBD, MIDI (enabled) */
  SIGMFP7   71   /* MFP  7, FDC/HDC (disabled) */
  SIGMFP8   72   /* MFP  8, Hsync (disabled) */
  SIGMFP9   73   /* MFP  9, RS232 transmit error */
  SIGMFP10  74   /* MFP 10, RS232 transmit buffer empty */
  SIGMFP11  75   /* MFP 11, RS232 receive error */
  SIGMFP12  76   /* MFP 12, RS232 receive buffer full */
  SIGMFP13  77   /* MFP 13, Timer A (disabled) */
  SIGMFP14  78   /* MFP 14, RS232 RI (disabled) */
  SIGMFP15  79   /* MFP 15, Monitor (disabled) */

Note: Incompatible with <tos.h> for Pure C v1.1
\end

screen( "Time Format Sequences" )
\#strftime\#() Time Format Sequences
----------------------------------------------------------------------
 %a  abbreviated weekday name
 %A  full weekday name
 %b  abbreviated month name
 %B  full month name
 %c  date and time representation (MM/DD/YY HH:MM:DD)
 %d  day of month (1-31)
 %H  hour (0-23)
 %I  hour (1-12)
 %j  day of year (1-366)
 %m  month (1-12)
 %M  minute (0-59)
 %p  AM/PM
 %s  second (0-59)
 %U  week number (0-53) with Sunday as first day of week
 %w  weekday (0=Sunday, ..., 6=Saturday)
 %W  week number (0-53) with Monday as first day of week
 %x  date representation (MM/DD/YY)
 %X  time representation (HH:MM:SS)
 %y  two digit year representation
 %Y  four digit year repesentation
 %Z  time zone name
 %%  percent sign
\end

screen( capsensitive("tm") )
ANSI Standard Time Structure                                  <time.h>
----------------------------------------------------------------------
struct tm
 {
  int tm_sec;   /* seconds after the minute -- [0,  59] */
  int tm_min;   /* minutes after the hour   -- [0,  59] */
  int tm_hour;  /* hours since midnight     -- [0,  23] */
  int tm_mday;  /* day of the month         -- [1,  31] */
  int tm_mon;   /* months since January     -- [0,  11] */
  int tm_year;  /* years since 1900                     */
  int tm_wday;  /* day since Sunday         -- [0,   6] */
  int tm_yday;  /* day since January 1      -- [0, 365] */
  int tm_isdst; /* daylight saving time flag            */
                /* 0=no, >0=yes, <0=unknown             */
 };

See also \#Date & Time\#
\end


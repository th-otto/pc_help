  int    intin[132];    /* input integer array           */
  int    intout[140];   /* output integer array          */
  int    ptsin[145];    /* input point coordinate array  */
  int    ptsout[145];   /* output point coordinate array */
 } VDIPARBLK;

extern  VDIPARBLK _VDIParBlk;

Note: Version 1.0 used \#GEMPARBLK\# to pass VDI parameters.

See also \#VDIPB\#.
\end

screen( capsensitive("VDIPB") )
Global Arrays used to Pass \#VDI\# Parameters                      <vdi.h>
----------------------------------------------------------------------

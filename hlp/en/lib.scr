Base Page Address                                              <tos.h>
---------------------------------------------------------------------- 
  extern \#BASPAG\# *_BasPag;

See also \#PCSTART\#.
\end

screen( capsensitive("_PgmSize") )
Program Size (including stack)                                 <tos.h>
---------------------------------------------------------------------- 
  extern long _PgmSize;

See also \#PCSTART\#.
\end

screen( capsensitive("_app") )
Application Flag                                               <aes.h>
----------------------------------------------------------------------
  extern int _app;   /* 1 = application, 0 = accessory */

See also \#PCSTART\#.
\end

screen( capsensitive("_StkLim") )
Address for lower limit of stack
----------------------------------------------------------------------
  extern void*   _StkLim;

See also \#PCSTART\#.
\end

screen( capsensitive("_RedirTab") )
Redirection Address Table
----------------------------------------------------------------------
  extern void* _RedirTab[6];

The redirection table is neither initialized by \#PCSTART\#, nor is it
used by any library function.  However, \#PCSTART\# contains a pointer to
it two bytes into the TEXT segment of the program, making it easy to
locate by another process.

One can use this feature to redirect I/O of an child process as
follows:

1) Load the child process into RAM using \#Pexec\#().
2) Insert jump vectors from the current process into the _RedirTab of
   the child process.
3) When the child process executes, it must look into _RedirTab for
   these jump vectors and execute them instead of using \#putc\#() etc.

This is how PCC.TTP etc. are able to write into the message window of
Pure C instead of to the \#VT52\# emulator.
\end

screen( capsensitive("_AtExitVec") )
Cleanup jump vector
----------------------------------------------------------------------
  extern void (*_AtExitVec) (void);

If set, this address will be called before the program exits.
It is set by \#atexit\#().

See \#PCSTART\#.
\end

screen( capsensitive("_FilSysVec") )
File system cleanup jump vector
----------------------------------------------------------------------
  extern void (*_FilSysVec) (void);

If set, this address will be called before the program exits.
It is set by \#PCSTDLIB\# I/O functions.

See \#PCSTART\#.
\end

screen( capsensitive("Cookies") )
Standard Cookies
----------------------------------------------------------------------
\#_AKP\#  Atari Keyboard Preference
_CPU  0 (68000) or 30 (68030)
\#_FDC\#  Floppy Disk Controller.
_FLK  Indicates file and record locking extensions to GEMDOS.
\#_FPU\#  Floating Point Processor
_FRB  Pointer to 64K buffer for DMA transfers to \link("%%GLOBAL%%")TT RAM\#.
\#_IDT\#  International Date & Time preference
\#_MCH\#  Machine (model code)
\#_NET\#  Network software installed
\#_SND\#  Sound Hardware
_SWI  Configuration dip switches
\#_VDO\#  Video Hardware
\#FSMC\#  FSM or Speedo GDOS.
\#Gnva\#  Geneva (OS upgrage) structure pointer.
\link("MiNT Version")MiNT\#  MiNT (OS upgrade) version number.
SAM   System Audio Manager.

See also \#get_cookie\#.
\end

screen( "_VDO" )
_VDO Cookie - major/minor part number for video shifter
----------------------------------------------------------------------
  High word: 0=ST, 1=STE, 2=TT, 3=Falcon

See also \#get_cookie\#.
\end

screen( "_SND" )
_SND Cookie - Sound Hardware
----------------------------------------------------------------------
  Bit 0 = GI sound chip
  Bit 1 = stereo DMA sound
  Bit 2 = DMA record
  Bit 3 = 16 bit CODEC
  Bit 4 = DSP

See also \#get_cookie\#.
\end

screen( "_MCH" )
_MCH Cookie - Machine (model)
----------------------------------------------------------------------
      0 = ST
 $10000 = STE
 $10008 = ST Book
 $10010 = Mega STE
 $20000 = TT030
 $30000 = Falcon

See also \#get_cookie\#.
\end

screen( "_FPU" )
_FPU Cookie - Floating Point Processor
----------------------------------------------------------------------
High word:
  0 = no FPU
  1 = SFP004
  2 = either 68881 or 68882
  3 = either 68881 or 68882 plus SPF004
  4 = 68881
  5 = 68881 plus SPF004
  6 = 68882
  7 = 68882 plus SPF004
  8 = 68040 (internal FPU)
  9 = 68040 plus SPF004

See also \#get_cookie\#.
\end

screen( "_IDT" )
_IDT Cookie - International Date & Time preference
----------------------------------------------------------------------
 Bits 12-15 = Time: 0 = 12 hour
                    1 = 24 hour
 Bits 8-11  = Date: 0 = MM-DD-YY
                    1 = DD-MM-YY
                    2 = YY-MM-DD
                    3 = YY-DD-MM
 Bits 0-7   = Date separator character (0 = '/').

See also \#get_cookie\#.
\end

screen( "_AKP" )
_AKP Cookie - Atari Keyboard Preference
----------------------------------------------------------------------
bit 0: 50 Hz screen rate (1).

bits 1-15:
   0 = USA
   1 = Germany
   2 = France
   3 = UK
   4 = Spain
   5 = Italy
   6 = Sweden
   7 = Switzerland (French)
   8 = Switzerland (German)
   9 = Turkey
  10 = Finland
  11 = Norway
  12 = Denmark
  13 = Saudi Arabia
  14 = Holland
  15 = Czechoslovakia
  16 = Hungary

See also \#get_cookie\# and \link("%%GLOBAL%%")palmode\#.
\end

screen( "_FDC" )
_FDC Cookie - Floppy Disk Controller
----------------------------------------------------------------------
Bits 12-15:    0 = standard drive (360K or 720K)
               1 = high density (1.44M)
               2 = extra-high density (2.88M)

Bits 0-11: 'ATC' = Atari Compatible
           'DP1' = DreamPark Development upgrade.

See also \#get_cookie\#.
\end

screen( "_NET" )
_NET Cookie - NET_INFO structure pointer
----------------------------------------------------------------------
typedef struct
 {
  long publisher;
  long version;
 } NET_INFO;

See also \#get_cookie\#.
\end

screen( "FSMC" )
FSMC Cookie - GDOS_INFO structure pointer
----------------------------------------------------------------------
typedef struct
 {
  long         gdos_type;    /* '_FSM' or '_SPD' */
  unsigned int version;
  int          quality;      /* 0=draft, 1=final, -1=default */
 } GDOS_INFO;

See also \#get_cookie\#.
\end

screen( "Gnva" )
Gnva Cookie - Geneva Multitasking \#AES\#
----------------------------------------------------------------------
typedef struct
 {
  int ver;
  char *process_name;
  int apid;
  int (**aes_funcs)();
  int (**xaes_funcs)();
 } G_COOKIE;

See also \#get_cookie\#.
\end

screen( "MiNT Cookie" )
\#MiNT\# Cookie - version number
----------------------------------------------------------------------
(major version << 8) + minor version 

e.g.; version 1.02 is stored as 0x102L.

See also \#get_cookie\#.
\end

screen( "get_cookie" )
/* *******************************************************************
                          get_cookie
pname is address of cookie name (long or 4 character string).
pval returns the cookie value (long, pointer or bit field structure).

Returns TRUE (-1) if cookie found, FALSE (0) if not found.
******************************************************************* */
#include <tos.h>

extern long \#cookie_jar\#( null );       /* assembly language function */

int get_cookie(void* pname, void* pval)
 {
  unsigned char *p;
  long name,*jar;

  jar = (long*) Supexec(cookie_jar);
  if(!jar) return(0);

  p = pname;
  name = ((((( (long) p[0] << 8) | p[1]) << 8) | p[2]) << 8) | p[3];

  while(*jar) {
    if(*jar == name) {
      *((long*) pval) = *(++jar);
      return(-1);
     }
    jar+=2;
   }
  return(0);
 }
\end

screen( "cookie_jar" )
/* *******************************************************************
long cookie_jar(void);

returns pointer to cookie jar.  Must be executed in Supervisor mode.
******************************************************************* */
globl cookie_jar

cookie_jar:
    move.l  $5A0,D0
    rts
\end


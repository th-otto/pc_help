#include <graphics.h>

void setwritemode( int mode );

  <clip> is the writing mode: COPY_PUT or XOR_PUT.


Function sets the writing mode for drawing straight lines.
Affects only \#line\#(), \#lineto\#(), \#linerel\#(), \#rectangle\#() & \#drawpoly\#().

VDI: \#vswr_mode\#()

See also \#BGI Attributes\# and \#graphresult\#().
\end


screen( "Cauxin",
        sensitive("CAUXIN") )
Cauxin                                                    Unit Tos
------------------------------------------------------------------

Deklaration       function  Cauxin : Integer

Beschreibung      Die Funktion Cauxin liest ein Zeichen von der
                  seriellen Schnittstelle ein. Die Funktion wartet
                  gegebenenfalls bis ein Zeichen bereitsteht.

Querverweis       \#Cauxis\#             \#Cauxout\#
\end

screen( "Cauxis",
        sensitive("CAUXIS") )
Cauxis                                                    Unit Tos
------------------------------------------------------------------

Deklaration       function  Cauxis : Integer

Beschreibung      Die Funktion Cauxis überprüft, ob ein Zeichen
                  von der seriellen Schnittstelle gelesen werden
                  kann. Liegt ein Zeichen vor, erhält man als
                  Funktionsresultat -1, sonst 0.

Querverweis       \#Cauxos\#             \#Cauxin\#
\end

screen( "Cauxos",
        sensitive("CAUXOS") )
Cauxos                                                    Unit Tos
------------------------------------------------------------------

Deklaration       function  Cauxos : Integer

Beschreibung      Die Funktion Cauxos überprüft, ob ein Zeichen
                  über die seriellen Schnittstelle ausgegeben
                  werden kann. Kann ein Zeichen übertragen werden,
                  erhält man als Funktionsresultat -1, sonst 0.

Querverweis       \#Cauxis\#             \#Cauxout\#
\end

screen( "Cauxout",
        sensitive("CAUXOUT") )
Cauxout                                                   Unit Tos
------------------------------------------------------------------

Deklaration       procedure  Cauxout( c : Integer )

Beschreibung      Die Prozedur Cauxout gibt das Zeichen c auf der
                  serielle Schnittstelle aus.

Querverweis       \#Cauxos\#             \#Cauxin\#
\end

screen( "Cconin",
        sensitive("CCONIN") )
Cconin                                                    Unit Tos
------------------------------------------------------------------

Gemdosfunktion 1

Deklaration    function Cconin : LongInt;

Beschreibung   Die GEMDOS-Routine Cconin liest ein Zeichen vom
               Standardeingabekanal. Der Standardeingabekanal ist
               defaultmässig mit der Tastatur verbunden, kann aber
               über die GEMDOS-Funktion \#Fforce\# mit anderen
               Eingabegeräten assoziiert werden.

Resultat       Die Funktion liefert als Resultat das eingelesene
               Zeichen. Falls das eingelesene Zeichen von der
               Tastatur kommt, befindet sich der Ascii-Code des
               Zeichens in den Bits 0..7 des Langwortresultates,
               die Bits 16..23 enthalten den Scancode der Tastatur.

Querverweis    \#Cconout\#   \#Cconis\#   \#Fforce\#
\end

screen( "Cconis",
        sensitive("CCONIS") )
Cconis                                                    Unit Tos
------------------------------------------------------------------

Gemdosfunktion 11

Deklaration    function Cconis : Integer;

Beschreibung   Die GEMDOS-Funktion Cconis überprüft, ob auf dem
               Standardeingabekanal Eingabezeichen bereit sind.
               Der Standardeingabekanal ist defaultmässig mit der
               Tastatur verbunden.

Resultat       Die Funktion liefert als Resultat -1, wenn Eingabe-
               zeichen vorliegen, sonst 0.

Querverweis    \#Cconin\#
\end

screen( "Cconout",
        sensitive("CCONOUT") )
Cconout                                                   Unit Tos
------------------------------------------------------------------

Gemdosfunktion 2

Deklaration    procedure Cconout( c : Integer );

Beschreibung   Die GEMDOS-Funktion Cconout gibt das Zeichen c auf
               den Standardausgabekanal aus. Der Standardausgabe-
               kanal ist defaultmässig mit dem Bildschirm
               assoziiert.

Querverweis    \#Cconin\#, \#Cconos\#
\end

screen( "Cconos",
        sensitive("CCONOS") )
Cconos                                                    Unit Tos
------------------------------------------------------------------

Gemdosfunktion 16

Deklaration    function Cconos : Integer;

Beschreibung   Die GEMDOS-Funktion Cconos überprüft, ob der
               Standardausgabekanal bereit ist, Zeichen anzunehmen.
               Der Standardausgabekanal ist defaultmässig mit dem
               Bildschirm assoziiert.

Resultat       Die Funktion liefert als Resultat den Status des
               Standardausgabekanals. Wenn der Standardausgabe-
               kanal bereit ist, ein Zeichen anzunehmen, wird -1
               zurückgegeben, sonst 0.

Querverweis    \#Cconout\#
\end

screen( "Cconrs",
        sensitive("CCONRS"),
        sensitive("LINEPTR") )
Cconrs                                                    Unit Tos
------------------------------------------------------------------

Gemdosfunktion 10

Deklaration    procedure Cconrs( var buf : LINE );

               LINEPTR = ^LINE;
               LINE = record
                   maxlen : Byte;
                   buffer : String;
               end;

Beschreibung   Die GEMDOS-Funktion Cconrs liest einen String vom
               Standardeingabekanal. Die Eingabe wird durch die
               RETURN-Taste abgeschlossen. Der Eingabestring kann
               editiert werden. Vor dem Aufruf muss buf.maxlen die
               Anzahl der maximal einzugebenden Zeichen zugewiesen
               bekommen. Der Standardkanal ist defaultmässig mit
               der Tastatur verbunden.

Resultat       Nach AbschluŞ der Funktion enthält buf.buffer einen
               Pascal-String mit der Eingabe.

Querverweis    \#Cconws\#
\end

screen( "Cconws",
        sensitive("CCONWS") )
Cconws                                                    Unit Tos
------------------------------------------------------------------

Gemdosfunktion 9

Deklaration    procedure Cconws( str : String );

Beschreibung   Die GEMDOS-Funktion Cconws schreibt einen String
               auf den Standardausgabekanal. Der String in buf
               muŞ mit dem ASCII-Zeichen 0 terminiert sein. Der
               Standardausgabekanal ist defaultmässig mit dem
               Bildschirm verbunden.

Resultat       Die Funktion liefert als Resultat die Anzahl der
               tatsächlich ausgegebenen Zeichen.

Querverweis    \#Cconrs\#
\end

screen( "Cnecin",
        sensitive("CNECIN") )
Cnecin                                                    Unit Tos
------------------------------------------------------------------

Gemdosfunktion 8

Deklaration    function Cnecin : LongInt;

Beschreibung   Die GEMDOS-Funktion Cnecin liest ein Zeichen direkt
               vom Standardeingabekanal, ohne daŞ das Zeichen auf
               dem Standardausgabekanal ausgegeben wird.

Resultat       Die Funktion liefert als Resultat das eingelesene
               Zeichen.

Querverweis    \#Cconin\#   \#Crawcin\#   \#Crawio\#
\end

screen( "Cprnos",
        sensitive("CPRNOS") )
Cprnos                                                    Unit Tos
------------------------------------------------------------------

Gemdosfunktion 17

Deklaration    function Cprnos : Integer;

Beschreibung   Die GEMDOS-Funktion Cprnos überprüft, ob die
               Druckerschnittstelle PRN: bereit ist, Zeichen
               anzunehmen.

Resultat       Die Funktion liefert als Resultat den Drucker-
               Status. Wenn der Drucker bereit ist, ein Zeichen
               anzunehmen, wird ein Wert ungleich 0 zurückgegeben,
               sonst 0.

Querverweis    \#Cconos\#
\end

screen( "Cprnout",
        sensitive("CPRNOUT") )
Cprnout                                                   Unit Tos
------------------------------------------------------------------

Gemdosfunktion 5

Deklaration    function Cprnout( c : Integer ) : Integer;

Beschreibung   Die GEMDOS-Funktion Cprnout gibt das Zeichen c auf
               die Druckerschnittstelle PRN: aus.

Resultat       Die Funktion liefert als Resultat -1, wenn das
               Zeichen an den Drucker ausgegeben werden konnte.
               Falls der Drucker nicht bereit ist (Busy oder
               Offline) wird 0 zurückgegeben.

Querverweis    \#Cprnos\#
\end

screen( "Crawcin",
        sensitive("CRAWCIN") )
Crawcin                                                   Unit Tos
------------------------------------------------------------------

Gemdosfunktion 7

Deklaration    function Crawcin : LongInt;

Beschreibung   Die GEMDOS-Funktion Crawcin liest ein Zeichen vom
               Standardeingabekanal. Das Zeichen wird nicht inter-
               pretiert und nicht auf dem Standardausgabekanal
               ausgegeben. Das heiŞt, daŞ <Control-C>, <Control-S>
               und <Control-Q> ignoriert werden.

Resultat       Die Funktion liefert als Resultat das eingelesene
               Zeichen.

Querverweis    \#Cconin\#   \#Cconout\#   \#Crawio\#
\end

screen( "Crawio",
        sensitive("CRAWIO") )
Crawio                                                    Unit Tos
------------------------------------------------------------------

Gemdosfunktion 6

Deklaration    function Crawio( w : Integer ) : LongInt;

Beschreibung   Die GEMDOS-Funktion Crawio führt ungepufferte Ein-
               Ausgaben durch. Wenn als Argument w die Zahl $FF
               übergeben wurde, dann wird ein Zeichen vom Standard-
               eingabekanal gelesen. Wenn w einen anderen Wert hat,
               wird das Zeichen auf den Standardausgabekanal aus-
               gegeben.

Resultat       Die Funktion liefert als Resultat das eingelesene
               Zeichen.

Querverweis    \#Cconin\#   \#Cconout\#
\end

screen( "Dcreate",
        sensitive("DCREATE") )
Dcreate                                                   Unit Tos
------------------------------------------------------------------

Gemdosfunktion 57

Deklaration    function Dcreate( pathname : String ) : Integer;

Beschreibung   Die GEMDOS-Funktion Dcreate erzeugt ein Verzeichnis
               mit dem Pfadnamen path. Der String path muŞ mit dem
               ASCII-Zeichen 0 abgeschlossen sein.

Resultat       Die Funktion liefert 0 falls das Verzeichnis
               erzeugt werden konnte oder einen negativen Fehler-
               code.

Querverweis    \#Ddelete\#
\end

screen( "Ddelete",
        sensitive("DDELETE") )
Ddelete                                                   Unit Tos
------------------------------------------------------------------

Gemdosfunktion 58

Deklaration    function Ddelete( pathname : String ) : Integer;

Beschreibung   Die GEMDOS-Funktion Ddelete löscht das Verzeichnis
               mit dem Pfadnamen path, falls es keine weiteren
               Dateien oder Unterverzeichnisse enthält. Der String
               path muŞ mit dem ASCII-Zeichen 0 abgeschlossen sein.

Resultat       Die Funktion liefert als Resultat eine 0, wenn das
               Verzeichnis gelöscht werden konnte, sonst einen
               negativen Fehlercode.

Querverweis    \#Dcreate\#
\end

screen( "Dfree",
        sensitive("DFREE"),
        sensitive("DISKINFO"),
        sensitive("DISKINFOPTR") )
Dfree                                                     Unit Tos
------------------------------------------------------------------

Gemdosfunktion 54

Deklaration    function Dfree( var buf : DISKINFO; drv : Integer ):
               LongInt;

               DISKINFOPtr = ^DISKINFO;
               DISKINFO = record
                   b_free :      LongInt;
                   b_total :  LongInt;
                   b_secsiz : LongInt;
                   b_clsiz :  LongInt;
               end;

Beschreibung   Die GEMDOS-Funktion Dfree ermittelt die Gesamt-
               Kapazität und den freien Speicherplatz eines Lauf-
               werks driveno. Als Parameter wird ein DISKINFO
               Record übergeben, in den die Funktion die Infor-
               mationen einträgt.

Resultat       Die Funktion liefert bei korrekter Ausführung den
               Wert 0, sonst einen negativen Fehlercode.
\end

screen( "Dgetdrv",
        sensitive("DGETDRV") )
Dgetdrv                                                   Unit Tos
------------------------------------------------------------------

Gemdosfunktion 25

Deklaration    function Dgetdrv : Integer;

Beschreibung   Die GEMDOS-Funktion Dgetdrv liefert das aktuelle
               Laufwerk.

Resultat       Die Funktion liefert als Resultat einen Code für
               das aktuelle Laufwerk:

               0      A:
               1      B:
               2      C:
               3      D:      usw.

Querverweis    \#Dsetdrv\#
\end

screen( "Dgetpath",
        sensitive("DGETPATH") )
Dgetpath                                                  Unit Tos
------------------------------------------------------------------

Gemdosfunktion 71

Deklaration    function Dgetpath( var buf : String;
                                  driveno : Integer ) : Integer;

Beschreibung   Die GEMDOS-Funktion Dgetpath liefert das aktuelle
               Verzeichnis für das Laufwerk driveno. Der Pfad wird
               im Puffer path als String zurückgegeben. GEMDOS-
               Pfadnamen können bis zu 128 Zeichen lang sein,
               daher sollte der Puffer entsprechend groŞ angelegt
               werden. Der Parameter driveno erhält einen Code für
               das Laufwerk:

               0      aktuelles Laufwerk
               1      A:
               2      B:
               3      C:
               4      D:      usw.

Achtung!       Im Gegensatz zu allen anderen Laufwerks-Funktion
               wird hier das Laufwerk A: mit 1 codiert !

Resultat       Die Funktion liefert als Resultat 0, wenn kein
               Fehler auftrat, sonst einen negativen Fehlercode.

Querverweis    \#Dsetpath\#
\end

screen( "Dsetdrv",
        sensitive("DSETDRV") )
Dsetdrv                                                   Unit Tos
------------------------------------------------------------------

Gemdosfunktion 14

Deklaration    function Dsetdrv( drv : Integer ) : LongInt;

Beschreibung   Die GEMDOS-Funktion Dsetdrv setzt das aktuelle Lauf-
               werk auf drv. Der Parameter drv wird wie folgt
               codiert:

               0      A:
               1      B:
               2      C:
               3      D:      usw.

Resultat       Die Funktion liefert als Resultat einen Bit-Vektor
               der verfügbaren Laufwerke. Für jedes verfügbare
               Laufwerk ist das entsprechende Bit gesetzt. Dabei
               entspricht Bit 0 dem Laufwerk A: etc.

Querverweis    \#Dgetdrv\#
\end

screen( "Dsetpath",
        sensitive("DSETPATH") )
Dsetpath                                                  Unit Tos
------------------------------------------------------------------

Gemdosfunktion 59

Deklaration    function Dsetpath( path : String ) : Integer;

Beschreibung   Die GEMDOS-Funktion Dsetpath setzt das aktuelle Ver-
               zeichnis auf den Pfadnamen path. Der String-
               Parameter path muŞ mit dem ASCII-Zeichen 0 abge-
               schlossen sein.

Resultat       Die Funktion liefert als Resultat eine 0, wenn das
               Verzeichnis existiert, sonst einen negativen Fehler-
               code.

Querverweis    \#Dgetpath\#
\end

screen( "Fattrib",
        sensitive("FATTRIB") )
Fattrib                                                   Unit Tos
------------------------------------------------------------------

Gemdosfunktion 67

Deklaration    function Fattrib( fname : String;
                                 wflag, attribs : Integer ) :
               Integer;

Beschreibung   Die GEMDOS-Funktion Fattrib liest oder setzt die
               Attribute der mit filename bezeichneten Datei. Für
               den Parameter attribs sind folgende Werte zulässig:

               FA_RDONLY      Datei darf nur gelesen werden.
               FA_HIDDEN      Datei wird beim Auflisten des
                              Dateiverzeichnisses nicht angezeigt.
               FA_SYSTEM       Systemdatei.
               FA_LABEL       Diskettenname (11 Bytes).
               FA_DIREC       Unterverzeichnis.
               FA_ARCH        Datei wurde verändert.

               Für den Parameter wflag sind folgende Werte
               zulässig:

               0              Attribute lesen
               1              Attribute setzen

Resultat       Die Funktion liefert als Resultat die Attribute,
               wenn die Attribute gelesen werdenkonnten , sonst
               ist das Resultat nicht definiert.
\end

screen( "Fclose",
        sensitive("FCLOSE") )
Fclose                                                    Unit Tos
------------------------------------------------------------------

Gemdosfunktion 62

Deklaration    function Fclose( handle : Integer ) : Integer;

Beschreibung   Die GEMDOS-Funktion Fclose schlieŞt die Datei mit
               dem Dateibezeichner handle. Falls die Datei im Netz-
               werk mit einem Locking versehen wurde, wird das
               Locking aufgehoben.

Resultat       Die Funktion liefert als Resultat 0, wenn die Datei
               geschlossen werden konnte, sonst einen negativen
               Fehlercode.

Querverweis    \#Fopen\#
\end

screen( "Fcreate",
        sensitive("FCREATE") )
Fcreate                                                   Unit Tos
------------------------------------------------------------------

Deklaration    function  Fcreate( fname : String;
                                   attribs : Integer ) : LongInt;

Beschreibung   Die Funktion Fcreate erzeugt eine Datei mit dem
               Pfadnamen fname. Der Parameter attr legt das Attri-
               but der Datei fest und kann aus den folgenden,
               mit \link("%%GLOBAL%%")or\# verknüpfbaren Flags zusammengesetzt werden:

               ---------------------------------------------------
               attr           Bedeutung
               ---------------------------------------------------
               FA_RDONLY      Datei ist schreibgeschützt.
               FA_HIDDEN      Datei wird beim Auflisten des
                              Dateiverzeichnisses nicht angezeigt.
               FA_SYSTEM      Systemdatei.
               FA_DIREC       Eintrag ist keine Datei, sondern
                              Laufwerkkennung.
               ---------------------------------------------------

Resultat       Die Funktion liefert als Resultat einen LongInt-
               Wert. Ist dieser negativ, so trat ein Fehler auf.
               Andernfalls steht das niederwertige Wort des Re-
               sultats ein Handle, das in nachfolgenden Schreib-/
               Lese-Operationen als Dateikennung verwendet wird.

Bespiel        {$X+}
               uses Tos;
               var
                  handle : Integer;
                  result : LongInt;
                  c : Char;
               begin
                 result := Fcreate( 'TEST.DAT', 0 );
                 if result < 0 then
                   Halt( 1 );
                 handle := Integer( result );
                 c := 'x';
                 Fwrite( handle, 1, @c );
                 Fclose( handle );
               end.

Querverweis    \#Fopen\#
\end

screen( "Fdatime",
        sensitive("DOSTIME"),
        sensitive("DOSTIMEPTR"),
        sensitive("FDATIME") )
Fdatime                                                   Unit Tos
------------------------------------------------------------------

Gemdosfunktion 87

Deklaration    procedure Fdatime( var timeptr : DOSTIME;
                                  handle, wflag : Integer );

               DOSTIMEPtr = ^DOSTIME;
               DOSTIME = record
                   time : Word;
                   date : Word;
               end;

Beschreibung   Die GEMDOS-Funktion Fdatime liest oder setzt Datum
               und Uhrzeit der Datei mit dem Bezeichner handle.
               Der Parameter timeptr zeigt auf die Struktur
               DOSTIME. Der Parameter wflag kann folgende Werte
               annehmen:

               0     Datum / Uhrzeit der Datei lesen
               1     Datum / Uhrzeit der Datei setzen
               
Resultat       Die Funktion liefert als Resultat Datum und Uhrzeit
               oder Wert 0 in time und date falls der zugriff auf
               die Datei nicht erfolgreich war.
\end

screen( "Fdelete",

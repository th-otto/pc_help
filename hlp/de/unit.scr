------------------------------------------------------------------

Die Unit Gem definiert die folgenden Konstanten zur Schriftaus-
richtung mittels \#vst_alignment\#:

    const                   { Horizontale Ausrichtung:           }
          TA_LEFT     = 0;  { Linksjustiert                      }
          TA_CENTER   = 1;  { Zentriert                          }
          TA_RIGHT    = 2;  { Rechtsjustiert                     }

                            { Vertikale Ausrichtung:             }
          TA_BASELINE = 0;  { Basislinie                         }
          TA_HALF     = 1;  { Halblinie (Oberkante Kleinbuchst.) }
          TA_ASCENT   = 2;  { Zeichenoberkante                   }
          TA_BOTTOM   = 3;  { Zeichenzellenunterkante            }
          TA_DESCENT  = 4;  { Zeichenunterkante                  }
          TA_TOP      = 5;  { Zeichenzellenoberkante             }
\end


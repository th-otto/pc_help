          Yellow   = 6;   { gelb           }
          Magenta  = 7;   { fuchsinrot     }
          LWhite   = 8;   { hellgrau       }
          LBlack   = 9;   { dunkelgrau     }
          LRed     = 10;  { hellrot        }
          LGreen   = 11;  { hellgrün       }
          LBlue    = 12;  { hellblau       }
          LCyan    = 13;  { helltürkis     }
          LYellow  = 14;  { hellgelb       }
          LMagenta = 15;  { hellfuchsinrot }
\end

screen( "Schreibmodus",
        sensitive("MD_ERASE"),
        sensitive("MD_REPLACE"),
        sensitive("MD_TRANS"),
        sensitive("MD_XOR") )
Schreibmodus                                              Unit Gem
------------------------------------------------------------------

Die Unit Gem definiert die folgenden Konstanten zum Setzen eines
Schreibmodus mit der Funktion \#vswr_mode\#:

    const
          { Neu := (Vorn AND Maske) OR (Hinten AND NOT Maske }
          MD_REPLACE = 1;

          { Neu := (Vorn AND Maske) OR (Alt AND NOT Maske }
          MD_TRANS   = 2;

          { Neu := Maske XOR Alt }
          MD_XOR     = 3;

          { Neu := (Alt AND Maske) OR (Vorn AND NOT Maske }
          MD_ERASE   = 4;

Die Formel über den Schreibmodi gibt die Verknüpfung der einzelnen
Bits an. Die Bezeichner haben die folgenden Bedeutungen:

    Neu        Neue Farbe
    Alt        Aktuelle Farbe
    Maske      Grafikobjekt
    Vorn       Vordergrundfarbe des Grafikobjekts
    Hinten     Hintergrundfarbe des Grafikobjekts
\end


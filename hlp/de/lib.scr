screen( capsensitive("BASPAG"),
		capsensitive("p_bbase"),
		capsensitive("p_blen"),
		capsensitive("p_cmdlin"),
		capsensitive("p_curdrv"),
		capsensitive("p_dbase"),
		capsensitive("p_dlen"),
		capsensitive("p_dta"),
